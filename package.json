{
  "name": "nixoncreativestudio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run placeholders && npm run og:pages && astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "placeholders": "node scripts/generate-placeholders.mjs",
    "og": "node scripts/generate-og-default.mjs",
    "og:pages": "node scripts/generate-og.mjs",
    "test": "node --experimental-strip-types --test src/lib/*.test.ts",
    "lint": "eslint src/**/*.{ts,tsx,astro} scripts/**/*.mjs",
    "lint:fix": "eslint --fix src/**/*.{ts,tsx,astro} scripts/**/*.mjs",
    "format": "prettier --write .",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.4",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource/bebas-neue": "^5.2.7",
    "@react-three/fiber": "^9.6.1",
    "@tabler/icons": "^3.44.0",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.7",
    "astro-expressive-code": "^0.43.1",
    "astro-pagefind": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "plaiceholder": "^3.0.0",
    "primereact": "^10.9.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-photo-album": "^3.6.0",
    "shadcn": "^4.8.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "opentype.js": "^2.0.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
