# =============================================================================
# Nixon Creative Studio | Environment Variables (Template)
# =============================================================================
# Copy this file to .env and fill in real values. Never commit the real .env;
# it stays out of git via .gitignore.
#
# In Astro, the PUBLIC_ prefix exposes the variable to client-side code.
# Without it, the variable would only be readable on the server, which would
# not work for the contact form (it runs in the browser).
#
# When deploying to Cloudflare Pages, ADD THE SAME VARIABLE in the dashboard:
#   Workers & Pages > nixoncreativestudio > Settings > Environment variables
# Add it for both Production and Preview environments, then trigger a redeploy.
# =============================================================================


# -----------------------------------------------------------------------------
# Web3Forms access key
# -----------------------------------------------------------------------------
# Free serverless form handler. Get a key from https://web3forms.com/
# by entering the email where inquiries should land. The key is not a
# secret in the traditional sense, but treating it like one keeps it out
# of source history if it ever needs to be rotated.
# -----------------------------------------------------------------------------
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key-here


# -----------------------------------------------------------------------------
# Cloudflare Web Analytics token
# -----------------------------------------------------------------------------
# Privacy-friendly traffic analytics from Cloudflare. Free at our volume,
# no cookie banner needed. Get a token at:
#   dash.cloudflare.com > Analytics & Logs > Web Analytics > Add a site
#
# If empty, the analytics beacon simply doesn't render. Set it locally
# AND in Cloudflare Pages > Settings > Build > Variables and secrets so
# the production build embeds the script tag.
# -----------------------------------------------------------------------------
PUBLIC_CF_ANALYTICS_TOKEN=your-cloudflare-analytics-token-here
