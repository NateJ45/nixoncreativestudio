# =============================================================================
# Nixon Creative Studio | Environment Variables (Template)
# =============================================================================
# Copy this file to .env and fill in real values. Never commit the real .env;
# it stays out of git via .gitignore.
#
# In Astro, the PUBLIC_ prefix exposes the variable to client-side code.
# Without it, the variable would only be readable on the server, which would
# not work for the contact form (it runs in the browser).
#
# When deploying to Cloudflare Pages, ADD THE SAME VARIABLE in the dashboard:
#   Workers & Pages > nixoncreativestudio > Settings > Environment variables
# Add it for both Production and Preview environments, then trigger a redeploy.
# =============================================================================


# -----------------------------------------------------------------------------
# Web3Forms access key
# -----------------------------------------------------------------------------
# Free serverless form handler. Get a key from https://web3forms.com/
# by entering the email where inquiries should land. The key is not a
# secret in the traditional sense, but treating it like one keeps it out
# of source history if it ever needs to be rotated.
# -----------------------------------------------------------------------------
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key-here


# -----------------------------------------------------------------------------
# Cloudflare Web Analytics token
# -----------------------------------------------------------------------------
# Privacy-friendly traffic analytics from Cloudflare. Free at our volume,
# no cookie banner needed. Get a token at:
#   dash.cloudflare.com > Analytics & Logs > Web Analytics > Add a site
#
# If empty, the analytics beacon simply doesn't render. Set it locally
# AND in Cloudflare Pages > Settings > Build > Variables and secrets so
# the production build embeds the script tag.
# -----------------------------------------------------------------------------
PUBLIC_CF_ANALYTICS_TOKEN=your-cloudflare-analytics-token-here


# -----------------------------------------------------------------------------
# Coming Soon gate
# -----------------------------------------------------------------------------
# When set to the literal string "true" at build time, every page ships
# with both the real content and a ComingSoon overlay. A small inline
# script in <head> decides which to show by checking the visitor's
# localStorage for a matching PUBLIC_PREVIEW_TOKEN. /coming-soon/ itself
# is always live regardless of this var.
#
# Cloudflare Pages: add the var to Settings > Variables and Secrets,
# then trigger a redeploy. To launch the site, change the value to
# anything other than "true" (or remove the var entirely) and redeploy.
#
# Local dev: set in .env. Unset = full WIP site visible; "true" = gated
# (unless localStorage carries the bypass token).
#
# This is a soft gate, not security. The real HTML ships in the source
# either way. For real auth, layer Cloudflare Access on top.
# -----------------------------------------------------------------------------
PUBLIC_COMING_SOON=false


# -----------------------------------------------------------------------------
# Coming Soon bypass token
# -----------------------------------------------------------------------------
# Random secret string that unlocks the gate for you. Pick something
# long and hard to guess (e.g., a UUID or 32+ random chars). Anyone
# who knows this token can bypass the gate, so don't share it.
#
# PUBLIC_ prefix is required: the value is inlined into the gate script
# at build time so the script can compare against URL params and
# localStorage. This means the token IS visible in shipped HTML to
# anyone viewing source — soft gate, not security.
#
# How to use:
#   1. Set PUBLIC_COMING_SOON=true and PUBLIC_PREVIEW_TOKEN=<your-secret>
#      in Cloudflare Pages env vars. Trigger a redeploy.
#   2. On every device where you want to bypass, visit any URL once with
#      ?preview=<your-secret> appended, e.g.:
#        https://nixoncreativestudio.com/?preview=<your-secret>
#   3. The script saves the token to localStorage and reloads the page
#      without the query param. From then on, that browser bypasses the
#      gate on every page.
#
# To revoke your bypass: clear localStorage for the site in your browser.
# To rotate the token: change PUBLIC_PREVIEW_TOKEN here and redeploy.
# All existing localStorage entries stop matching; visit the bypass URL
# again with the new token to re-enable.
# -----------------------------------------------------------------------------
PUBLIC_PREVIEW_TOKEN=change-this-to-something-random
