# Installed npm packages. Reproducible from package-lock.json, so never committed.
node_modules/

# Astro production build output. Regenerated by `npm run build` on every deploy.
dist/

# Astro's internal cache and generated type files (content collection types, etc.).
# Safe to delete locally; Astro rebuilds it on the next dev/build run.
.astro/

# Environment variables. Keep secrets (API keys, tokens) out of the repo.
# .env.example may be committed if a template is useful for new setups.
.env
.env.*
!.env.example

# Package-manager debug logs. Created when an install or run command fails.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# macOS Finder metadata. Created automatically when browsing folders in Finder.
.DS_Store

# VS Code workspace settings. Personal editor config, not project-wide truth.
# If a shared setting becomes important (recommended extensions, format-on-save),
# commit a specific file like .vscode/extensions.json by un-ignoring it.
.vscode/

# JetBrains IDE settings folder (WebStorm, IntelliJ). Same reasoning as .vscode/.
.idea/

# Claude Code per-machine settings. The shared `.claude/settings.json` (without
# `.local`) may be committed; the `.local.json` variant is personal and ignored.
.claude/settings.local.json

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example

# Playwright MCP scratch directory. The MCP writes page snapshots and console
# logs here while it drives the browser; transient, regenerated every run.
.playwright-mcp/

# Ad-hoc Playwright screenshots saved during visual checks. Useful in the
# moment, not part of the source.
phase-*.png

# Lighthouse audit reports and Chrome DevTools performance traces. Generated
# on demand when auditing the site; regenerated every run, large JSON files,
# not part of source. Pattern catches .lighthouse/, .lighthouse-mobile/, and
# any future per-run directory.
.lighthouse*/

# Microsoft Office lock files (Word, Excel). Auto-created while a document is
# open; auto-removed when it closes. Should never end up in the repo.
~$*
