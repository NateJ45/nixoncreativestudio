---
// Safe to edit. This page is a Derek Sivers-style /now page. The arrays
// below hold the content; rewrite them when the season changes (about
// once a quarter is the right cadence).
/* ============================================================================
   /now | What I'm working on right now
   ============================================================================
   Standalone page that gives a present-tense snapshot of the studio:
   client work, personal projects, what I'm reading, what I'm shooting,
   what I'm learning. Updated quarterly-ish.

   This format originated from Derek Sivers (https://nownownow.com/about)
   as an antidote to outdated "about" pages. It works well for a one-
   person studio because it gives returning visitors a fresh signal
   without forcing them to dig through a blog.

   The "Last updated" stamp is important: it's the trust signal that this
   page reflects current reality, not a forgotten placeholder. The status
   pill at the top of the page turns that same date into a live relative
   label ("Updated N weeks ago") computed at build time.

   LAYOUT NOTES (the revamp):
   - Status pill up top with a pulsing dot + relative-freshness label.
   - "Working on" renders as a vertical timeline with connected nodes.
   - "Booking" renders as availability chips (open / limited signals).
   - "Reading" and "Learning" render as scroll-revealed cards.
   - Every block fades + rises in on scroll via the data-reveal vocabulary,
     which is reduced-motion safe by default.
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';

// Update this when you edit the page. Plain ISO date.
const lastUpdated = '2026-06-15';
const lastUpdatedLabel = new Intl.DateTimeFormat('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
}).format(new Date(lastUpdated));

// Relative freshness label for the status pill, computed from lastUpdated.
// Reads in the largest sensible unit: today / N days / N weeks / N months.
// This is the trust signal. If it ever says "8 months ago," that's the
// nudge to rewrite the arrays below.
function freshnessLabel(iso: string): string {
  const then = new Date(iso).getTime();
  const now = Date.now();
  const days = Math.max(0, Math.round((now - then) / 86_400_000));
  if (days <= 0) return 'Updated today';
  if (days === 1) return 'Updated yesterday';
  if (days < 14) return `Updated ${days} days ago`;
  if (days < 60) return `Updated ${Math.round(days / 7)} weeks ago`;
  const months = Math.round(days / 30);
  return `Updated ${months} ${months === 1 ? 'month' : 'months'} ago`;
}
const freshness = freshnessLabel(lastUpdated);

// Working on. Active client and studio work. Rendered as a vertical timeline,
// so order reads top-to-bottom as "most front-of-mind first." Keep these warm
// and generic: describe the shape of the work, not named clients.
const workingOn = [
  'Building a small business site for a West Chester music teacher, copy and photography included.',
  'Planning a summer Sunday-morning photo shoot with a partner church.',
  'Sketching the next iteration of this studio site (the one you are reading).',
];

// Booking. Capacity signals for prospective clients. Each entry carries a
// `status` that sets the chip color and the screen-reader-friendly label,
// so availability never reads on color alone.
//   open    -> green, taking inquiries
//   limited -> amber, one slot or partial
const booking = [
  {
    status: 'open' as const,
    label: 'Web design',
    detail: 'Open for one more small business or nonprofit project this summer.',
  },
  {
    status: 'limited' as const,
    label: 'Photography',
    detail: 'A few shoot days left in July and August around existing work.',
  },
];

// Map each booking status to its visual + accessible treatment. The text
// prefix ("Open" / "Limited") and the dot shape carry the meaning so the
// color is reinforcement, never the only cue.
const statusMeta = {
  open:    { word: 'Open',    dot: 'bg-emerald-500',  ring: 'ring-emerald-500/30',  text: 'text-emerald-700 dark:text-emerald-400' },
  limited: { word: 'Limited', dot: 'bg-tertiary',     ring: 'ring-tertiary/40',     text: 'text-tertiary' },
};

// Reading. Books / longer-form pieces. Split title from author so the card
// can weight them differently.
const reading = [
  { title: 'Design as Art', author: 'Bruno Munari' },
  { title: 'How Buildings Learn', author: 'Stewart Brand' },
  { title: 'The Mom Test', author: 'Rob Fitzpatrick', note: 're-read' },
];

// Learning. Skills / topics I'm trying to get sharper on.
const learning = [
  'View Transitions and the newer web animation APIs',
  'Long-exposure photography in low-light interiors',
  'Faster turnarounds on photo culling and edits',
];
---

<BaseLayout
  title="Now | Nixon Creative Studio"
  description="What I'm working on, reading, and learning right now. Updated quarterly."
>

  <section class="py-2xl" aria-labelledby="now-heading">
    <div class="ncs-container max-w-[64rem]">

      <header class="mb-2xl flex flex-col gap-m" data-reveal>
        <!-- Status pill: a live pulsing dot plus the relative-freshness label.
             The dot is decorative; the label text carries the meaning. -->
        <p
          class="inline-flex w-fit items-center gap-s rounded-full border border-border bg-bg-soft px-4 py-1.5 text-sm font-medium text-text"
        >
          <span class="now-pulse relative inline-flex h-2.5 w-2.5 shrink-0" aria-hidden="true">
            <span class="now-pulse-ring absolute inline-flex h-full w-full rounded-full bg-emerald-500/70"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
          </span>
          <span>{freshness}</span>
        </p>

        <h1 id="now-heading" class="max-w-[22ch] leading-[0.95]">
          What's on the docket right now.
        </h1>
        <p class="max-w-[60ch] text-lg leading-[1.6] text-text">
          A snapshot of current client work, what I'm reading, and what I'm trying to get sharper on. The whole page rewrites every couple of months. This format started with <a class="link-underline text-link" href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">Derek Sivers</a>.
        </p>
      </header>

      <!-- Working on: a vertical timeline. Each item is a node on a connected
           line, so the list reads as an ordered "right now" feed top to bottom.
           The line is a single ::before on the <ol>; each node draws its own dot
           via ::before so the rail stays continuous behind them. -->
      <section class="mb-2xl flex flex-col gap-l" aria-labelledby="now-working">
        <h2 id="now-working" class="text-h4 text-heading" data-reveal>Working on</h2>
        <ol class="now-timeline relative m-0 list-none p-0">
          {workingOn.map((item, index) => (
            <li
              class="now-timeline-item relative pb-l pl-10 last:pb-0"
              data-reveal="left"
              style={`--reveal-delay: ${index * 110}ms;`}
            >
              <p class="leading-[1.6] text-text">{item}</p>
            </li>
          ))}
        </ol>
      </section>

      <!-- Booking: availability chips. Status word + colored dot + detail line.
           Color is reinforced by the leading word and the dot, never alone. -->
      <section class="mb-2xl flex flex-col gap-l" aria-labelledby="now-booking">
        <h2 id="now-booking" class="text-h4 text-heading" data-reveal>Booking</h2>
        <ul class="grid list-none gap-m p-0 sm:grid-cols-2">
          {booking.map((slot, index) => {
            const meta = statusMeta[slot.status];
            return (
              <li
                class="spotlight-card hover-lift relative overflow-hidden rounded-xl border border-border bg-bg-soft p-l"
                data-spotlight
                data-reveal="scale"
                style={`--reveal-delay: ${index * 110}ms;`}
              >
                <div class="relative z-10 flex flex-col gap-s">
                  <span
                    class:list={[
                      'inline-flex w-fit items-center gap-s rounded-full bg-bg px-3 py-1 text-xs font-semibold uppercase tracking-[0.06em] ring-1',
                      meta.ring,
                      meta.text,
                    ]}
                  >
                    <span class:list={['h-2 w-2 rounded-full', meta.dot]} aria-hidden="true"></span>
                    {meta.word}
                  </span>
                  <span class="text-h5 font-display text-heading">{slot.label}</span>
                  <p class="leading-[1.55] text-text">{slot.detail}</p>
                </div>
              </li>
            );
          })}
        </ul>
      </section>

      <!-- Reading + Learning: two card columns, each a scroll-revealed grid. -->
      <div class="grid grid-cols-1 gap-2xl md:grid-cols-2">

        <section class="flex flex-col gap-l" aria-labelledby="now-reading">
          <h2 id="now-reading" class="text-h4 text-heading" data-reveal>Reading</h2>
          <ul class="flex list-none flex-col gap-s p-0">
            {reading.map((book, index) => (
              <li
                class="spotlight-card hover-lift relative overflow-hidden rounded-xl border border-border bg-bg-soft p-m"
                data-spotlight
                data-reveal="right"
                style={`--reveal-delay: ${index * 90}ms;`}
              >
                <div class="relative z-10 flex flex-col gap-1">
                  <span class="font-display text-h5 leading-tight text-heading">
                    {book.title}
                    {book.note && (
                      <span class="ml-2 align-middle text-xs font-medium uppercase tracking-[0.06em] text-link">({book.note})</span>
                    )}
                  </span>
                  <span class="text-sm text-text-muted">{book.author}</span>
                </div>
              </li>
            ))}
          </ul>
        </section>

        <section class="flex flex-col gap-l" aria-labelledby="now-learning">
          <h2 id="now-learning" class="text-h4 text-heading" data-reveal>Learning</h2>
          <ul class="flex list-none flex-col gap-s p-0">
            {learning.map((item, index) => (
              <li
                class="spotlight-card hover-lift relative overflow-hidden rounded-xl border border-border bg-bg-soft p-m"
                data-spotlight
                data-reveal="right"
                style={`--reveal-delay: ${index * 90}ms;`}
              >
                <p class="relative z-10 leading-[1.55] text-text">{item}</p>
              </li>
            ))}
          </ul>
        </section>

      </div>

      <p class="mt-2xl font-mono text-[0.85rem] italic text-text-muted" data-reveal="fade">
        Last updated {lastUpdatedLabel}.
      </p>

    </div>
  </section>

  <CtaBanner />

</BaseLayout>

<style>
  /* Vertical timeline rail. A single gradient line runs the full height of the
     list, behind every node. Fades out at the bottom so the last item feels
     like the end of the feed rather than a hard cut. */
  .now-timeline::before {
    content: "";
    position: absolute;
    top: 0.4rem;
    bottom: 1.5rem;
    left: 0.3125rem; /* centers the 0.625rem rail under the node dots */
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-accent),
      color-mix(in oklab, var(--color-accent) 15%, transparent)
    );
  }

  /* Each timeline node: a ringed dot sitting on the rail. The ring matches the
     page background so the dot reads as a bead on the line, not a flat circle. */
  .now-timeline-item::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    left: 0;
    height: 0.625rem;
    width: 0.625rem;
    border-radius: 9999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-bg);
  }

  /* The first node gets a soft accent halo so the top of the feed has a clear
     "you are here / most recent" anchor. */
  .now-timeline-item:first-child::before {
    box-shadow:
      0 0 0 4px var(--color-bg),
      0 0 0 8px color-mix(in oklab, var(--color-accent) 25%, transparent);
  }

  /* Status-pill pulse: an expanding, fading ring behind the solid dot. Mirrors
     the live "fresh" signal without depending on color alone (the label text
     carries the meaning). Disabled under reduced motion below. */
  .now-pulse-ring {
    animation: now-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes now-ping {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    75%,
    100% {
      transform: scale(2.4);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .now-pulse-ring {
      animation: none;
    }
  }
</style>
