---
// Safe to edit. The page wiring is foundation; the copy at the top is
// safe to swap when positioning changes.
/* ============================================================================
   /journal | Journal Index
   ============================================================================
   Listing for the journal collection. Sorts newest first, filters out
   drafts in production builds, and renders a card per entry.

   The page renders even when the collection is empty: an empty-state
   block invites Nathan to publish the first entry without leaving a
   broken-looking page out on the live site.
   ============================================================================ */

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const all = (await getCollection('journal', ({ data }) =>
  // Drop drafts in production. import.meta.env.PROD is true on `astro build`,
  // false on `astro dev`, so drafts stay visible locally.
  import.meta.env.PROD ? data.draft !== true : true,
)).sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  title="Journal | Nixon Creative Studio"
  description="Short essays, process notes, and field reports from the studio."
>

  <section class="py-2xl" aria-labelledby="journal-heading">
    <div class="ncs-container">

      <header class="mb-xl flex flex-col gap-xs">
        <p class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">J1</p>
        <h1 id="journal-heading">Journal</h1>
        <p class="max-w-[56ch] text-lg leading-[1.5] text-text-muted">
          Short notes from the studio: process, opinions, the occasional field report. Updated whenever there's something worth writing down.
        </p>
      </header>

      {all.length === 0 ? (
        <!-- Empty-state. Renders when no entries are published yet, so the
             page doesn't ship as a bare title. -->
        <p class="max-w-[56ch] text-text">
          No entries yet. The first one is being drafted. In the meantime, see <a class="text-link underline underline-offset-2" href="/work/">selected work</a> or <a class="text-link underline underline-offset-2" href="/contact">say hello</a>.
        </p>
      ) : (
        <ul class="flex flex-col gap-l">
          {all.map((entry) => (
            <li>
              <a
                class="group flex flex-col gap-s rounded-lg p-m text-inherit no-underline transition-colors duration-150 hover:bg-bg-soft focus-visible:bg-bg-soft focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
                href={`/journal/${entry.id}/`}
              >
                <p class="flex items-center gap-s font-mono text-[0.8rem] uppercase tracking-[0.05em] text-text-muted">
                  <span>{fmt.format(entry.data.published)}</span>
                  {entry.data.tags && entry.data.tags.length > 0 && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>{entry.data.tags.join(', ')}</span>
                    </>
                  )}
                </p>
                <h2 class="text-h3 text-heading transition-colors group-hover:text-link group-focus-visible:text-link">
                  {entry.data.title}
                </h2>
                <p class="max-w-[64ch] leading-[1.5] text-text">{entry.data.summary}</p>
                <span class="card-link">Read on</span>
              </a>
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

  <CtaBanner />

</BaseLayout>
