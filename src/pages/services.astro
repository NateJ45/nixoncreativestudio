---
// Safe to edit. The services, tiers, and faq arrays below hold every word
// of user-facing copy on this page.
/* ============================================================================
   /services | Services
   ============================================================================
   Seven-block stack:
     1. Hero (positioning statement, solid-token headline)
     2. Three service chapters as elevated, alternating spotlight-cards
     3. Process recap (reuses the homepage Process component)
     4. "What a website costs" band: three web tiers (Launch / Signature /
        Flagship) + an "add to any project" strip (photography, brand, care)
     5. "Why it costs what it costs" justification block
     6. FAQ (native <details>/<summary>, JS-free, smooth grid-row open/close)
     7. CTA banner

   The process steps reuse ProcessBand (the homepage's closing band) in its
   soft, no-CTA variant, so the four steps read identically across the site.

   Motion vocabulary used here (all reduced-motion safe, defined globally):
     data-reveal / data-reveal="left|right"  scroll fade+rise
     spotlight-card + data-spotlight          cursor-following glow on a card
     hover-lift                               lift on hover
     data-countup                             number animates up when in view

   PRICING LIVES IN src/data/pricing.ts: the `tiers` and `addOns` arrays are
   imported below and shared with the homepage PricingTeaser, so the two never
   drift. The FAQ answers here are prose and can't import those values, so when
   a price changes, change it in pricing.ts AND in the matching FAQ answer. The
   numbers reflect the 2026 market for an agency-grade solo studio: Launch
   from $4,000, Signature from $7,000 (where most projects land), Flagship
   from $12,000, photography from $900, brand $500+, care from $75/mo.
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import ProcessBand from '../components/ProcessBand.astro';
import CtaBanner from '../components/CtaBanner.astro';
import SelectedWork from '../components/SelectedWork.astro';
import { Image } from 'astro:assets';
// Real proof for the Web design service: a shipped client site, shown at full
// strength. Swap this import for any other case-study cover to feature a
// different project.
import webDesignShot from '../assets/case-studies/second-presbyterian-chicago.png';
import { site } from '../data/site';
// Tiers + add-ons come from the shared single source of truth (also used by
// the homepage PricingTeaser), so the numbers can never drift between pages.
import { webTiers as tiers, addOns } from '../data/pricing';

// The three services are parallel offerings a client picks from, not an
// ordered sequence (you can buy photography without strategy), so they carry
// no 01/02/03 numerals. Numbered markers live only on the genuinely-ordered
// Process band. Strategy is listed first because most projects start there.
const services = [
  {
    title: 'Strategy',
    lede: 'The planning work that decides what the site is for, who it serves, and how it earns its keep.',
    body: 'Strategy always comes first. Without it, design becomes decoration. We start with a working session, then I write a short brief that the rest of the project follows.',
    priceFrom: 1500, // standalone floor; included free inside every build
    // No screenshot for strategy (it is planning work, not a screen). A
    // labelled placeholder panel stands in until a real artifact (a sitemap or
    // brief) is dropped here; see Web design below for the real-image pattern.
    image: null,
    imageAlt: '',
    placeholderIcon: 'strategy',
    points: [
      'A working session, then back-and-forth until the plan is right',
      'Audience map and conversion path',
      'Content inventory of what you already have',
      'A one-page brief the rest of the project follows',
    ],
  },
  {
    title: 'Web design',
    lede: 'Modern, accessible, fast websites built on the platform that fits you, from a custom-coded site to Squarespace or WordPress, and set up so your team can actually run it.',
    body: 'I match the build to your budget and to whoever will maintain it after launch. Everything is built mobile-first and tested for accessibility from the very first screen, then handed off so you are never locked out of your own site.',
    priceFrom: 4000, // Launch tier floor; see the pricing band below
    // Real shipped site, shown at full strength (research: show the work, do
    // not fade it behind text). Swap webDesignShot above to feature another.
    image: webDesignShot,
    imageAlt: 'The Second Presbyterian Church of Chicago website, designed and built by the studio',
    placeholderIcon: null,
    points: [
      'A custom design built to your brand, not a stock template',
      'Self-hosted typography and imagery',
      'Mobile-first responsive layouts',
      'WCAG-aware accessibility from day one',
      'Deployed to Cloudflare Pages, auto-rebuild on every commit',
    ],
  },
  {
    title: 'Photography',
    lede: 'Headshots, event coverage, and environmental photography shot for your website by the same person who designed it.',
    body: 'When the photographer and the designer are one person, the photos match the layout instead of fighting it. Images arrive edited, web-optimized, and ready to drop in.',
    priceFrom: 900, // half-day floor; ~$1,200/day folded into a build
    // Placeholder until a real photo is dropped in. Replace with:
    //   import photoShot from '../assets/photography/<file>.jpg';
    // then set image: photoShot and a real imageAlt.
    image: null,
    imageAlt: '',
    placeholderIcon: 'photography',
    points: [
      'On-site Sunday or weekday coverage',
      'Headshots for team and staff',
      'Environmental photography of your space',
      'Edited, web-optimized images delivered with the website',
    ],
  },
];

// Placeholder glyphs for the services without a real image yet (Strategy,
// Photography). Inner SVG markup, drawn into the placeholder panel; they match
// the hero three-service flow icons so the page reads as one set.
const placeholderIcons: Record<string, string> = {
  strategy:
    '<circle cx="12" cy="12" r="9" /><polygon points="15.5 8.5 13 13 8.5 15.5 11 11 15.5 8.5" />',
  photography:
    '<path d="M4 8h3l1.4-2h7.2L17 8h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1Z" /><circle cx="12" cy="13" r="3.2" />',
};

// `tiers` (the three web design tiers: Launch / Signature / Flagship) and
// `addOns` (photography, brand, care) are imported above from
// src/data/pricing.ts, the single source shared with the homepage teaser.
// Edit any price there, not here.

// "Why it costs what it costs." The honest justification block: what the price
// buys and what a cheaper quote usually leaves out. Each point is tied to how
// the studio actually works, so it reads as true rather than as a sales pitch.
const whyItCosts = [
  {
    title: 'One person, no handoffs',
    body: 'The person who plans your site designs it, builds it, and shoots the photos. No agency markup, and nothing lost in translation between a strategist, a designer, and a developer who never quite talk to each other.',
  },
  {
    title: 'Built to be handed off',
    body: 'Every site is set up so the next volunteer or staff member can keep it running, and you own it outright. A cheaper site that leaves you stranded the day the freelancer goes quiet costs far more to replace than it saved.',
  },
  {
    title: 'Accessible by default',
    body: 'Every page meets WCAG AA and scores 100 for accessibility. Most budget builds fail this badly. For a church, school, or nonprofit it is both the right thing to do and real legal cover, included, not an upsell.',
  },
  {
    title: 'Cheap is expensive later',
    body: 'A bargain site quietly runs into thousands a year once you bolt on the features it could not handle up front. I would rather build it once, on a stack that is nearly free to run and is yours to keep.',
  },
];

const faq = [
  {
    q: 'What does it cost?',
    a: 'Websites start at $4,000 for a focused Launch site. Most projects land between $7,000 and $11,000, and builds with real custom functionality start around $12,000. Every build is custom and comes with a content system you can manage yourself; what moves the number is scope, functionality, photography, and content. The first conversation is free and ends with an honest ballpark before either of us is committed, and larger projects can be split into monthly payments so the budget is about cash flow, not one big wall.',
  },
  {
    q: 'What if I have been quoted less somewhere else?',
    a: 'You probably can find a cheaper quote, and for a very simple need that might be the right call. What a low quote usually leaves out is the part that matters later: accessibility, a content system your team can actually run, a plan for who maintains the site after launch, and someone who still answers the phone in a year. A site you have to rebuild in eighteen months is the expensive one. I would rather build it once.',
  },
  {
    q: 'How long does a typical project take?',
    a: 'Most websites land between six and ten weeks from kickoff to launch. Larger projects with custom photography or multiple content collections can run twelve to sixteen weeks. The brief at the end of strategy sets the real timeline.',
  },
  {
    q: 'Do you offer maintenance?',
    a: 'Optional. After launch you own the site outright and can leave it alone for years if nothing breaks. If you want hands-on support, care plans start at $75 a month for updates, backups, and security, with higher tiers that add a monthly bucket of content edits.',
  },
  {
    q: 'Can you work with my existing brand?',
    a: 'Yes. If you already have a logo, palette, and type system, we use it. If you do not, brand work can be folded into the strategy phase or scoped separately.',
  },
  {
    q: 'Where are you based, and do you work with clients outside Cincinnati?',
    a: "I'm based in Cincinnati, but web design, strategy, and brand work happen with clients anywhere, fully remote when that is easier. Photography is the one piece that needs me on site, so that stays within the greater Cincinnati region.",
  },
];

// JSON-LD schemas for /services: Service (one per offering) and FAQPage.
// FAQPage does the most work here. Google will surface FAQ
// answers directly in search results for matching queries.
const schemas = [
  ...services.map((service) => ({
    '@context':     'https://schema.org',
    '@type':        'Service',
    name:           service.title,
    description:    service.body,
    provider:       { '@id': `${site.url}#organization` },
    // Photography needs me on site, so it stays regional; strategy, web design,
    // and brand work serve clients anywhere (region + country).
    areaServed:     service.title === 'Photography'
      ? 'Greater Cincinnati region'
      : ['Greater Cincinnati region', 'United States'],
    // Publish the "from" floor as an Offer so the price shows in structured
    // data alongside the visible page. Spread in only when the service has one.
    ...(service.priceFrom ? {
      offers: {
        '@type': 'Offer',
        priceSpecification: {
          '@type':       'PriceSpecification',
          minPrice:      service.priceFrom,
          priceCurrency: 'USD',
        },
      },
    } : {}),
  })),
  {
    '@context': 'https://schema.org',
    '@type':    'FAQPage',
    mainEntity: faq.map(({ q, a }) => ({
      '@type': 'Question',
      name:    q,
      acceptedAnswer: {
        '@type': 'Answer',
        text:    a,
      },
    })),
  },
];
---

<BaseLayout
  title="Services | Nixon Creative Studio"
  description="Strategy, web design, and brand work for clients anywhere, plus photography across the greater Cincinnati region. Based in Cincinnati."
  schemas={schemas}
>

  <!-- ----------------------------------------------------------------------
       Hero. Two columns at lg+: the positioning headline + sub on the left, an
       animated "three-service flow" on the right (Strategy -> Web design ->
       Photography, the order the copy names), so the empty right half now carries
       a visual that illustrates the sentence. Single column below lg, where the
       flow is hidden (it only earns its place beside the copy at lg+) and the
       hero tightens to just the headline + sub. The headline uses its own clamp (smaller than
       the global h1) so the long title sits comfortably and never runs off the
       bottom on short or mobile screens. The flow is decorative (aria-hidden);
       the headline carries the real content and the solid heading color (no
       gradient text).
       ---------------------------------------------------------------------- -->
  <section class="py-xl lg:py-2xl" aria-labelledby="services-hero-heading">
    <div class="ncs-container">
      <div class="grid items-center gap-xl lg:grid-cols-[1.05fr_0.95fr]">

        <div class="flex flex-col gap-m">
          <h1
            id="services-hero-heading"
            class="services-headline leading-[0.98]"
            data-reveal
            style="--reveal-delay: 80ms;"
          >
            Strategy, web design, and photography for organizations that care about the long run.
          </h1>
          <p
            class="max-w-[52ch] text-lg leading-[1.6] text-text"
            data-reveal
            style="--reveal-delay: 180ms;"
          >
            Most projects use all three services, in that order. Some use one or two. The first conversation always ends with an honest scope, not a sales pitch.
          </p>
        </div>

        <!-- Three-service flow. Decorative reinforcement of the headline
             (aria-hidden), and the right half of the two-column hero. It only
             earns its place beside the copy at lg+, so it is hidden below lg
             rather than stacked under the copy on mobile (where it just repeated
             the headline and pushed the page down). -->
        <div class="services-flow hidden lg:block" aria-hidden="true" data-reveal="fade" style="--reveal-delay: 300ms;">
          <div class="flow-card surface-card spotlight-card hover-lift rounded-2xl" data-spotlight>
            <ol class="flow-track relative z-10">

            <li class="flow-step" style="--i: 0;">
              <span class="flow-marker">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" />
                  <polygon points="15.5 8.5 13 13 8.5 15.5 11 11 15.5 8.5" />
                </svg>
              </span>
              <span class="flow-text">
                <span class="flow-name">Strategy</span>
                <span class="flow-desc">Goals, audience, scope</span>
              </span>
            </li>

            <li class="flow-step" style="--i: 1;">
              <span class="flow-marker">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="16" rx="2" />
                  <path d="M3 9h18" />
                  <path d="M6 6.5h.01" />
                </svg>
              </span>
              <span class="flow-text">
                <span class="flow-name">Web design</span>
                <span class="flow-desc">Designed, built, yours</span>
              </span>
            </li>

            <li class="flow-step" style="--i: 2;">
              <span class="flow-marker">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 8h3l1.4-2h7.2L17 8h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1Z" />
                  <circle cx="12" cy="13" r="3.2" />
                </svg>
              </span>
              <span class="flow-text">
                <span class="flow-name">Photography</span>
                <span class="flow-desc">Shot for the site</span>
              </span>
            </li>

            </ol>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Service offerings. Each is its own elevated spotlight-card with a
       cursor-following glow, a hover lift, and a staggered scroll-reveal.
       These are parallel services (not an ordered sequence), so the list is
       a <ul> and carries no numerals. The cards alternate reveal direction
       (left / right / left) so they arrive with a little choreography.
       ---------------------------------------------------------------------- -->
  <section class="bg-dotgrid py-2xl" aria-label="Service details">
    <div class="ncs-container">
      <ul class="flex list-none flex-col gap-l p-0">
        {services.map((service, index) => {
          // The proof visual sits left for even services, right for odd, so the
          // run reads as a guided tour rather than a stack. On mobile the copy
          // leads and the visual follows (DOM order: copy first, visual second).
          const visualLeft = index % 2 === 0;
          return (
          <li
            class="surface-card spotlight-card hover-lift group relative isolate overflow-hidden rounded-2xl p-l md:p-xl"
            data-spotlight
            data-reveal={visualLeft ? 'left' : 'right'}
            style={`--reveal-delay: ${index * 90}ms;`}
          >
            <div class="relative z-10 grid grid-cols-1 items-center gap-l md:grid-cols-2 md:gap-xl">

              <!-- Copy: title, lede, body, and the what's-included list. No
                   sequence numeral: these are parallel offerings, not steps. -->
              <div class:list={['flex flex-col gap-m', visualLeft ? 'md:order-2' : 'md:order-1']}>
                <div class="flex flex-col gap-s">
                  <h2 class="text-heading">{service.title}</h2>
                  <p class="max-w-[48ch] text-[1.0625rem] font-medium leading-[1.55] text-text">
                    {service.lede}
                  </p>
                  <p class="max-w-[52ch] leading-[1.7] text-text-muted">
                    {service.body}
                  </p>
                </div>

                <!-- What's included, as a checked list. The dot glyph is
                     decorative; the text carries the meaning. -->
                <div class="flex flex-col gap-s">
                  <p class="text-sm font-semibold uppercase tracking-[0.12em] text-text-muted">
                    What's included
                  </p>
                  <ul class="flex flex-col gap-2 leading-[1.5] text-text">
                    {service.points.map((point) => (
                      <li class="flex items-start gap-s">
                        <span
                          class="mt-[0.35em] inline-block h-[0.45rem] w-[0.45rem] shrink-0 rounded-full bg-accent"
                          aria-hidden="true"
                        ></span>
                        <span>{point}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Proof visual: a real shipped site for Web design; a labelled
                   placeholder panel for the services without an image yet. Drop
                   a real <Image> in (set `image` on the service) and it inherits
                   the same frame. -->
              <div class:list={[visualLeft ? 'md:order-1' : 'md:order-2']}>
                {service.image ? (
                  <div class="services-shot-frame">
                    <Image
                      src={service.image}
                      alt={service.imageAlt}
                      widths={[400, 640, 900]}
                      sizes="(min-width: 768px) 42vw, 90vw"
                      class="services-shot-img"
                    />
                  </div>
                ) : (
                  <div class="services-shot-frame services-shot-placeholder" aria-hidden="true">
                    <svg
                      class="services-shot-ph-icon"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.4"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={service.placeholderIcon ? placeholderIcons[service.placeholderIcon] : ''}
                    />
                    <span class="services-shot-ph-label">{service.title}</span>
                  </div>
                )}
              </div>

            </div>
          </li>
          );
        })}
      </ul>
    </div>
  </section>


  <!-- Process recap. The same ProcessBand the homepage closes with, in its
       soft mid-page variant with no CTA, so the four steps read identically
       across the site. -->
  <ProcessBand variant="soft" showCta={false} headingId="process-heading" />


  <!-- ----------------------------------------------------------------------
       What a website costs. Three web tiers (Launch / Signature / Flagship),
       each publishing an honest "from" floor plus the typical range, then a
       lighter "add to any project" strip for photography, brand, and care.
       Numbers live in the `tiers` and `addOns` arrays; the FAQ must agree.
       The floor counts up on scroll, but the static text is always the real
       number so no-JS visitors and crawlers see the true figure.
       ---------------------------------------------------------------------- -->
  <section class="bg-bg-soft py-2xl" aria-labelledby="services-pricing-heading">
    <div class="ncs-container">

      <header class="mb-l flex max-w-[62ch] flex-col gap-xs" data-reveal>
        <h2 id="services-pricing-heading" class="text-heading">What a website costs</h2>
        <p class="text-lg leading-[1.55] text-text-muted">
          A starting point, not a fixed menu. Every build is custom and comes with a content system you can run yourself, so the tiers differ in scope and how much functionality you need, not whether the work is custom. The free first conversation ends with an honest ballpark, and larger projects can be split into monthly payments.
        </p>
      </header>

      <ul class="grid list-none gap-l p-0 [grid-template-columns:repeat(auto-fit,minmax(16rem,1fr))]">
        {tiers.map((tier, index) => (
          <li
            class:list={[
              'tier-card spotlight-card surface-card relative isolate flex flex-col gap-m overflow-hidden rounded-2xl p-l',
              tier.highlighted && 'tier-card--featured',
            ]}
            data-spotlight
            data-reveal
            style={`--reveal-delay: ${index * 110}ms;`}
          >
            {tier.badge && (
              <span class="inline-flex w-fit items-center rounded-full bg-accent px-s py-[0.2rem] text-xs font-semibold uppercase tracking-[0.1em] text-primary-foreground">
                {tier.badge}
              </span>
            )}

            <div class="relative z-10 flex flex-col gap-m">
              <h3 class="text-h4 text-heading">{tier.name}</h3>

              <!-- Price line: the floor counts up to its real value, with the
                   typical range stated underneath so the "from" is honest. -->
              <div class="flex flex-col gap-1">
                <p class="flex items-baseline gap-xs">
                  <span class="text-sm font-medium text-text-muted">from</span>
                  <span class="font-display text-h2 leading-none text-heading">
                    $<span
                      data-countup
                      data-countup-to={tier.priceFrom}
                      data-countup-duration="1200"
                    >{tier.priceFrom.toLocaleString()}</span>{tier.priceSuffix}
                  </span>
                </p>
                <p class="text-sm text-text-muted">{tier.range}</p>
              </div>

              <p class="leading-[1.6] text-text-muted">{tier.note}</p>

              <ul class="mt-xs flex flex-col gap-2 leading-[1.5] text-text">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-s">
                    <span
                      class="mt-[0.35em] inline-block h-[0.45rem] w-[0.45rem] shrink-0 rounded-full bg-accent"
                      aria-hidden="true"
                    ></span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ul>

      <p class="mt-l max-w-[60ch] text-sm leading-[1.6] text-text-muted" data-reveal>
        Strategy is the front of every project, not a line item. The price above already includes the session and the brief.
      </p>

      <!-- Add to any project: photography, standalone brand, optional care.
           Lighter cards than the tiers above; these attach to a build. -->
      <div class="mt-2xl" data-reveal>
        <h3 class="text-h5 text-heading">Add to any project</h3>
        <ul class="mt-m grid list-none gap-m p-0 [grid-template-columns:repeat(auto-fit,minmax(15rem,1fr))]">
          {addOns.map((addOn, index) => (
            <li
              class="surface-card flex flex-col gap-xs rounded-xl p-m"
              data-reveal
              style={`--reveal-delay: ${index * 90}ms;`}
            >
              <h4 class="text-h5 text-heading">{addOn.name}</h4>
              <p class="font-display text-xl leading-none text-link">{addOn.price}</p>
              <p class="text-sm leading-[1.6] text-text-muted">{addOn.note}</p>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Why it costs what it costs. The honest justification block that follows
       the price immediately, so the "someone quoted me less" objection is
       answered the moment it forms. Two-column hairline-ruled list, not cards.
       ---------------------------------------------------------------------- -->
  <section class="bg-dotgrid py-2xl" aria-labelledby="services-why-heading">
    <div class="ncs-container">

      <header class="mb-l flex max-w-[60ch] flex-col gap-xs" data-reveal>
        <h2 id="services-why-heading" class="text-heading">Why it costs what it costs</h2>
        <p class="text-lg leading-[1.55] text-text-muted">
          Plenty of people will quote you less. Here is what the price actually buys, and what a cheaper one usually leaves out.
        </p>
      </header>

      <ul class="grid list-none gap-l p-0 md:grid-cols-2">
        {whyItCosts.map((point, index) => (
          <li
            class="flex flex-col gap-xs border-t border-border pt-m"
            data-reveal
            style={`--reveal-delay: ${index * 90}ms;`}
          >
            <h3 class="text-h5 text-heading">{point.title}</h3>
            <p class="max-w-[52ch] leading-[1.7] text-text-muted">{point.body}</p>
          </li>
        ))}
      </ul>

      <!-- Quiet, honest note on tooling. Addresses the modern-tools / AI
           question head-on and reframes it to judgment + accountability, so it
           reads as a trust signal rather than a confession. -->
      <p class="mt-l max-w-[60ch] leading-[1.7] text-text-muted" data-reveal>
        I build with modern tools, including AI-assisted workflows, the same way I use frameworks and a camera. They help one person do the work of a team. The strategy, the design, and the accountability stay mine, start to finish.
      </p>

    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       FAQ. Native <details>/<summary> for accessible, JS-free disclosure.
       The answer wrapper animates open and closed with a CSS grid trick:
       grid-template-rows goes from 0fr (collapsed) to 1fr (open), which
       transitions smoothly without needing a fixed pixel height. The "+"
       marker rotates to "x" via the group-open: variant. The whole row
       still works with keyboard and screen readers because it is a real
       <details> element.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl" aria-labelledby="services-faq-heading">
    <div class="ncs-container">

      <header class="mb-l flex max-w-[60ch] flex-col gap-xs" data-reveal>
        <h2 id="services-faq-heading" class="text-heading">Common questions</h2>
        <p class="text-lg leading-[1.55] text-text-muted">
          The things people ask before the first call.
        </p>
      </header>

      <div class="flex flex-col border-t border-border">
        {faq.map((item, index) => (
          <!-- `group` lets the summary's open-state pseudo and the answer
               wrapper both react via group-open:. -->
          <details
            class="faq-item group border-b border-border"
            data-reveal="fade"
            style={`--reveal-delay: ${index * 70}ms;`}
          >
            <!-- list-none drops the default disclosure triangle. The webkit
                 marker pseudo hides the Safari version. The "+" rotates to an
                 "x" when open; the rotation plus the smooth panel are two
                 non-color cues, so state is never signalled by color alone. -->
            <summary class="flex cursor-pointer list-none items-center justify-between gap-m py-m font-body text-lg font-semibold text-heading transition-colors duration-200 hover:text-link [&::-webkit-details-marker]:hidden after:font-mono after:text-xl after:leading-none after:text-accent after:transition-transform after:duration-300 after:content-['+'] group-open:after:rotate-[135deg]">
              {item.q}
            </summary>
            <!-- Animated reveal: the grid row scales from 0fr to 1fr. The
                 inner div needs overflow-hidden so the clipped content does
                 not spill while the row is collapsing. -->
            <div class="faq-answer grid">
              <div class="overflow-hidden">
                <p class="max-w-[64ch] pb-m leading-[1.7] text-text">{item.a}</p>
              </div>
            </div>
          </details>
        ))}
      </div>

    </div>
  </section>


  <!-- Recent work proof strip. Reuses the homepage Selected Work block
       (collection-driven, featured===true), so the services page proves the
       work with real shipped sites right before it asks for the inquiry. -->
  <SelectedWork />

  <CtaBanner
    title="Ready to scope a project?"
    sub="The first conversation is free and lands at an honest ballpark by the end. Email is fastest, but a phone call works too."
  />

</BaseLayout>

