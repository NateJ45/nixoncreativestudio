---
// Safe to edit. The services and faq arrays below hold every word of
// user-facing copy on this page.
/* ============================================================================
   /services | Services
   ============================================================================
   Five-block stack:
     1. Hero (positioning statement)
     2. Three expanded service chapters with description + included-items
     3. Process recap (reuses the homepage Process component)
     4. FAQ (native <details>/<summary>, no JS required)
     5. CTA banner

   The Process component is reused, not duplicated. Edit Process.astro
   once and both the homepage and this page update.
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import Process from '../components/Process.astro';
import CtaBanner from '../components/CtaBanner.astro';

const services = [
  {
    num: 'i',
    title: 'Strategy',
    body: 'Strategy is the planning work that decides what the site is for, who it serves, and how it earns its keep. It always comes first. Without it, design becomes decoration.',
    points: [
      'Half-day workshop with your team',
      'Audience map and conversion path',
      'Content inventory of what you already have',
      'A one-page brief that the rest of the project follows',
    ],
  },
  {
    num: 'ii',
    title: 'Web design',
    body: 'Modern, accessible, fast websites built in plain HTML and CSS. No page builder subscription layer between you and your site. Real fonts, real images, code a future maintainer can read.',
    points: [
      'Hand-built component design system',
      'Self-hosted typography and imagery',
      'Mobile-first responsive layouts',
      'WCAG-aware accessibility from day one',
      'Deployed to Cloudflare Pages with auto-rebuild on every commit',
    ],
  },
  {
    num: 'iii',
    title: 'Photography',
    body: 'Headshots, event coverage, environmental photography for the website. Same person who designed the site shows up with the camera, so the photos match the layout instead of fighting it.',
    points: [
      'On-site Sunday or weekday coverage',
      'Headshots for team and staff',
      'Environmental photography of your space',
      'Edited, web-optimized images delivered alongside the website',
    ],
  },
];

const faq = [
  {
    q: 'How long does a typical project take?',
    a: 'Most websites land between six and ten weeks from kickoff to launch. Larger projects with custom photography or multiple content collections can run twelve to sixteen weeks. The brief at the end of strategy sets the real timeline.',
  },
  {
    q: 'What does it cost?',
    a: 'Projects start at $3,500 for a small business site and scale up depending on scope, photography, and content. The first conversation is always free and ends with an honest ballpark before either of us is committed.',
  },
  {
    q: 'Do you offer maintenance?',
    a: 'Optional. After launch you own the site outright and can leave it alone for years if nothing breaks. If you want hands-on support, I offer a flat monthly retainer for ongoing edits and content updates.',
  },
  {
    q: 'Can you work with my existing brand?',
    a: 'Yes. If you already have a logo, palette, and type system, we use it. If you do not, brand work can be folded into the strategy phase or scoped separately.',
  },
];
---

<BaseLayout
  title="Services | Nixon Creative Studio"
  description="Strategy, web design, and photography for organizations in the Cincinnati region."
>

  <!-- ----------------------------------------------------------------------
       Hero. Single column, no portrait to balance, so positioning line
       and intro paragraph sit left-aligned.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class="ncs-container">
      <p class="mb-m inline-flex items-baseline gap-s text-[0.95rem] text-text-muted">
        <span class="font-mono text-sm tracking-[0.05em]">S1</span>
        <span>Services</span>
      </p>
      <h1 class="mb-m max-w-[22ch] leading-[0.95]">
        Strategy, web design, and photography for organizations that care about the long run.
      </h1>
      <p class="max-w-[60ch] text-lg leading-[1.6] text-text">
        Most projects use all three services, in that order. Some use one or two. The first conversation always ends with an honest scope, not a sales pitch.
      </p>
    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Expanded chapters. Each chapter: heading row (number + title),
       then two-column body at >= 48rem (description left, inclusions
       right). Stacks on narrow screens.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class="ncs-container">
      <ol class="flex flex-col gap-2xl pl-0">
        {services.map((service) => (
          <li class="flex flex-col gap-l">

            <header class="flex items-baseline gap-m">
              <span
                class="font-mono text-2xl tracking-[0.05em] text-accent"
                aria-hidden="true"
              >
                {service.num}
              </span>
              <h2 class="text-primary">{service.title}</h2>
            </header>

            <div class="grid grid-cols-1 gap-l md:grid-cols-[1.2fr_1fr]">
              <p class="max-w-[56ch] text-[1.0625rem] leading-[1.7] text-text">
                {service.body}
              </p>
              <!-- Inclusions list. Real bullets restored via list-disc. -->
              <ul class="ml-5 list-disc space-y-2 leading-[1.6] text-text">
                {service.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>

          </li>
        ))}
      </ol>
    </div>
  </section>


  <!-- Process recap. Reuses the homepage Process component verbatim. -->
  <Process />


  <!-- ----------------------------------------------------------------------
       FAQ. Native <details>/<summary> for accessible disclosure without
       JavaScript. The "+" indicator rotates to "×" when open via the
       group-open: variant on the summary's ::after pseudo.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class="ncs-container">

      <header class="mb-l flex flex-col gap-xs">
        <span class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">S5</span>
        <h2 class="text-primary">Common questions</h2>
      </header>

      <div class="flex flex-col border-t border-black/[0.08]">
        {faq.map((item) => (
          <!-- `group` lets the summary's open-state pseudo react via group-open: -->
          <details class="group border-b border-black/[0.08] py-m">
            <!-- list-none drops the default disclosure triangle. The webkit
                 marker pseudo hides the Safari version. -->
            <summary class="flex cursor-pointer list-none items-center justify-between gap-m font-body text-lg font-semibold text-primary [&::-webkit-details-marker]:hidden after:font-mono after:text-accent after:transition-transform after:duration-200 after:content-['+'] group-open:after:rotate-45">
              {item.q}
            </summary>
            <p class="mt-s max-w-[64ch] leading-[1.7] text-text">{item.a}</p>
          </details>
        ))}
      </div>

    </div>
  </section>


  <CtaBanner
    title="Ready to scope a project?"
    sub="The first conversation is free and lands at an honest ballpark by the end. Email is fastest, but a phone call works too."
  />

</BaseLayout>
