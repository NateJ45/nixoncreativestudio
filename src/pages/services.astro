---
// Safe to edit. The services, tiers, processSteps, and faq arrays below hold
// every word of user-facing copy on this page.
/* ============================================================================
   /services | Services  [editorial-grid revamp]
   ============================================================================
   Rebuilt on the same editorial-grid spine as the About page so the two read as
   one ruled document:

     [ 13rem marker rail ] [ content track ]

   SERVICES / WHAT I DO / PROCESS / PRICING / FAQ run down the rail as quiet mono
   word-labels; everything else hangs off one left axis. The three services and
   the three pricing tiers are now hairline-ruled editorial lists (the About
   "Practice" manifesto pattern), not card grids. The four process beats are
   inlined as a ruled list on the same axis (so this page no longer imports the
   soft-band Process component, and Process.astro stays on disk untouched). No
   bg-bg-soft bands anywhere, so dark mode is one seamless navy sheet and the
   only surface change is the closing CtaBanner.

   Honesty rules (unchanged): every price traces back to the FAQ answers below.
   $3,500 floor, optional photography add-on, optional monthly retainer. The
   tier numbers and the FAQ must agree; do not invent prices.

   Motion vocabulary (all reduced-motion safe, defined globally):
     data-reveal           scroll fade+rise (stagger siblings with --reveal-delay)
     data-countup          number animates up when it scrolls into view
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { site } from '../data/site';

// The three services are parallel offerings a client picks from, not an
// ordered sequence (you can buy photography without strategy), so they carry
// no 01/02/03 numerals. Numbered markers live only on the genuinely-ordered
// Process steps below. Strategy is listed first because most projects start there.
const services = [
  {
    title: 'Strategy',
    lede: 'The planning work that decides what the site is for, who it serves, and how it earns its keep.',
    body: 'Strategy always comes first. Without it, design becomes decoration. We start with a working session, then I write a short brief that the rest of the project follows.',
    points: [
      'Half-day workshop with your team',
      'Audience map and conversion path',
      'Content inventory of what you already have',
      'A one-page brief the rest of the project follows',
    ],
  },
  {
    title: 'Web design',
    lede: 'Modern, accessible, fast websites built on the platform that fits you, from a hand-coded site to Squarespace, Wix, or WordPress, and set up so your team can actually run it.',
    body: 'I match the build to your budget and to whoever will maintain it after launch. Everything is built mobile-first and tested for accessibility from the very first screen, then handed off so you are never locked out of your own site.',
    points: [
      'A custom design built to your brand, not a stock template',
      'Self-hosted typography and imagery',
      'Mobile-first responsive layouts',
      'WCAG-aware accessibility from day one',
      'Deployed to Cloudflare Pages, auto-rebuild on every commit',
    ],
  },
  {
    title: 'Photography',
    lede: 'Headshots, event coverage, and environmental photography shot for your website by the same person who designed it.',
    body: 'When the photographer and the designer are one person, the photos match the layout instead of fighting it. Images arrive edited, web-optimized, and ready to drop in.',
    points: [
      'On-site Sunday or weekday coverage',
      'Headshots for team and staff',
      'Environmental photography of your space',
      'Edited, web-optimized images delivered with the website',
    ],
  },
];

// The four genuinely-ordered process beats, inlined here (previously the
// imported Process.astro soft-band). The 01-04 numerals are the page's one
// sanctioned numbered sequence; they stay because the process is truly ordered.
// Copy is preserved verbatim from Process.astro; that file stays on disk for
// any future caller, /services just no longer imports it.
const processSteps = [
  {
    num: '01',
    title: 'Conversation',
    body: 'We meet for an hour, in person or on video, and talk about what you actually need. No pitch deck, no agency theater. Just a working session that ends with a one-page brief we both agree on.',
  },
  {
    num: '02',
    title: 'Strategy',
    body: 'I write the audience map, the page architecture, and the conversion path. You read it, push back, we revise. The strategy doc is the source of truth for every design choice that follows.',
  },
  {
    num: '03',
    title: 'Design and build',
    body: 'Components, content, and pages built in the open. Preview links land in your inbox at every milestone so you can react early instead of seeing the whole thing for the first time at launch.',
  },
  {
    num: '04',
    title: 'Launch and follow-through',
    body: 'We go live together, then I stay close for the first month to fix anything that surfaces. After that you own the site outright, with documentation and a simple way to reach me when something comes up.',
  },
];

// Pricing tiers. Every number here is pulled straight from the FAQ answers
// below so the two never drift. Strategy is the entry point of the project,
// not a separately priced product, so it lives inside the build price.
const tiers = [
  {
    name: 'Small business site',
    priceFrom: 3500, // honest floor from the FAQ "What does it cost?" answer
    priceSuffix: '+',
    note: 'Strategy, design, and build for a small business or organization. Scope, photography, and content move the number from there.',
    features: [
      'Strategy session and one-page brief',
      'A custom, accessible, fast site',
      'Set up and handed off for you to run',
    ],
    highlighted: true,
    badge: 'Most projects start here',
  },
  {
    name: 'Photography add-on',
    priceLabel: 'Add-on',
    note: 'Headshots, event, and environmental photography folded into the project so the imagery is made for the layout, not borrowed from a stock library.',
    features: [
      'On-site coverage, weekday or Sunday',
      'Team headshots and your space',
      'Edited, web-ready files delivered with the site',
    ],
    highlighted: false,
  },
  {
    name: 'Monthly care',
    priceLabel: 'Optional',
    note: 'A flat monthly retainer for ongoing edits and content updates. Skip it entirely and the site is still yours to leave alone for years.',
    features: [
      'Ongoing edits and content updates',
      'A simple way to reach me when something comes up',
      'Cancel any time, no lock-in',
    ],
    highlighted: false,
  },
];

const faq = [
  {
    q: 'How long does a typical project take?',
    a: 'Most websites land between six and ten weeks from kickoff to launch. Larger projects with custom photography or multiple content collections can run twelve to sixteen weeks. The brief at the end of strategy sets the real timeline.',
  },
  {
    q: 'What does it cost?',
    a: 'Projects start at $3,500 for a small business site and scale up depending on scope, photography, and content. The first conversation is always free and ends with an honest ballpark before either of us is committed.',
  },
  {
    q: 'Do you offer maintenance?',
    a: 'Optional. After launch you own the site outright and can leave it alone for years if nothing breaks. If you want hands-on support, I offer a flat monthly retainer for ongoing edits and content updates.',
  },
  {
    q: 'Can you work with my existing brand?',
    a: 'Yes. If you already have a logo, palette, and type system, we use it. If you do not, brand work can be folded into the strategy phase or scoped separately.',
  },
  {
    q: 'Where are you based, and do you work with clients outside Cincinnati?',
    a: "I'm based in Cincinnati, but web design, strategy, and brand work happen with clients anywhere, fully remote when that is easier. Photography is the one piece that needs me on site, so that stays within the greater Cincinnati region.",
  },
];

// JSON-LD schemas for /services: Service (one per offering) and FAQPage.
// FAQPage does the most work here. Google will surface FAQ
// answers directly in search results for matching queries.
const schemas = [
  ...services.map((service) => ({
    '@context':     'https://schema.org',
    '@type':        'Service',
    name:           service.title,
    description:    service.body,
    provider:       { '@id': `${site.url}#organization` },
    // Photography needs me on site, so it stays regional; strategy, web design,
    // and brand work serve clients anywhere (region + country).
    areaServed:     service.title === 'Photography'
      ? 'Greater Cincinnati region'
      : ['Greater Cincinnati region', 'United States'],
  })),
  {
    '@context': 'https://schema.org',
    '@type':    'FAQPage',
    mainEntity: faq.map(({ q, a }) => ({
      '@type': 'Question',
      name:    q,
      acceptedAnswer: {
        '@type': 'Answer',
        text:    a,
      },
    })),
  },
];

// The shared editorial grid + rail label, copied from about.astro so /services
// and /about read as one ruled document with one left axis.
const railGrid =
  'grid grid-cols-1 gap-x-[clamp(2rem,5vw,4rem)] gap-y-3 lg:grid-cols-[13rem_minmax(0,1fr)] lg:items-start';
const railLabel = 'font-mono text-sm uppercase tracking-[0.08em] text-text-muted';
// One ruled row inside the track: the About "Practice" manifesto pattern, used
// by the services, the process steps, and the pricing tiers.
const ruledRow = 'grid gap-s border-t border-border py-l md:grid-cols-[1fr_2fr] md:gap-l';
// Shared accent-dot bullet for the "what's included" / feature lists.
const dotList = 'flex flex-col gap-2 leading-[1.5] text-text';
---

<BaseLayout
  title="Services | Nixon Creative Studio"
  description="Strategy, web design, and brand work for clients anywhere, plus photography across the greater Cincinnati region. Based in Cincinnati."
  schemas={schemas}
>

  <!-- ====================================================================
       Masthead (SERVICES). The only h1. No top hairline (it opens the page).
       ==================================================================== -->
  <section class="pt-2xl pb-2xl" aria-labelledby="services-hero-heading">
    <div class="ncs-container">
      <div class={railGrid}>

        <div class="flex flex-col gap-2" aria-hidden="true">
          <p class={railLabel}>Services</p>
          <p class="font-mono text-[0.8rem] text-text-muted">Cincinnati based, clients anywhere</p>
        </div>

        <div class="min-w-0">
          <h1
            id="services-hero-heading"
            class="max-w-[24ch] leading-[0.95]"
            data-reveal
          >
            Strategy, web design, and photography for organizations that care about the long run.
          </h1>
          <p
            class="mt-m max-w-[60ch] text-lg leading-[1.6] text-text"
            data-reveal
            style="--reveal-delay: 120ms;"
          >
            Most projects use all three services, in that order. Some use one or two. The first conversation always ends with an honest scope, not a sales pitch.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ====================================================================
       The offer (WHAT I DO). The three services as a hairline-ruled
       two-column editorial list (title + lede left, body + included right),
       not a card grid. Parallel offerings, so no numerals.
       ==================================================================== -->
  <section class="pb-2xl" aria-labelledby="services-offer-heading">
    <div class="ncs-container">
      <div class={`${railGrid} border-t border-border pt-2xl`}>

        <p class={railLabel} aria-hidden="true">What I do</p>

        <div class="min-w-0">
          <header class="max-w-[60ch]" data-reveal>
            <h2 id="services-offer-heading" class="text-heading">Three services, one person</h2>
            <p class="mt-xs text-lg leading-[1.55] text-text-muted">
              Most projects use all three. Some use one or two.
            </p>
          </header>

          <ul class="mt-l flex list-none flex-col border-b border-border p-0">
            {services.map((service, index) => (
              <li
                class={ruledRow}
                data-reveal
                style={`--reveal-delay: ${index * 100}ms;`}
              >
                <!-- Left: title + lede. -->
                <div class="flex flex-col gap-2">
                  <h3 class="text-h4 text-heading">{service.title}</h3>
                  <p class="max-w-[42ch] font-medium leading-[1.5] text-text">
                    {service.lede}
                  </p>
                </div>

                <!-- Right: body + what's included. The dot glyph is
                     decorative; the text carries the meaning. -->
                <div class="flex flex-col gap-s">
                  <p class="max-w-[60ch] leading-[1.7] text-text-muted">{service.body}</p>
                  <div class="flex flex-col gap-2">
                    <p class="text-sm font-semibold uppercase tracking-[0.12em] text-text-muted">
                      What's included
                    </p>
                    <ul class={dotList}>
                      {service.points.map((point) => (
                        <li class="flex items-start gap-s">
                          <span
                            class="mt-[0.5em] inline-block h-[0.45rem] w-[0.45rem] shrink-0 rounded-full bg-accent"
                            aria-hidden="true"
                          ></span>
                          <span>{point}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>


  <!-- ====================================================================
       How we work (PROCESS). The four ordered beats inlined as a ruled list
       on the shared axis (replacing the imported bg-bg-soft Process band).
       The 01-04 numerals are the page's one sanctioned numbered sequence.
       ==================================================================== -->
  <section class="pb-2xl" aria-labelledby="services-process-heading">
    <div class="ncs-container">
      <div class={`${railGrid} border-t border-border pt-2xl`}>

        <p class={railLabel} aria-hidden="true">Process</p>

        <div class="min-w-0">
          <header class="max-w-[60ch]" data-reveal>
            <h2 id="services-process-heading" class="text-heading">How we work</h2>
            <p class="mt-xs text-lg leading-[1.55] text-text-muted">
              Four steps, in order. Everything else follows from the first conversation.
            </p>
          </header>

          <ol class="mt-l flex flex-col border-b border-border p-0">
            {processSteps.map((step, index) => (
              <li
                class={ruledRow}
                data-reveal
                style={`--reveal-delay: ${index * 90}ms;`}
              >
                <!-- Left: numeral + step title. The numeral is aria-hidden;
                     the title carries the meaning in the heading tree. -->
                <div class="flex flex-col gap-2">
                  <span class="font-mono text-[0.95rem] tracking-[0.06em] text-link" aria-hidden="true">
                    {step.num}
                  </span>
                  <h3 class="text-h4 text-heading">{step.title}</h3>
                </div>
                <!-- Right: the step body. -->
                <p class="max-w-[60ch] leading-[1.6] text-text">{step.body}</p>
              </li>
            ))}
          </ol>
        </div>

      </div>
    </div>
  </section>


  <!-- ====================================================================
       What it costs (PRICING). The three tiers as a clean hairline-ruled
       comparison on the same axis, not a card grid. Every number traces back
       to the FAQ: $3,500 floor (count-up preserved), photography add-on,
       optional retainer. The "Most projects start here" marker is quiet text,
       not a filled pill.
       ==================================================================== -->
  <section class="pb-2xl" aria-labelledby="services-pricing-heading">
    <div class="ncs-container">
      <div class={`${railGrid} border-t border-border pt-2xl`}>

        <div class="flex flex-col gap-2" aria-hidden="true">
          <p class={railLabel}>Pricing</p>
          <p class="font-mono text-[0.8rem] text-text-muted">From $3,500</p>
        </div>

        <div class="min-w-0">
          <header class="max-w-[60ch]" data-reveal>
            <h2 id="services-pricing-heading" class="text-heading">What it costs</h2>
            <p class="mt-xs text-lg leading-[1.55] text-text-muted">
              A starting point, not a fixed menu. The free first conversation ends with a real ballpark for your project.
            </p>
          </header>

          <ul class="mt-l flex list-none flex-col border-b border-border p-0">
            {tiers.map((tier, index) => (
              <li
                class={`${ruledRow} md:grid-cols-[minmax(0,15rem)_1fr]`}
                data-reveal
                style={`--reveal-delay: ${index * 100}ms;`}
              >
                <!-- Left: tier name, the quiet "most projects" marker, and the
                     price line. The floor price counts up; the add-on and
                     retainer carry a plain word (genuinely "depends on scope"). -->
                <div class="flex flex-col gap-2">
                  <h3 class="text-h4 text-heading">{tier.name}</h3>
                  {tier.badge && (
                    <p class="text-xs font-semibold uppercase tracking-[0.1em] text-link">
                      {tier.badge}
                    </p>
                  )}
                  <p class="mt-1 flex items-baseline gap-xs">
                    {tier.priceFrom ? (
                      <>
                        <span class="text-sm font-medium text-text-muted">from</span>
                        <span class="font-display text-h2 leading-none text-heading">
                          $<span
                            data-countup
                            data-countup-to={tier.priceFrom}
                            data-countup-duration="1200"
                          >{tier.priceFrom.toLocaleString()}</span>{tier.priceSuffix}
                        </span>
                      </>
                    ) : (
                      <span class="font-display text-h3 leading-none text-link">
                        {tier.priceLabel}
                      </span>
                    )}
                  </p>
                </div>

                <!-- Right: the note + what's included. -->
                <div class="flex flex-col gap-s">
                  <p class="max-w-[60ch] leading-[1.6] text-text-muted">{tier.note}</p>
                  <ul class={dotList}>
                    {tier.features.map((feature) => (
                      <li class="flex items-start gap-s">
                        <span
                          class="mt-[0.5em] inline-block h-[0.45rem] w-[0.45rem] shrink-0 rounded-full bg-accent"
                          aria-hidden="true"
                        ></span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ))}
          </ul>

          <p class="mt-l max-w-[60ch] text-sm leading-[1.6] text-text-muted" data-reveal>
            Strategy is the front of every project, not a line item. The price above already includes the session and the brief.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ====================================================================
       Common questions (FAQ). Native <details>/<summary> for accessible,
       JS-free disclosure, moved onto the shared axis. The answer wrapper
       animates open and closed with a CSS grid trick: grid-template-rows
       0fr -> 1fr. The "+" marker rotates to "x" via group-open. The whole
       row works with keyboard and screen readers because it is a real
       <details> element. Markup + scoped styles preserved verbatim.
       ==================================================================== -->
  <section class="pb-2xl" aria-labelledby="services-faq-heading">
    <div class="ncs-container">
      <div class={`${railGrid} border-t border-border pt-2xl`}>

        <p class={railLabel} aria-hidden="true">FAQ</p>

        <div class="min-w-0">
          <header class="max-w-[60ch]" data-reveal>
            <h2 id="services-faq-heading" class="text-heading">Common questions</h2>
            <p class="mt-xs text-lg leading-[1.55] text-text-muted">
              The things people ask before the first call.
            </p>
          </header>

          <div class="mt-l flex flex-col border-t border-border">
            {faq.map((item, index) => (
              <!-- `group` lets the summary's open-state pseudo and the answer
                   wrapper both react via group-open:. -->
              <details
                class="faq-item group border-b border-border"
                data-reveal="fade"
                style={`--reveal-delay: ${index * 70}ms;`}
              >
                <!-- list-none drops the default disclosure triangle. The webkit
                     marker pseudo hides the Safari version. The "+" rotates to an
                     "x" when open; the rotation plus the smooth panel are two
                     non-color cues, so state is never signalled by color alone. -->
                <summary class="flex cursor-pointer list-none items-center justify-between gap-m py-m font-body text-lg font-semibold text-heading transition-colors duration-200 hover:text-link [&::-webkit-details-marker]:hidden after:font-mono after:text-xl after:leading-none after:text-accent after:transition-transform after:duration-300 after:content-['+'] group-open:after:rotate-[135deg]">
                  {item.q}
                </summary>
                <!-- Animated reveal: the grid row scales from 0fr to 1fr. The
                     inner div needs overflow-hidden so the clipped content does
                     not spill while the row is collapsing. -->
                <div class="faq-answer grid">
                  <div class="overflow-hidden">
                    <p class="max-w-[64ch] pb-m leading-[1.7] text-text">{item.a}</p>
                  </div>
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>


  <CtaBanner
    title="Ready to scope a project?"
    sub="The first conversation is free and lands at an honest ballpark by the end. Email is fastest, but a phone call works too."
  />

</BaseLayout>

<style>
  /* FAQ smooth open/close, JS-free.
     The answer wrapper is a CSS grid whose single row animates from 0fr
     (height collapsed to nothing) to 1fr (full natural height). Animating
     grid-template-rows transitions cleanly between the two without us ever
     knowing the pixel height, which is what makes a content-driven panel
     animate at all. The inner overflow-hidden div clips the text while the
     row is mid-transition. */
  .faq-answer {
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease;
  }

  .faq-item[open] .faq-answer {
    grid-template-rows: 1fr;
  }

  /* Respect reduced-motion: the panel still opens and closes, just instantly,
     matching the global motion policy. */
  @media (prefers-reduced-motion: reduce) {
    .faq-answer {
      transition: none;
    }
  }
</style>
