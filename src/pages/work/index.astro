---
// Safe to edit. Page content is driven from the case-studies content
// collection; add new MDX files in src/content/case-studies/ to grow the list.
/* ============================================================================
   /work | Selected Work Index
   ============================================================================
   Landing for the full case study list. Loads every entry from the
   case-studies collection, sorts newest first by published date, and
   renders each as a card linking to /work/{slug}.

   This is the only place the full catalogue lives. The homepage Selected
   Work section is a curated subset (featured===true).
   ============================================================================ */

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import WorkFilter from '../../components/WorkFilter';

const entries = (await getCollection('case-studies')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);

// Distinct sectors + years for the filter chips. Sectors stay in a
// fixed display order; years sort newest first.
const sectorLabels: Record<string, string> = {
  church:          'Church',
  preschool:       'Preschool',
  nonprofit:       'Nonprofit',
  'small-business':'Small Business',
};
const presentSectors = Array.from(new Set(entries.map((e) => e.data.sector)));
const sectors = (['church', 'preschool', 'nonprofit', 'small-business'] as const)
  .filter((s) => presentSectors.includes(s))
  .map((value) => ({ value, label: sectorLabels[value] }));
const years = Array.from(new Set(entries.map((e) => e.data.year))).sort((a, b) => b - a);
---

<BaseLayout
  title="Selected work | Nixon Creative Studio"
  description="A list of recent web design, brand, and photography projects from Nixon Creative Studio."
>

  <section class="py-2xl" aria-labelledby="work-index-heading">
    <div class="ncs-container">

      <!-- Intro block. Same number + title + sub pattern as SectionHeading,
           but rendered as an h1 since this page is the work landing. -->
      <header class="mb-xl flex flex-col gap-xs">
        <p class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">01</p>
        <h1 id="work-index-heading">Selected work</h1>
        <p class="max-w-[56ch] text-lg leading-[1.5] text-text-muted">
          A list of recent projects. Each one started with a conversation about what the organization actually needed.
        </p>
      </header>

      {/* Filter chips. Sector + year, client-side. The chips toggle a
          data-hidden attribute on the cards below; matching CSS in
          globals.css hides them with display:none. */}
      {(sectors.length > 1 || years.length > 1) && (
        <div class="mb-l">
          <WorkFilter client:load sectors={sectors} years={years} />
        </div>
      )}

      <!-- Card grid. Same auto-fit minmax pattern as the homepage strip. -->
      <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(18rem,1fr))]">
        {entries.map((entry) => {
          // Pretty sector label for the meta row: kebab-case → Title Case.
          const sectorLabel = entry.data.sector
            .replace(/-/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase());
          return (
            <li data-work-card data-sector={entry.data.sector} data-year={entry.data.year}>
              <!-- Whole card is the link, standard card a11y pattern. -->
              <a
                class="group flex flex-col gap-m rounded-xl text-inherit no-underline transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
                href={`/work/${entry.id}/`}
              >

                <!-- Image block. 4:3 aspect keeps cards uniform. Astro
                     <Image /> emits a real img with srcset; the wrapper
                     handles aspect ratio + rounding. alt="" because the
                     card's h2 immediately below carries the same name;
                     describing the image too would make screen readers
                     announce the title twice for one card. -->
                <div class="aspect-[4/3] w-full overflow-hidden rounded-lg bg-bg-soft">
                  <Image
                    src={entry.data.cover}
                    alt=""
                    widths={[400, 600, 900]}
                    sizes="(min-width: 56rem) 33vw, 100vw"
                    class="block h-full w-full object-cover"
                  />
                </div>

                <div class="flex flex-col gap-xs">
                  <p class="flex items-center gap-s font-mono text-[0.8rem] uppercase tracking-[0.05em] text-text-muted">
                    <span>{entry.data.year}</span>
                    <span aria-hidden="true">·</span>
                    <span>{sectorLabel}</span>
                  </p>
                  <h2 class="text-h3 text-heading">{entry.data.title}</h2>
                  <p class="leading-[1.5] text-text">{entry.data.summary}</p>
                  {entry.data.stack && entry.data.stack.length > 0 && (
                    <!-- Stack reveal. Collapsed (opacity 0 + max-height 0)
                         until the card is hovered or focus-visible. Reads
                         as a designer-y "inside the build" detail without
                         crowding the card at rest. Hidden from screen
                         readers via aria-hidden because the same info is
                         on the case study detail page and announcing it
                         here would clutter the link's accessible name. -->
                    <p
                      aria-hidden="true"
                      class="max-h-0 overflow-hidden font-mono text-[0.75rem] uppercase tracking-[0.06em] text-text-muted opacity-0 transition-[max-height,opacity,margin] duration-200 group-hover:mt-xs group-hover:max-h-12 group-hover:opacity-100 group-focus-visible:mt-xs group-focus-visible:max-h-12 group-focus-visible:opacity-100"
                    >
                      Built with {entry.data.stack.join(', ')}
                    </p>
                  )}
                  <span class="card-link">Read the case study</span>
                </div>

              </a>
            </li>
          );
        })}
      </ul>

      {/* "No matches" placeholder. Server-rendered, hidden by default
          via data-hidden, revealed by WorkFilter when all cards are
          filtered out. Lets visitors know the filter is doing something
          and isn't broken. */}
      <p
        data-work-empty
        data-hidden
        class="mt-l text-text-muted"
      >
        Nothing matches that filter yet. Try clearing one of the chips above.
      </p>

    </div>
  </section>

  <CtaBanner />

</BaseLayout>
