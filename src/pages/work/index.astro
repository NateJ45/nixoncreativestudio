---
// Safe to edit. Page content is driven from the case-studies content
// collection; add new MDX files in src/content/case-studies/ to grow the list.
/* ============================================================================
   /work | Selected Work Index
   ============================================================================
   Landing for the full case study list. Loads every entry from the
   case-studies collection, sorts newest first by published date, and
   renders each as a card linking to /work/{slug}.

   This is the only place the full catalogue lives. The homepage Selected
   Work section is a curated subset (featured===true).
   ============================================================================ */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CaseStudyCover from '../../components/CaseStudyCover.astro';
import WorkFilter from '../../components/WorkFilter';
import { getCoverPlaceholder } from '../../lib/coverPlaceholder';

const entries = (await getCollection('case-studies')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);

// Pre-baked blur placeholders for every cover. The data was generated
// by scripts/generate-placeholders.mjs at build time; the lookup here
// is a synchronous map read.
const placeholders = new Map<string, string | undefined>();
for (const entry of entries) {
  placeholders.set(entry.id, getCoverPlaceholder(entry.id));
}

// Distinct sectors + years for the filter chips. Sectors stay in a
// fixed display order; years sort newest first.
const sectorLabels: Record<string, string> = {
  church:          'Church',
  preschool:       'Preschool',
  nonprofit:       'Nonprofit',
  'small-business':'Small Business',
};
const presentSectors = Array.from(new Set(entries.map((e) => e.data.sector)));
const sectors = (['church', 'preschool', 'nonprofit', 'small-business'] as const)
  .filter((s) => presentSectors.includes(s))
  .map((value) => ({ value, label: sectorLabels[value] }));
const years = Array.from(new Set(entries.map((e) => e.data.year))).sort((a, b) => b - a);
---

<BaseLayout
  title="Selected work | Nixon Creative Studio"
  description="A list of recent web design, brand, and photography projects from Nixon Creative Studio."
>

  <section class="py-2xl" aria-labelledby="work-index-heading">
    <div class="ncs-container">

      <!-- Intro block. Rendered as an h1 since this is the work landing.
           The old decorative "01" mono eyebrow is gone; in its place a
           plain text kicker plus an honest count of projects, both derived
           from the real entries array so they never drift from the list. -->
      <header class="mb-xl flex flex-col gap-xs">
        <p
          data-reveal="fade"
          class="font-mono text-sm uppercase tracking-[0.12em] text-link"
        >
          Portfolio
        </p>
        <h1 id="work-index-heading" data-reveal class="text-gradient">Selected work</h1>
        <p
          data-reveal
          style="--reveal-delay: 90ms"
          class="max-w-[58ch] text-lg leading-[1.5] text-text-muted"
        >
          {entries.length}
          {entries.length === 1 ? ' project' : ' projects'} for churches,
          preschools, nonprofits, and small businesses around Cincinnati. Each
          one started with a conversation about what the organization actually
          needed.
        </p>
      </header>

      {/* Filter chips. Sector + year, client-side. The chips toggle a
          data-hidden attribute on the cards below; matching CSS in
          globals.css hides them with display:none. */}
      {(sectors.length > 1 || years.length > 1) && (
        <div class="mb-l">
          <WorkFilter client:load sectors={sectors} years={years} />
        </div>
      )}

      <!-- Card grid. Same auto-fit minmax pattern as the homepage strip.
           Each card scroll-reveals with a per-card stagger (delay derived
           from its index), lifts on hover, lights a cursor-following NCS-blue
           spotlight glow, and gently zooms its cover. The cover sits in a
           transition:name wrapper so it morphs into the matching hero on the
           case-study detail page (which declares the same cover-${id} name). -->
      <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(18rem,1fr))]">
        {entries.map((entry, i) => {
          // Pretty sector label for the meta row: kebab-case → Title Case.
          const sectorLabel = entry.data.sector
            .replace(/-/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase());
          return (
            <li data-work-card data-sector={entry.data.sector} data-year={entry.data.year}>
              <!-- Whole card is the link, standard card a11y pattern. The
                   spotlight-card class + data-spotlight wire the hover glow;
                   data-reveal fades it up on scroll with a staggered delay
                   so the grid populates row by row instead of all at once.
                   The stagger is capped so a long catalogue never feels slow. -->
              <a
                data-reveal
                data-spotlight
                style={`--reveal-delay: ${Math.min(i, 7) * 80}ms`}
                class="spotlight-card group hover-lift flex h-full flex-col gap-m rounded-xl border border-border bg-bg-soft p-s text-inherit no-underline transition-transform duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
                href={`/work/${entry.id}/`}
              >

                <!-- z-10 wrapper keeps the card content above the spotlight
                     glow that the spotlight-card paints behind it. -->
                <div class="relative z-10 flex h-full flex-col gap-m">

                  <!-- Cover. CaseStudyCover wraps Astro <Image /> with a
                       plaiceholder blur preview that paints while the full
                       image downloads, then fades the real image in.
                       alt="" because the card's h2 immediately below carries
                       the same name; describing the image too would make
                       screen readers announce the title twice per card.

                       The wrapper carries transition:name so this exact
                       cover element morphs into the detail page's hero image
                       during a View Transition. overflow-hidden clips the
                       inner zoom; the cover scales up a touch on hover. -->
                  <div
                    transition:name={`cover-${entry.id}`}
                    class="overflow-hidden rounded-lg"
                  >
                    <CaseStudyCover
                      cover={entry.data.cover}
                      placeholder={placeholders.get(entry.id)}
                      alt=""
                      widths={[400, 600, 900]}
                      sizes="(min-width: 56rem) 33vw, 100vw"
                      fit="cover"
                      class="aspect-[4/3] w-full transition-transform duration-500 ease-out group-hover:scale-[1.04] group-focus-visible:scale-[1.04]"
                    />
                  </div>

                  <div class="flex flex-col gap-xs">
                    <p class="flex items-center gap-s font-mono text-[0.8rem] uppercase tracking-[0.05em] text-text-muted">
                      <span>{entry.data.year}</span>
                      <span aria-hidden="true">·</span>
                      <span>{sectorLabel}</span>
                    </p>
                    <h2 class="text-h3 text-heading transition-colors duration-200 group-hover:text-link group-focus-visible:text-link">
                      {entry.data.title}
                    </h2>
                    {entry.data.outcome && (
                      <!-- Outcome line. The honest one-line result, lifted to
                           the top of the card body so the proof-point reads at
                           first scan. --link color marks it as the takeaway. -->
                      <p class="font-semibold leading-[1.4] text-link">{entry.data.outcome}</p>
                    )}
                    <p class="leading-[1.5] text-text">{entry.data.summary}</p>
                    {entry.data.stack && entry.data.stack.length > 0 && (
                      <!-- Stack reveal. Collapsed (opacity 0 + max-height 0)
                           until the card is hovered or focus-visible. Reads
                           as a designer-y "inside the build" detail without
                           crowding the card at rest. Hidden from screen
                           readers via aria-hidden because the same info is
                           on the case study detail page and announcing it
                           here would clutter the link's accessible name. -->
                      <p
                        aria-hidden="true"
                        class="max-h-0 overflow-hidden font-mono text-[0.75rem] uppercase tracking-[0.06em] text-text-muted opacity-0 transition-[max-height,opacity,margin] duration-200 group-hover:mt-xs group-hover:max-h-12 group-hover:opacity-100 group-focus-visible:mt-xs group-focus-visible:max-h-12 group-focus-visible:opacity-100"
                      >
                        Built with {entry.data.stack.join(', ')}
                      </p>
                    )}
                    <span class="card-link mt-auto pt-xs">Read the case study</span>
                  </div>

                </div>

              </a>
            </li>
          );
        })}
      </ul>

      {/* "No matches" placeholder. Server-rendered, hidden by default
          via data-hidden, revealed by WorkFilter when all cards are
          filtered out. Lets visitors know the filter is doing something
          and isn't broken. */}
      <p
        data-work-empty
        data-hidden
        class="mt-l text-text-muted"
      >
        Nothing matches that filter yet. Try clearing one of the chips above.
      </p>

    </div>
  </section>

  <CtaBanner />

</BaseLayout>
