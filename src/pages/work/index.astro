---
// Safe to edit. Page content is driven from the case-studies content
// collection; add new MDX files in src/content/case-studies/ to grow the list.
/* ============================================================================
   /work | Selected Work Index  [editorial-grid revamp]
   ============================================================================
   The full catalogue, rebuilt on the same editorial-grid spine as the About
   page so the two read as one ruled document:

     [ 13rem marker rail ] [ content track ]

   The catalogue is no longer a grid of equal cards. It is one hairline-ruled
   index of rows on a single left axis: each row is a single link to its case
   study, with the sector, title, and honest outcome line as type on the left and
   a small persistent cover thumbnail on the right (this is a visual portfolio, so
   the work stays visible, kept restrained as an aligned thumbnail rather than a
   big card). The newest entry gets a larger title as the lead. The cover keeps
   its shared-element View Transition into the detail hero.

   The "Open any of them" live-domain proof is folded into the same ruled column
   (no detached background band), so dark mode is one seamless navy sheet.

   Functional bits preserved verbatim: the WorkFilter sector island (toggles
   data-hidden on the rows), the collection-driven list, the real optimized
   covers + blur placeholders, and no year shown anywhere.
   ============================================================================ */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CaseStudyCover from '../../components/CaseStudyCover.astro';
import WorkFilter from '../../components/WorkFilter';
import { getCoverPlaceholder } from '../../lib/coverPlaceholder';

const entries = (await getCollection('case-studies')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);

// Entries that ship a real, public live URL, for the "open any of them" proof
// list. The strongest trust signal a web vendor has is work a visitor can click
// and inspect in five seconds, so these link straight to the live site (not the
// case study). Domains are shown as plain text, real domains only.
const entriesLive = entries.filter((e) => e.data.liveUrl);
const prettyDomain = (url: string) =>
  url.replace(/^https?:\/\//, '').replace(/^www\./, '').replace(/\/+$/, '');

// Pre-baked blur placeholders for every cover (generated at build time).
const placeholders = new Map<string, string | undefined>();
for (const entry of entries) {
  placeholders.set(entry.id, getCoverPlaceholder(entry.id));
}

// Distinct sectors for the filter chips, in a fixed display order. Year is
// intentionally not surfaced anywhere on the portfolio, so clients can't read
// project timing or count per year.
const sectorLabels: Record<string, string> = {
  church:          'Church',
  preschool:       'Preschool',
  nonprofit:       'Nonprofit',
  'small-business':'Small Business',
};
const presentSectors = Array.from(new Set(entries.map((e) => e.data.sector)));
const sectors = (['church', 'preschool', 'nonprofit', 'small-business'] as const)
  .filter((s) => presentSectors.includes(s))
  .map((value) => ({ value, label: sectorLabels[value] }));

// The shared editorial grid + rail label, copied from about.astro so /work and
// /about read as one ruled document with one left axis.
const railGrid =
  'grid grid-cols-1 gap-x-[clamp(2rem,5vw,4rem)] gap-y-3 lg:grid-cols-[13rem_minmax(0,1fr)] lg:items-start';
const railLabel = 'font-mono text-sm uppercase tracking-[0.08em] text-text-muted';
---

<BaseLayout
  title="Selected work | Nixon Creative Studio"
  description="A list of recent web design, brand, and photography projects from Nixon Creative Studio."
>

  <!-- ====================================================================
       Masthead (WORK). The page head: the only h1, with the honest count.
       No top hairline (it opens the page).
       ==================================================================== -->
  <section class="pt-2xl pb-2xl" aria-labelledby="work-index-heading">
    <div class="ncs-container">
      <div class={railGrid}>

        <div class="flex flex-col gap-2" aria-hidden="true">
          <p class={railLabel}>Work</p>
          <p class="font-mono text-[0.8rem] text-text-muted">
            {entries.length} {entries.length === 1 ? 'project' : 'projects'}
          </p>
        </div>

        <div class="min-w-0">
          <h1 id="work-index-heading" data-reveal>Selected work</h1>
          <p
            data-reveal
            style="--reveal-delay: 90ms"
            class="mt-xs max-w-[58ch] text-lg leading-[1.5] text-text-muted"
          >
            {entries.length}
            {entries.length === 1 ? ' project' : ' projects'} for churches,
            preschools, nonprofits, and small businesses around Cincinnati. Each
            one started with a conversation about what the organization actually
            needed.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ====================================================================
       Filter (FILTER). The sector chips, on the shared axis as a quiet control
       bar. The WorkFilter island is unchanged: it toggles data-hidden on the
       rows below. Rendered only when there's more than one sector.
       ==================================================================== -->
  {sectors.length > 1 && (
    <section class="pb-l" aria-label="Filter projects by sector">
      <div class="ncs-container">
        <div class={`${railGrid} border-t border-border pt-2xl`}>
          <p class={railLabel} aria-hidden="true">Filter</p>
          <div class="min-w-0" data-reveal>
            <WorkFilter client:load sectors={sectors} />
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ====================================================================
       The Index (INDEX). One hairline-ruled <ol> of rows on the left axis. Each
       row is a single link to the case study: sector + title + outcome as type
       on the left, a small persistent cover thumbnail on the right (lg+). The
       cover keeps its transition:name for the shared-element morph into the
       detail hero. The newest entry leads with a larger title.
       ==================================================================== -->
  <section class="pb-2xl" aria-labelledby="work-index-heading">
    <div class="ncs-container">
      <div class={`${railGrid} border-t border-border pt-2xl`}>

        <div class="flex flex-col gap-3" aria-hidden="true">
          <p class={railLabel}>Index</p>
          <span class="h-px w-12 bg-tertiary"></span>
        </div>

        <div class="min-w-0">
          <ol class="flex flex-col border-b border-border">
            {entries.map((entry, i) => {
              const sectorLabel = entry.data.sector
                .replace(/-/g, ' ')
                .replace(/\b\w/g, (c) => c.toUpperCase());
              const isLead = i === 0;
              // One calm proof line per row: the honest outcome if present, the
              // summary as a fallback so no row is bare.
              const proof = entry.data.outcome ?? entry.data.summary;
              return (
                <li data-work-card data-sector={entry.data.sector}>
                  <a
                    href={`/work/${entry.id}/`}
                    data-reveal
                    style={`--reveal-delay: ${Math.min(i, 5) * 70}ms`}
                    class="group grid grid-cols-1 items-center gap-l border-t border-border py-l text-inherit no-underline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 lg:grid-cols-[minmax(0,1fr)_11rem]"
                  >
                    <div class="min-w-0">
                      <p class="text-xs font-semibold uppercase tracking-[0.06em] text-text-muted">
                        {sectorLabel}
                      </p>
                      <h2 class:list={[
                        'mt-1 text-heading transition-colors duration-200 group-hover:text-link group-focus-visible:text-link',
                        isLead ? 'text-h2' : 'text-h3',
                      ]}>
                        {entry.data.title}
                      </h2>
                      {proof && (
                        <p class:list={[
                          'mt-2 font-semibold leading-[1.4] text-link',
                          isLead && 'text-lg',
                        ]}>
                          {proof}
                        </p>
                      )}
                      <span class="card-link mt-s inline-flex">Read the case study</span>
                    </div>

                    <!-- Cover thumbnail (lg+). alt="" because the row's h2 carries
                         the name; the transition:name wrapper morphs it into the
                         detail page's hero during a View Transition. -->
                    <div
                      transition:name={`cover-${entry.id}`}
                      class="hidden overflow-hidden rounded-lg lg:block"
                    >
                      <CaseStudyCover
                        cover={entry.data.cover}
                        placeholder={placeholders.get(entry.id)}
                        alt=""
                        widths={[220, 330, 440]}
                        sizes="(min-width: 64rem) 11rem, 0px"
                        fit="cover"
                        class="aspect-[4/3] w-full transition-transform duration-500 ease-out group-hover:scale-[1.04] group-focus-visible:scale-[1.04]"
                      />
                    </div>
                  </a>
                </li>
              );
            })}
          </ol>

          {/* "No matches" placeholder. Server-rendered, hidden by default via
              data-hidden, revealed by WorkFilter when all rows are filtered out. */}
          <p data-work-empty data-hidden class="mt-l text-text-muted">
            Nothing matches that filter yet. Try clearing one of the chips above.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ====================================================================
       Live sites (LIVE). The "open any of them" proof, folded into the ruled
       column (no background band) as a second hairline list: every shipped site
       as a clickable real domain in a new tab. A faster, different affordance
       than the index above (the live site, not the case study).
       ==================================================================== -->
  {entriesLive.length > 1 && (
    <section class="pb-2xl" aria-labelledby="live-sites-heading">
      <div class="ncs-container">
        <div class={`${railGrid} border-t border-border pt-2xl`}>

          <div class="flex flex-col gap-2" aria-hidden="true">
            <p class={railLabel}>Live</p>
            <span class="font-mono text-[0.8rem] text-text-muted">↗ open in a new tab</span>
          </div>

          <div class="min-w-0">
            <header class="max-w-[60ch]" data-reveal>
              <h2 id="live-sites-heading">Open any of them</h2>
              <p class="mt-xs text-lg leading-[1.55] text-text-muted">
                Every project here is a real, shipped site. Do not take my word for it,
                click through and look around.
              </p>
            </header>

            <ul class="mt-l flex flex-col border-b border-border">
              {entriesLive.map((e, i) => (
                <li data-reveal style={`--reveal-delay: ${Math.min(i, 5) * 60}ms`}>
                  <a
                    href={e.data.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-baseline justify-between gap-s border-t border-border py-s text-inherit no-underline transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
                  >
                    <span class="font-display text-h4 leading-[1.1] text-heading transition-colors group-hover:text-link group-focus-visible:text-link">
                      {e.data.client}
                    </span>
                    <span class="inline-flex shrink-0 items-center gap-1 font-mono text-[0.8rem] text-text-muted transition-colors group-hover:text-link group-focus-visible:text-link">
                      {prettyDomain(e.data.liveUrl)}
                      <span aria-hidden="true">↗</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>
  )}

  <CtaBanner />

</BaseLayout>
