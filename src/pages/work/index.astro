---
// Safe to edit. Page content is driven from the case-studies content
// collection; add new MDX files in src/content/case-studies/ to grow the list.
/* ============================================================================
   /work | Selected Work Index
   ============================================================================
   Landing for the full case study list. Loads every entry from the
   case-studies collection, sorts newest first by published date, and
   renders each as a card linking to /work/{slug}.

   This is the only place the full catalogue lives. The homepage Selected
   Work section is a curated subset (featured===true).
   ============================================================================ */

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const entries = (await getCollection('case-studies')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
---

<BaseLayout
  title="Selected work | Nixon Creative Studio"
  description="A list of recent web design, brand, and photography projects from Nixon Creative Studio."
>

  <section class="py-2xl">
    <div class="ncs-container">

      <!-- Intro block. Same number + title + sub pattern as SectionHeading,
           but rendered as an h1 since this page is the work landing. -->
      <header class="mb-xl flex flex-col gap-xs">
        <p class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">01</p>
        <h1>Selected work</h1>
        <p class="max-w-[56ch] text-lg leading-[1.5] text-text-muted">
          A list of recent projects. Each one started with a conversation about what the organization actually needed.
        </p>
      </header>

      <!-- Card grid. Same auto-fit minmax pattern as the homepage strip. -->
      <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(18rem,1fr))]">
        {entries.map((entry) => {
          // Pretty sector label for the meta row: kebab-case → Title Case.
          const sectorLabel = entry.data.sector
            .replace(/-/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase());
          return (
            <li>
              <!-- Whole card is the link, standard card a11y pattern. -->
              <a
                class="group flex flex-col gap-m rounded-xl text-inherit no-underline transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
                href={`/work/${entry.id}/`}
              >

                <!-- Image block. 4:3 aspect keeps cards uniform. Astro
                     <Image /> emits a real img with srcset; the wrapper
                     handles aspect ratio + rounding. -->
                <div class="aspect-[4/3] w-full overflow-hidden rounded-lg bg-bg-soft">
                  <Image
                    src={entry.data.cover}
                    alt={`${entry.data.title} hero image`}
                    widths={[400, 600, 900]}
                    sizes="(min-width: 56rem) 33vw, 100vw"
                    class="block h-full w-full object-cover"
                  />
                </div>

                <div class="flex flex-col gap-xs">
                  <p class="flex items-center gap-s font-mono text-[0.8rem] uppercase tracking-[0.05em] text-text-muted">
                    <span>{entry.data.year}</span>
                    <span aria-hidden="true">·</span>
                    <span>{sectorLabel}</span>
                  </p>
                  <h2 class="text-h3 text-primary">{entry.data.title}</h2>
                  <p class="leading-[1.5] text-text">{entry.data.summary}</p>
                  <span class="card-link">Read the case study</span>
                </div>

              </a>
            </li>
          );
        })}
      </ul>

    </div>
  </section>

  <CtaBanner />

</BaseLayout>
