---
// Foundation, edit with care. This page renders every case study from the
// content collection; layout changes here apply to every entry.
/* ============================================================================
   /work/[slug] | Case Study Detail Page
   ============================================================================
   One static page per case study, generated at build time from the
   case-studies content collection.

   Same shape for every entry: reading progress bar, hero block (meta +
   title + client + summary + service badges + image), MDX body, then
   next/previous navigation + CtaBanner. Adding a new MDX file in
   src/content/case-studies/ auto-creates its page on the next build.
   ============================================================================ */

import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CaseStudyCover from '../../components/CaseStudyCover.astro';
import ReadingProgress from '../../components/ReadingProgress';
import { Badge } from '../../components/ui/badge';
import { readingTime } from '../../lib/readingTime';
import { getCoverPlaceholder } from '../../lib/coverPlaceholder';
import { site } from '../../data/site';

// getStaticPaths now passes neighbors as props (for the next/prev nav at
// the bottom of each case study). The full sorted list is computed once
// here; each route gets only its own entry plus the neighbor stubs it
// needs to render the nav, so we don't ship the whole catalogue per page.
export async function getStaticPaths() {
  const all = (await getCollection('case-studies')).sort(
    (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
  );
  return all.map((entry, i) => {
    const previous = i < all.length - 1 ? all[i + 1] : undefined;
    const next     = i > 0             ? all[i - 1] : undefined;
    // Strip neighbors down to just the fields the nav block uses; keeps
    // props payload small and the page free of incidental data.
    const trim = (e: typeof entry | undefined) =>
      e ? { id: e.id, title: e.data.title, summary: e.data.summary } : undefined;
    return {
      params: { slug: entry.id },
      props:  { entry, previous: trim(previous), next: trim(next) },
    };
  });
}

const { entry, previous, next } = Astro.props;
const { Content, headings } = await render(entry);

// Table-of-contents headings (the body h2s). Both the sticky sidebar TOC and the
// wide two-column body layout only kick in when there are at least two, so short
// studies stay single-column and centered.
const tocHeadings = (headings ?? []).filter((h) => h.depth === 2);
const hasToc = tocHeadings.length >= 2;
const { title, client, sector, services, summary, cover, role, tags, published, updated, stack, liveUrl, outcome, testimonial } = entry.data;

// Pretty-printed sector label for the meta row. kebab-case → Title Case.
const sectorLabel = sector.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

// Reading time from the raw MDX body. ~200 wpm rounded up. Renders next
// to the meta row so visitors know how long the case study is before
// committing to scroll.
const minutes = readingTime(entry.body ?? '');

// Note: published / updated dates are intentionally NOT displayed in the UI
// (the client doesn't want project timing showcased). They stay in the
// frontmatter and feed sort order, the RSS feed, and the JSON-LD below.

// Resolve the cover through Astro's image pipeline so we can use the
// optimized URL for both the OG image meta tag and the CreativeWork
// schema. Width caps the file size; social platforms cap previews at
// 1200px anyway.
const ogCover = await getImage({ src: cover, width: 1200, format: 'jpg' });
const ogCoverUrl = new URL(ogCover.src, site.url).toString();

// Build-time plaiceholder blur preview. Returns undefined when the
// source file doesn't follow the src/assets/case-studies/{slug}.{ext}
// convention, in which case CaseStudyCover falls back to its bg-soft
// solid placeholder.
const coverBlur = getCoverPlaceholder(entry.id);

// Article + CreativeWork JSON-LD for this case study. CreativeWork is
// the more general type that fits portfolio entries; Article gives
// search engines a date / headline / image they can show in rich
// results. Both reference the studio Organization via @id.
const schemas = [
  {
    '@context':     'https://schema.org',
    '@type':        ['Article', 'CreativeWork'],
    headline:       title,
    description:    summary,
    image:          ogCoverUrl,
    datePublished:  published.toISOString(),
    ...(updated ? { dateModified: updated.toISOString() } : {}),
    author:         { '@id': `${site.url}#organization` },
    publisher:      { '@id': `${site.url}#organization` },
    about:          client,
    keywords:       services.join(', '),
  },
];
---

<BaseLayout
  title={`${title} | Nixon Creative Studio`}
  description={summary}
  ogImage={ogCover.src}
  ogType="article"
  schemas={schemas}
>

  {/* Reading progress bar pinned to the top of the viewport. Only
      rendered here, not in BaseLayout, because the rest of the site has
      mostly short pages where a progress bar would be visual noise. */}
  <ReadingProgress client:idle />

  <article>

    <!-- Hero block. Two-column on >= 56rem (copy left, image right),
         stacked on mobile. Generous padding so the case study feels like
         its own landing, not a continuation of the previous page. -->
    <header class="py-2xl">
      <div class="ncs-container grid grid-cols-1 items-center gap-xl min-[56rem]:grid-cols-2">

        <div class="flex flex-col gap-m" data-reveal>

          <!-- Meta stamp: sector + read time. Mono and muted. No year. -->
          <p class="flex flex-wrap items-center gap-s font-mono text-[0.85rem] uppercase tracking-[0.06em] text-text-muted">
            <span>{sectorLabel}</span>
            <span aria-hidden="true">·</span>
            <span>{minutes} min read</span>
          </p>

          <h1 class="leading-[0.95]">{title}</h1>

          <!-- Client line below the title; client and title often differ
               for ministry or program-level engagements. -->
          <p class="font-display text-h4 text-link">{client}</p>

          <p class="max-w-[56ch] text-lg leading-[1.6] text-text">{summary}</p>

          {/* Outcome callout (optional). The honest, one-line result of the
              project, lifted out of the body so the proof reads at first scan.
              Marked as the takeaway by a small label + larger --link type and
              whitespace, not a side-stripe border (an absolute-ban tell). */}
          {outcome && (
            <div class="mt-s max-w-[56ch]">
              <p class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Outcome</p>
              <p class="mt-1 text-xl font-semibold leading-[1.4] text-link">{outcome}</p>
            </div>
          )}

          {/* Live site link (optional). For a web design portfolio this is
              the strongest single trust signal: a click straight to real,
              working proof. Rendered as a brand-weight link with an external
              cue; opens in a new tab with rel noopener for safety. */}
          {liveUrl && (
            <a
              href={liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-fit items-center gap-2 font-body text-base font-semibold text-link underline underline-offset-4 transition-colors hover:text-accent focus-visible:text-accent focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
            >
              Visit the live site
              <span aria-hidden="true">↗</span>
            </a>
          )}

          {/* Role line (optional). Tiny mono uppercase, sits below the
              summary as a credit. Useful when the case study wants to
              clarify whether Nathan led design, code, photography, or
              some combination. */}
          {role && (
            <p class="font-mono text-[0.85rem] uppercase tracking-[0.06em] text-text-muted">
              <span class="text-text">Role:</span> {role}
            </p>
          )}

          {/* Stack list (optional). When present, render a tiny tools
              line so designers and devs evaluating the work can scan
              what was used. Plain text, no styling flourish. */}
          {stack && stack.length > 0 && (
            <p class="font-mono text-[0.85rem] uppercase tracking-[0.06em] text-text-muted">
              <span class="text-text">Built with:</span> {stack.join(', ')}
            </p>
          )}

          <!-- Service badges. Each rendered as an outlined accent-color
               pill. flex-wrap so they wrap on narrow screens. -->
          <ul class="mt-s flex flex-wrap gap-xs" aria-label="Services delivered">
            {services.map((service) => (
              <li class="inline-flex items-center rounded-full border border-link px-2.5 py-1 font-body text-[0.8rem] text-link">
                {service}
              </li>
            ))}
          </ul>

          {/* Tag chips (optional). Smaller and quieter than the service
              pills above so the eye reads them as supporting metadata
              rather than primary scope. */}
          {tags && tags.length > 0 && (
            <ul class="flex flex-wrap gap-xs" aria-label="Tags">
              {tags.map((tag) => (
                <li>
                  <Badge variant="outline" className="border-border text-text-muted">
                    {tag}
                  </Badge>
                </li>
              ))}
            </ul>
          )}

        </div>

        <!-- Hero image. CaseStudyCover wraps Astro <Image /> with a
             plaiceholder blur preview painted as the wrapper's bg, then
             fades the full image in once it loads.

             alt="" because the case study's h1 sits just above the image
             inside the same <header>, so a descriptive alt would make
             screen readers announce the title twice. For a richer
             description (e.g. "Photo of the Crestview team in the
             sanctuary"), add a coverAlt field to the case-studies
             schema in content.config.ts and thread it through here. -->
        <div transition:name={`cover-${entry.id}`}>
          <CaseStudyCover
            cover={cover}
            placeholder={coverBlur}
            alt=""
            widths={[640, 960, 1440]}
            sizes="(min-width: 56rem) 50vw, 100vw"
          />
        </div>

      </div>
    </header>

    <!-- MDX body + optional TOC sidebar. Two-column at xl (sidebar at
         left, prose middle); single-column below.

         Sidebar renders only when the MDX body has at least two h2s, so
         short case studies with one or no h2 just show the prose at full
         width. -->
    <div class="ncs-container">
      <div
        class:list={[
          'mx-auto grid max-w-[84rem] gap-xl pb-2xl pt-l',
          hasToc ? 'xl:grid-cols-[14rem_minmax(0,1fr)]' : 'xl:grid-cols-1',
        ]}
      >

        {/* Sticky TOC. Lists every h2 in the MDX body as a jump link.
            Hidden below xl since the sidebar would crowd narrow viewports.
            Native <nav aria-label> so screen readers identify it. */}
        {hasToc && (
          <nav aria-label="In this case study" class="hidden xl:block">
            <div class="sticky top-l flex flex-col gap-xs">
              <p class="font-mono text-[0.75rem] uppercase tracking-[0.08em] text-text-muted">
                In this case study
              </p>
              <ul class="flex flex-col gap-xs">
                {tocHeadings.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="block text-[0.95rem] leading-[1.4] text-text transition-colors duration-150 hover:text-link focus-visible:text-link"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </nav>
        )}

        {/* MDX prose. When the TOC is present the content column is wide. The
            TEXT blocks (h2/p/ul/...) are capped to a readable measure AND
            centered (mx-auto) so they share one center axis with the full-width
            media (SiteShowcase, FeatureHighlight, images). That turns the old
            one-sided "empty column to the right" into balanced breathing room on
            both sides, with media still stretching the full width. Every text
            block uses the SAME max-width so their left edges line up. Without a
            TOC the prose is simply centered at a readable width. The arbitrary
            descendant selectors style the MDX output without the typography
            plugin and without leaking to the rest of the site. */}
        <div
          data-prose
          class:list={[
            'text-[1.0625rem] leading-[1.7] text-text',
            hasToc ? 'w-full' : 'mx-auto w-full max-w-[72ch]',
            '[&_h2]:mt-l [&_h2]:mb-s [&_h2]:scroll-mt-l [&_h2]:text-h3 [&_h2]:text-heading [&_h2:first-child]:mt-0',
            '[&_p]:mb-m [&_ul]:mb-m [&_ul]:list-disc [&_ul]:pl-5 [&_li]:mb-1',
            '[&_a]:text-link [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:underline-offset-4',
            hasToc
              ? '[&_p]:mx-auto [&_p]:max-w-[70ch] [&_h2]:mx-auto [&_h2]:max-w-[70ch] [&_h3]:mx-auto [&_h3]:max-w-[70ch] [&_ul]:mx-auto [&_ul]:max-w-[70ch] [&_ol]:mx-auto [&_ol]:max-w-[70ch] [&_blockquote]:mx-auto [&_blockquote]:max-w-[70ch]'
              : '',
          ]}
        >
          <Content />
        </div>

      </div>
    </div>

    {/* Testimonial pull-quote (optional). Real client social proof, set
        apart from the body as a centered editorial quote. Renders nothing
        when the frontmatter has no testimonial, so it is safe to leave off
        until a real quote is collected. Never fabricated. */}
    {testimonial && (
      <aside class="border-t border-border py-2xl" aria-label="Client testimonial" data-reveal>
        <figure class="ncs-container mx-auto max-w-[60ch] text-center">
          <blockquote class="font-display text-h3 leading-[1.2] text-heading">
            <p>“{testimonial.quote}”</p>
          </blockquote>
          <figcaption class="mt-m font-mono text-[0.85rem] uppercase tracking-[0.06em] text-text-muted">
            <span class="text-text">{testimonial.name}</span>{testimonial.title ? ` · ${testimonial.title}` : ''}
          </figcaption>
        </figure>
      </aside>
    )}

    {/* Next / previous case study nav. Sits between the body and the
        CtaBanner so visitors who finished reading have a forward path
        before hitting the "Start a project" CTA. Hidden entirely when
        there's only one case study in the catalogue. */}
    {(previous || next) && (
      <nav class="border-t border-border py-xl" aria-label="More case studies">
        <div class="ncs-container grid grid-cols-1 gap-l sm:grid-cols-2">

          {previous ? (
            <a
              href={`/work/${previous.id}/`}
              class="group flex flex-col gap-xs rounded-lg p-m text-inherit no-underline transition-colors duration-150 hover:bg-bg-soft focus-visible:bg-bg-soft focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
            >
              <span class="font-mono text-[0.8rem] uppercase tracking-[0.06em] text-text-muted">
                ← Previous case study
              </span>
              <span class="font-display text-h4 text-heading transition-colors group-hover:text-link group-focus-visible:text-link">
                {previous.title}
              </span>
              <span class="text-[0.95rem] leading-[1.5] text-text-muted">
                {previous.summary}
              </span>
            </a>
          ) : (
            <span></span>
          )}

          {next ? (
            <a
              href={`/work/${next.id}/`}
              class="group flex flex-col gap-xs rounded-lg p-m text-inherit no-underline transition-colors duration-150 hover:bg-bg-soft focus-visible:bg-bg-soft focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 sm:text-right"
            >
              <span class="font-mono text-[0.8rem] uppercase tracking-[0.06em] text-text-muted">
                Next case study →
              </span>
              <span class="font-display text-h4 text-heading transition-colors group-hover:text-link group-focus-visible:text-link">
                {next.title}
              </span>
              <span class="text-[0.95rem] leading-[1.5] text-text-muted">
                {next.summary}
              </span>
            </a>
          ) : (
            <span></span>
          )}

        </div>
      </nav>
    )}

  </article>

  <CtaBanner />

</BaseLayout>
