---
// Foundation, edit with care. This page renders every case study from the
// content collection; layout changes here apply to every entry.
/* ============================================================================
   /work/[slug] | Case Study Detail Page
   ============================================================================
   One static page per case study, generated at build time from the
   case-studies content collection.

   Same shape for every entry: hero block (meta + title + client + summary
   + service badges + image), then the MDX body, then CtaBanner. Adding
   a new MDX file in src/content/case-studies/ auto-creates its page on
   the next build.
   ============================================================================ */

import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, client, sector, services, summary, hero_image, year } = entry.data;

// Pretty-printed sector label for the meta row. kebab-case → Title Case.
const sectorLabel = sector.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
---

<BaseLayout title={`${title} | Nixon Creative Studio`} description={summary}>

  <article>

    <!-- Hero block. Two-column on >= 56rem (copy left, image right),
         stacked on mobile. Generous padding so the case study feels like
         its own landing, not a continuation of the previous page. -->
    <header class="py-2xl">
      <div class="ncs-container grid grid-cols-1 items-center gap-xl min-[56rem]:grid-cols-2">

        <div class="flex flex-col gap-m">

          <!-- Meta stamp: year + sector. Mono and muted. -->
          <p class="flex items-center gap-s font-mono text-[0.85rem] uppercase tracking-[0.06em] text-text-muted">
            <span>{year}</span>
            <span aria-hidden="true">·</span>
            <span>{sectorLabel}</span>
          </p>

          <h1 class="leading-[0.95]">{title}</h1>

          <!-- Client line below the title; client and title often differ
               for ministry or program-level engagements. -->
          <p class="font-display text-h4 text-accent">{client}</p>

          <p class="max-w-[56ch] text-lg leading-[1.6] text-text">{summary}</p>

          <!-- Service badges. Each rendered as an outlined accent-color
               pill. flex-wrap so they wrap on narrow screens. -->
          <ul class="mt-s flex flex-wrap gap-xs" aria-label="Services delivered">
            {services.map((service) => (
              <li class="inline-flex items-center rounded-full border border-accent px-2.5 py-1 font-body text-[0.8rem] text-accent">
                {service}
              </li>
            ))}
          </ul>

        </div>

        <!-- Hero image. Astro <Image /> handles WebP, srcset, explicit
             dimensions. overflow-hidden + rounded rounds the corners. -->
        <div class="overflow-hidden rounded-lg">
          <Image
            src={hero_image}
            alt={`${title} hero image`}
            widths={[600, 900, 1200]}
            sizes="(min-width: 56rem) 50vw, 100vw"
            class="block h-auto w-full"
          />
        </div>

      </div>
    </header>

    <!-- MDX body. The arbitrary descendant selectors on this wrapper style
         the MDX output (h2/p/ul/li/a) without using the typography plugin
         and without leaking those rules to the rest of the site. -->
    <div class="ncs-container">
      <div
        class={`mx-auto max-w-[72ch] pb-2xl pt-l text-[1.0625rem] leading-[1.7] text-text
          [&_h2]:mt-l [&_h2]:mb-s [&_h2]:text-h3 [&_h2]:text-primary [&_h2:first-child]:mt-0
          [&_p]:mb-m
          [&_ul]:mb-m [&_ul]:list-disc [&_ul]:pl-5
          [&_li]:mb-1
          [&_a]:text-accent [&_a]:underline [&_a]:underline-offset-2
          hover:[&_a]:text-secondary`}
      >
        <Content />
      </div>
    </div>

  </article>

  <CtaBanner />

</BaseLayout>
