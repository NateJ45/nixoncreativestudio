---
// Safe to edit. Friendly 404. Astro picks this up automatically for any
// route that doesn't match a real page; Cloudflare Pages serves it as
// the static fallback for unknown paths in production.
/* ============================================================================
   /404 | Page not found
   ============================================================================
   Hero-style single column, centered. An oversized low-opacity navy "404"
   anchors the page as a quiet centerpiece, the warm "that page wandered off"
   copy sits below, and the same helpful links carry visitors back into the site.
   The whole block reveals in on load. The "404" floats gently (and the
   float pauses under prefers-reduced-motion via the local @media rule).
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import { buttonVariants } from '../components/ui/button';
---

<BaseLayout
  title="Page not found | Nixon Creative Studio"
  description="That page wandered off. Here's how to get back on track."
>

  <section
    class="relative isolate flex min-h-[70vh] items-center overflow-hidden py-2xl"
    aria-labelledby="notfound-heading"
  >
    <div class="ncs-container flex flex-col items-center gap-m text-center">

      {/* Oversized quiet centerpiece. A low-opacity navy numeral as a backdrop.
          Decorative: the real "404" meaning is announced in the line below, so
          this is aria-hidden. */}
      <div
        class="notfound-figure pointer-events-none select-none leading-none"
        aria-hidden="true"
        data-reveal="scale"
      >
        <span
          class="block font-display text-[clamp(7rem,28vw,18rem)] leading-[0.85] tracking-tight text-heading/10 dark:text-heading/20"
        >404</span>
      </div>

      {/* Quiet mono label above the heading. Lowercase and lightly tracked so
          it reads as a small status line, not a shouted section eyebrow. */}
      <p
        class="font-mono text-sm text-text-muted"
        data-reveal
        style="--reveal-delay: 80ms"
      >
        Page not found
      </p>

      <h1
        id="notfound-heading"
        class="max-w-[18ch] leading-[0.95]"
        data-reveal
        style="--reveal-delay: 160ms"
      >
        That page wandered off.
      </h1>

      <p
        class="max-w-[50ch] text-lg leading-[1.6] text-text"
        data-reveal
        style="--reveal-delay: 240ms"
      >
        The link you followed might be old, or the address might be a typo. Nothing's broken on this end. Here are a few places to try instead.
      </p>

      <div
        class="mt-s flex flex-wrap items-center justify-center gap-m"
        data-reveal
        style="--reveal-delay: 320ms"
      >
        <span class="inline-block">
          <a href="/" class={buttonVariants({ variant: 'brand', size: 'cta', className: 'shine' })}>
            Back to home
          </a>
        </span>
        <a class="card-link" href="/work/">See selected work</a>
        <a class="card-link" href="/contact">Get in touch</a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* Gentle drift for the oversized 404. The reveal vocabulary handles the
     entrance; this keeps it quietly alive afterward. Paused for visitors who
     prefer reduced motion. */
  .notfound-figure {
    animation: notfound-float 7s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes notfound-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .notfound-figure {
      animation: none;
    }
  }
</style>
