---
// Foundation, edit with care. Phase 4 swaps the gradient tile placeholders
// for real photography backed by the new Photo and PhotoGallery components.
/* ============================================================================
   /photography | Photography
   ============================================================================
   Image-heavy showcase. Three categories: Events, Portraits, Environments.
   Each gets a short intro plus a gallery grid of square tiles.

   For now every tile is a brand-gradient placeholder. Phase 4 wires the
   new PhotoGallery (react-photo-album + yet-another-react-lightbox)
   into the gallery sections and the Photo component into PhotoStrip.
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';

// Category overview. id doubles as both the in-page anchor target and
// the gallery section id below.
const categories = [
  {
    id: 'events',
    title: 'Events',
    body: 'Sunday mornings, school assemblies, fundraisers, ribbon cuttings. Coverage that tells the story without making the room perform for the camera.',
    tiles: 6,
  },
  {
    id: 'portraits',
    title: 'Portraits',
    body: 'Team headshots, staff portraits, leadership pages. Comfortable lighting, consistent treatment, edited for web so the file size stays sane.',
    tiles: 6,
  },
  {
    id: 'environments',
    title: 'Environments',
    body: 'Lobbies, classrooms, sanctuaries, storefronts. The spaces visitors actually walk into, photographed in the light they actually see.',
    tiles: 4,
  },
];
---

<BaseLayout
  title="Photography | Nixon Creative Studio"
  description="Events, portraits, and environmental photography for organizations in the Cincinnati region."
>

  <!-- ----------------------------------------------------------------------
       Hero
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class="ncs-container">
      <p class="mb-m inline-flex items-baseline gap-s text-[0.95rem] text-text-muted">
        <span class="font-mono text-sm tracking-[0.05em]">P1</span>
        <span>Photography</span>
      </p>
      <h1 class="mb-m max-w-[22ch] leading-[0.95]">
        Photography that matches the website it lives on.
      </h1>
      <p class="max-w-[60ch] text-lg leading-[1.6] text-text">
        Most of these photos came from the same projects as the web work. Same person designed the site and showed up with the camera, so the imagery and the layout speak the same language.
      </p>
    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Category overview. Three quick-jump cards that scroll the visitor
       to the matching gallery section. Soft tinted band so the strip
       reads as a separate navigation block.
       ---------------------------------------------------------------------- -->
  <section class="bg-bg-soft pb-2xl pt-l">
    <div class="ncs-container">
      <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(16rem,1fr))]">
        {categories.map((category) => (
          <li>
            <a
              class="flex flex-col gap-s rounded-lg bg-bg p-m text-inherit no-underline transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
              href={`#${category.id}`}
            >
              <!-- Bumped to text-h3 so the card title reads as a heading. -->
              <h2 class="text-h3 text-primary">{category.title}</h2>
              <p class="leading-[1.5] text-text">{category.body}</p>
              <span class="card-link">Jump to gallery</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Gallery sections. One per category. Each has its own id so the
       overview cards above scroll directly to it. Tiles are gradient
       placeholders for now; Phase 4 swaps to real photography via the
       Photo component.
       ---------------------------------------------------------------------- -->
  {categories.map((category) => (
    <!-- scroll-mt-l reserves space above the section for a fixed header
         if one is ever added later. -->
    <section class="scroll-mt-l py-2xl" id={category.id}>
      <div class="ncs-container">

        <header class="mb-l flex flex-col gap-s">
          <h2 class="text-primary">{category.title}</h2>
          <p class="max-w-[56ch] text-lg leading-[1.5] text-text-muted">{category.body}</p>
        </header>

        <ul class="grid gap-m [grid-template-columns:repeat(auto-fit,minmax(15rem,1fr))]">
          {Array.from({ length: category.tiles }).map((_, idx) => (
            <!-- Square placeholder. Even-index tiles flip the gradient
                 direction (via [&:nth-child(even)] arbitrary selector) so
                 the strip has internal rhythm without real imagery. -->
            <li
              class="aspect-square w-full rounded-md bg-gradient-to-br from-primary to-secondary [&:nth-child(even)]:bg-gradient-to-bl"
              aria-label={`${category.title} placeholder ${idx + 1}`}
            ></li>
          ))}
        </ul>

      </div>
    </section>
  ))}


  <CtaBanner
    title="Need photography for your project?"
    sub="Day-of coverage, headshots, environments. Often paired with web work, sometimes booked on its own."
  />

</BaseLayout>
