---
// Safe to edit. The story prose and the principles array hold all of the
// user-facing copy on this page.
/* ============================================================================
   /about | About Nathan Nixon
   ============================================================================
   Four blocks down the page:
     1. Hero (portrait placeholder + intro)
     2. Story (a few paragraphs on the why)
     3. How I work (three principle cards on the soft tinted band)
     4. Currently (short list of what's on the docket)

   Closes with the shared CtaBanner so every page funnels to /contact.
   ============================================================================ */

import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';

// Three working principles. Keep these honest; they should describe how
// I actually work, not how I wish I worked.
const principles = [
  {
    title: 'Strategy before pixels',
    body: 'Every project starts with a working session and a one-page brief we both agree on. Design choices follow from there, not from whichever template looks freshest.',
  },
  {
    title: 'Own the whole stack',
    body: 'Plain CSS, BEM naming, real fonts, real images. No subscription page builder layer between you and the site, so a future maintainer can read the code without learning a vendor.',
  },
  {
    title: 'Local, not nationwide',
    body: 'I work with organizations in the Cincinnati region so we can meet in person when it helps. Short distance, fast feedback, real relationships.',
  },
];

// Currently list. Short, present-tense, swappable per season.
const currently = [
  'Wrapping a small business site for a West Chester piano teacher.',
  'Photographing a Sunday morning shoot for a partner church in February.',
  'Booking one more nonprofit project for the spring cohort.',
];

// Section heading style shared by the three lower sections.
const sectionHeadingClass = 'flex flex-col gap-xs';
const sectionNumClass = 'font-mono text-sm tracking-[0.05em] text-text-muted';
const sectionInnerClass = 'flex flex-col gap-l';
---

<BaseLayout
  title="About | Nixon Creative Studio"
  description="About Nathan Nixon, sole owner of Nixon Creative Studio in West Chester, Ohio."
>

  <!-- ----------------------------------------------------------------------
       Hero: portrait + copy two-column at >= 56rem, stacked below that.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class="ncs-container grid grid-cols-1 items-center gap-xl min-[56rem]:grid-cols-[1fr_1.2fr]">

      <!-- Portrait placeholder. Same brand-gradient pattern as the
           homepage Hero. Swap for an Astro <Image /> once the real
           headshot is in src/assets/brand/. -->
      <div
        class="aspect-[4/5] w-full rounded-lg bg-gradient-to-br from-bg-soft to-secondary"
        role="img"
        aria-label="Portrait placeholder"
      ></div>

      <div class="flex flex-col gap-m">
        <p class="inline-flex items-baseline gap-s text-[0.95rem] text-text-muted">
          <span class="font-mono text-sm tracking-[0.05em]">A1</span>
          <span>About</span>
        </p>
        <h1 class="max-w-[22ch] leading-[0.95]">
          A one-person studio for organizations that take their work seriously.
        </h1>
        <p class="max-w-[60ch] text-lg leading-[1.6] text-text">
          I'm Nathan Nixon. I run Nixon Creative Studio out of West Chester, Ohio, and I work with small businesses, nonprofits, churches, and schools across the Cincinnati region. I do the strategy, the design, the photography, and the code, so the person you meet on day one is the same person who hands you the finished site.
        </p>
      </div>

    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Story: a few paragraphs of background. Keeps the page personal
       without turning into a full biography.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class={`ncs-container ${sectionInnerClass}`}>

      <header class={sectionHeadingClass}>
        <span class={sectionNumClass} aria-hidden="true">A2</span>
        <h2>The short version</h2>
      </header>

      <div class="flex max-w-[64ch] flex-col gap-m text-[1.0625rem] leading-[1.7] text-text">
        <p>
          I started Nixon Creative Studio after a decade of doing communications work for churches and schools, where the people building the website were always one volunteer or one budget cycle away from disappearing. The pattern was the same every time: the project ran on a page builder, the launch went well, and the maintenance fell apart within a year.
        </p>
        <p>
          The studio is my answer to that pattern. Modern code, plain HTML and CSS underneath, real component names a future maintainer can follow. The same person on every project so there's no agency handoff at the worst moment. Strategy first so the design is doing real work instead of just looking new.
        </p>
        <p>
          I live in West Chester with my family. When I'm not at a screen I'm usually behind a camera, on a basketball court, or pretending I know how to fix something at the house.
        </p>
      </div>

    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       How I work: three principle cards on the soft tinted band. Sits
       between the white Story and the white Currently sections.
       ---------------------------------------------------------------------- -->
  <section class="bg-bg-soft py-2xl">
    <div class={`ncs-container ${sectionInnerClass}`}>

      <header class={sectionHeadingClass}>
        <span class={sectionNumClass} aria-hidden="true">A3</span>
        <h2>How I work</h2>
      </header>

      <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(16rem,1fr))]">
        {principles.map((principle) => (
          <li class="flex flex-col gap-s">
            <!-- text-h4 utility for the principle title (smaller than the
                 default h3 so the card stays compact). -->
            <h3 class="text-h4 text-primary">{principle.title}</h3>
            <p class="leading-[1.6] text-text">{principle.body}</p>
          </li>
        ))}
      </ul>

    </div>
  </section>


  <!-- ----------------------------------------------------------------------
       Currently: short list of what's on the docket. Updated by hand a
       few times a year so visitors can tell the studio is an active
       practice, not a placeholder page.
       ---------------------------------------------------------------------- -->
  <section class="py-2xl">
    <div class={`ncs-container ${sectionInnerClass}`}>

      <header class={sectionHeadingClass}>
        <span class={sectionNumClass} aria-hidden="true">A4</span>
        <h2>Currently</h2>
      </header>

      <!-- list-disc restores real bullets that the globals.css base reset
           strips by default. This is a content list, not nav, so bullets
           are appropriate. -->
      <ul class="ml-5 max-w-[64ch] list-disc space-y-1 text-[1.0625rem] leading-[1.7] text-text">
        {currently.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

    </div>
  </section>


  <CtaBanner
    title="Want to talk about a project?"
    sub="I take on a small number of projects each quarter. The earlier we talk, the easier it is to schedule the work."
  />

</BaseLayout>
