---
/* ============================================================================
   Base Layout
   ============================================================================
   The shell every page renders inside. Owns the document <head>, the
   global stylesheet import, the Header, the Footer, and any sitewide
   bookkeeping like analytics and font preloads.

   Page-specific content goes in the <slot /> inside <main>.
   ============================================================================ */

import '../styles/globals.css';
// Starwind UI supplementary CSS. Imported AFTER globals.css so globals owns
// the :root / .dark semantic tokens and the @custom-variant dark rule, and
// this file only adds the accordion keyframes plus @theme inline mappings for
// the Starwind-only tokens (--outline and the status colors). See the file
// header in starwind.css for the split.
import '../styles/starwind.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import BackToTop from '../components/BackToTop';
import StructuredData from '../components/StructuredData.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { site } from '../data/site';

// Astro View Transitions. Wires same-origin link clicks into the browser's
// View Transitions API for a smooth fade between pages instead of a hard
// reload. Same-origin navigation only; external links work as normal.
import { ClientRouter } from 'astro:transitions';

// Resolve the Bebas Neue woff2 file through Vite's URL pipeline. The ?url
// query asks Vite to copy the file into the build output and hand us the
// hashed public path at build time. The same path appears in the global
// stylesheet (loaded by @fontsource/bebas-neue/400.css), so the preload
// link below points at the exact resource the browser will fetch.
//
// Why preload Bebas Neue specifically: it's the display font used by every
// h1/h2 on the site, including the hero headline. The hero headline is
// almost always the LCP (Largest Contentful Paint) element, so getting
// the font loaded as early as possible shortens LCP measurably.
//
// Source Sans 3 (body) is not preloaded on purpose. It's a variable font
// with multiple weights baked in; preloading it would cost more bandwidth
// than the LCP gain is worth.
import bebasNeueWoff2 from '@fontsource/bebas-neue/files/bebas-neue-latin-400-normal.woff2?url';

// Coming-soon gate. Implemented client-side so the owner can bypass
// per-device by visiting a magic URL, while everyone else lands on
// the ComingSoon view. See the gate <script> further down in <head>
// for the runtime logic.
//
// PUBLIC_COMING_SOON=true at build time:
//   - Every page ships with BOTH the real content (Header / Main /
//     Footer) AND the ComingSoon overlay div.
//   - A blocking inline <script> in <head> adds class="ncs-gated" to
//     <html> unless the visitor's localStorage carries the bypass
//     token (or the current URL contains ?preview=<TOKEN>).
//   - CSS in globals.css hides everything but .ncs-overlay when
//     html.ncs-gated is present, and hides .ncs-overlay otherwise.
//   - <meta name="robots" content="noindex"> ships so search engines
//     don't index the WIP content while gated.
//
// PUBLIC_COMING_SOON unset (or anything other than "true") at build time:
//   - No overlay, no gating script, no noindex. Normal site.
//
// PUBLIC_PREVIEW_TOKEN is the bypass secret. Visit any page with
// ?preview=<PUBLIC_PREVIEW_TOKEN> once and the script saves it to
// localStorage; from then on, that browser bypasses on every page.
//
// PUBLIC_ prefix on both: required because they're read at build
// time AND inlined into the client script. The token is technically
// visible in shipped HTML for anyone viewing source — soft gate, not
// security. For real auth, use Cloudflare Access at the DNS layer.
const comingSoonEnabled = import.meta.env.PUBLIC_COMING_SOON === 'true';
const previewToken      = import.meta.env.PUBLIC_PREVIEW_TOKEN || '';

interface Props {
  title:        string;
  description?: string;
  /** Open Graph image URL. Defaults to the site-wide OG image in
      public/. Pages with a richer hero (case studies) pass their own
      cover so social shares render the project's actual artwork. */
  ogImage?:     string;
  /** Override the default og:type. Case study detail pages set this to
      "article" so platforms that treat articles specially (search,
      readers) render them correctly. */
  ogType?:      'website' | 'article';
  /** Page-specific schema.org JSON-LD blocks. Layered on top of the
      site-wide Organization schema by StructuredData. Used by About
      (Person), case study detail pages (Article + CreativeWork),
      /services (Service + FAQPage). */
  schemas?:     Array<Record<string, unknown>>;
}
const {
  title,
  description = 'Nixon Creative Studio',
  ogImage,
  ogType      = 'website',
  schemas     = [],
} = Astro.props;

// Build a canonical URL for the current page so og:url and JSON-LD have
// the right absolute reference. Astro.url is the live request URL in
// dev and the resolved page URL at build time.
const canonical = new URL(Astro.url.pathname, site.url).toString();

// Per-page Open Graph card. Derived from the pathname to match the images
// generated by src/pages/og/[...route].ts ('' becomes 'index'), so every page
// gets its own branded card. An explicit ogImage prop still overrides, and
// any path without a generated card would 404 the image, so the known routes
// are kept in sync with STATIC_PAGES in that route file. The default OG
// (public/og-default.png) remains as a manual fallback if a prop passes it.
const ogSlug = Astro.url.pathname.replace(/^\/+|\/+$/g, '') || 'index';
const resolvedOgImage = ogImage ?? `/og/${ogSlug}.png`;
const ogImageUrl = new URL(resolvedOgImage, site.url).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical URL. Tells search engines the authoritative location
         for this page, even if it's reached through alternate query
         strings or aliased paths. -->
    <link rel="canonical" href={canonical} />

    {comingSoonEnabled && (
      <meta name="robots" content="noindex, follow" />
    )}

    {comingSoonEnabled && (
      <script is:inline define:vars={{ previewToken }}>
        (function () {
          try {
            var url   = new URL(window.location.href);
            var param = url.searchParams.get('preview');

            if (param && previewToken && param === previewToken) {
              localStorage.setItem('ncs-preview', param);
              url.searchParams.delete('preview');
              window.location.replace(url.toString());
              return;
            }

            var stored = localStorage.getItem('ncs-preview');
            if (stored && previewToken && stored === previewToken) {
              return;
            }
          } catch (e) {
            /* localStorage blocked: fall through to gating */
          }
          document.documentElement.classList.add('ncs-gated');
        })();
      </script>
    )}

    <!-- RSS auto-discovery. Lets feed readers (and browser extensions
         that detect feeds) pick up /rss.xml without manual entry. -->
    <link rel="alternate" type="application/rss+xml" title={`${site.studioName} — Case Studies`} href="/rss.xml" />

    <!-- Open Graph + Twitter card meta. Drives the rich preview that
         appears when the URL is shared on Slack, iMessage, LinkedIn, etc.
         Pages that pass an `ogImage` prop (typically case studies, using
         their cover) get a project-specific preview; everything else
         falls back to the site-wide default in public/og-default.png. -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:site_name"   content={site.studioName} />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <!--
      Anti-FOUC theme bootstrap. Runs synchronously before <body> paints so
      the .dark class lands on <html> in time for the first frame; otherwise
      a visitor who prefers dark would see a flash of light theme.

      Decision order:
        1. localStorage["ncs-theme"] (the visitor's explicit choice)
           - "dark" -> force dark
           - "light" -> force light
           - "system" (or missing) -> fall through
        2. window.matchMedia('(prefers-color-scheme: dark)') for system.

      ThemeToggle.tsx writes to the same localStorage key, and Astro's
      View Transitions ClientRouter preserves <html> attributes across
      same-origin navigations, so the class survives page changes.

      is:inline keeps this out of the Vite module graph so it's literally
      the first script the browser executes, with no async delay.
      data-astro-rerun lets View Transitions re-execute it on swap, which
      matters if the visitor changes their OS theme on a system-pref tab
      mid-session and then navigates.
    -->
    <script is:inline data-astro-rerun>
      (function () {
        // Mark that JS is running so CSS can scope the scroll-reveal hidden
        // state to .js only. Without JS the class is absent and [data-reveal]
        // content stays fully visible (see globals.css section 6).
        document.documentElement.classList.add('js');
        try {
          var stored = localStorage.getItem('ncs-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var isDark = stored === 'dark' || ((stored === 'system' || !stored) && prefersDark);
          var root = document.documentElement;
          root.classList.toggle('dark', isDark);
          root.style.colorScheme = isDark ? 'dark' : 'light';
        } catch (e) {
          /* localStorage blocked (private mode / cookies disabled). Fall back
             to system preference only. */
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', prefersDark);
          document.documentElement.style.colorScheme = prefersDark ? 'dark' : 'light';
        }
      })();
    </script>

    <!-- Bebas Neue preload. `crossorigin` is required for font preloads:
         without it, the preload and the eventual CSS font fetch are
         considered different requests, and the browser would download the
         font twice. With it, the second fetch hits the preload cache. -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={bebasNeueWoff2}
      crossorigin
    />

    <!-- Cloudflare Web Analytics. Component renders the beacon script
         only when PUBLIC_CF_ANALYTICS_TOKEN is set, so local dev and any
         deploy without the token simply emits nothing. -->
    <Analytics />

    <!-- Astro View Transitions. Renders in <head> so the client router
         is in place before the first navigation. -->
    <ClientRouter />

    <!-- schema.org JSON-LD. Always emits the studio's Organization /
         LocalBusiness blocks; pages can layer in per-page schemas
         (Article for case studies, Service for /services, etc.) via
         the schemas prop. -->
    <StructuredData extra={schemas} />
  </head>
  <body>

    <!--
      Hello, curious visitor. This site is hand-built by Nathan Nixon on Astro,
      Tailwind, and Cloudflare, no page builder and no template. How it is made:
      /colophon. Want one like it: /contact.
    -->

    <!--
      Skip link. Hidden off-screen until it receives focus (Tab from the
      address bar), then jumps into view at top-left. Lets keyboard and
      screen reader users bypass the header / nav and land directly on
      page content. The href targets the <main id="main"> below.
    -->
    <a
      href="#main"
      class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-2 focus-visible:left-2 focus-visible:z-50 focus-visible:rounded-md focus-visible:bg-primary focus-visible:px-3 focus-visible:py-2 focus-visible:font-body focus-visible:text-sm focus-visible:font-semibold focus-visible:text-primary-foreground focus-visible:no-underline focus-visible:ring-3 focus-visible:ring-accent/50"
    >
      Skip to main content
    </a>

    <Header />
    <main id="main" tabindex="-1"><slot /></main>
    <Footer />

    {/* Floating back-to-top affordance. client:idle defers hydration
        until after critical content; the button starts hidden and only
        fades in after the visitor scrolls past 600px, so the delay is
        invisible. */}
    <BackToTop client:idle />

    {comingSoonEnabled && (
      <div class="ncs-overlay" aria-label="Launching soon">
        <ComingSoon />
      </div>
    )}

    <!--
      Lenis smooth scroll initializer. The script is a normal client-side
      module (no is:inline) so Astro bundles it and hashes the URL. Lives
      at the end of body so Lenis has the document mounted before it
      attaches its scroll listeners.

      View Transitions reuse loaded modules across same-origin navigations,
      so the Lenis instance keeps running without re-initializing on every
      page change. The script itself honors prefers-reduced-motion and
      becomes a no-op when the user has reduced-motion set.
    -->
    <script>
      import '../scripts/lenis-init';
    </script>

    <!--
      Progressive enhancement layer. Wires the declarative data-* effects
      (magnetic CTAs, cursor spotlight, count-up numbers, scroll-aware header)
      on every page including View Transitions navigations. Everything it does
      is optional polish: the page is fully functional without it, and each
      effect self-disables under prefers-reduced-motion or coarse pointers.
    -->
    <script>
      import '../scripts/enhance';
    </script>

    <!--
      Scroll-reveal observer. Reveals every [data-reveal] element as it
      enters the viewport by toggling .is-visible (styled in globals.css
      section 6). Re-runs on every View Transitions navigation via the
      astro:page-load event, which fires on the initial load too, so the
      listener registered once here covers all pages.

      Accessibility: when the visitor prefers reduced motion (or the browser
      lacks IntersectionObserver), every tagged element is shown immediately,
      so nothing depends on motion to appear.
    -->
    <script>
      function initReveal() {
        const els = Array.from(document.querySelectorAll('[data-reveal]:not(.is-visible)'));
        if (!els.length) return;

        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
        );

        els.forEach((el) => io.observe(el));
      }

      document.addEventListener('astro:page-load', initReveal);
    </script>

    <!-- A quiet hello in the console for anyone who opens dev tools. Honest:
         the real stack, with pointers to the colophon and contact. -->
    <script is:inline>
      console.log('%cNixon Creative Studio', 'font: 600 16px ui-sans-serif, system-ui; color: #40AAED;');
      console.log('Hand-built on Astro, Tailwind, and Cloudflare. How it is made: /colophon  ·  Want one like it: /contact');
    </script>
  </body>
</html>
