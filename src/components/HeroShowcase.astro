---
// Safe to edit.
/* ============================================================================
   HeroShowcase  [device pairing]
   ============================================================================
   The portfolio scene in the homepage hero (at lg and up): a landscape DESKTOP
   browser and a PHONE, both showing the SAME client site, both auto-scrolling
   the real page, and crossfading to the NEXT site every 5 seconds. Showing one
   site on two screens at once reads as "I build sites that work on every
   device," and cycling the set shows the range of work (church, preschool,
   journal, race, shop, school).

   How it cycles (script below, gated to motion-OK):
     - One site is active at a time; both devices show that site's desktop +
       mobile full-page screenshot, each slowly panning down the page.
     - Every 5s the active site advances and the frames crossfade. The address
       bar in the desktop chrome updates to the new host.
     - The next site is preloaded one step ahead, so a crossfade never lands on
       a blank, and only the sites you have seen have been downloaded.
     - Hovering (fine pointer) pauses the cycle and the scroll so you can look;
       it also pauses while the browser tab is hidden.

   Performance: inactive screenshots are display:none until the script promotes
   them, so the browser only downloads the first site on load and then ~one site
   per cycle, instead of the whole set up front. Desktop shots reuse the
   full-page captures that drive the case-study SiteShowcase; the phone shots are
   real mobile captures at src/assets/case-studies/shots/{slug}-mobile.png.

   Reduced motion / no-JS: the first site stays shown on both devices as a still,
   honest two-device collage (no cycle, no scroll).

   Decorative by design: the whole cluster is aria-hidden and out of the tab
   order. The real navigation is the "See the work" CTA beside it and the
   Selected Work section below, so the /work link here is a mouse-only bonus, not
   an accessibility trap.

   To curate: edit the `sites` array. Each needs a `-home.png` (desktop, captured
   at 1440 wide, full page) and a `-mobile.png` (phone, captured ~390 wide, full
   page) in src/assets/case-studies/shots/. Recapture with Playwright if a client
   redesigns.
   ============================================================================ */

import { Image } from 'astro:assets';

// Desktop full-page captures (shared with the case-study SiteShowcase).
import dSecondPres from '../assets/case-studies/shots/second-presbyterian-chicago-home.png';
import dWcp from '../assets/case-studies/shots/west-chester-preschool-home.png';
import dTheology from '../assets/case-studies/shots/theology-matters-home.png';
import dStoneSteps from '../assets/case-studies/shots/stone-steps-50k-home.png';
import dMas from '../assets/case-studies/shots/mas-monograms-home.png';
import dAcademy from '../assets/case-studies/shots/presbyterian-academy-home.png';

// Phone full-page captures (real mobile renders of the same sites).
import mSecondPres from '../assets/case-studies/shots/second-presbyterian-chicago-mobile.png';
import mWcp from '../assets/case-studies/shots/west-chester-preschool-mobile.png';
import mTheology from '../assets/case-studies/shots/theology-matters-mobile.png';
import mStoneSteps from '../assets/case-studies/shots/stone-steps-50k-mobile.png';
import mMas from '../assets/case-studies/shots/mas-monograms-mobile.png';
import mAcademy from '../assets/case-studies/shots/presbyterian-academy-mobile.png';

// Curated set, ordered for variety. `host` is what the desktop address bar
// shows. Second Pres uses its real domain in the bar even though the screenshot
// was taken from the staging worker (the domain switch is pending).
const sites = [
  { host: 'secondpreschicago.org', desktop: dSecondPres, mobile: mSecondPres },
  { host: 'westchesterpreschool.org', desktop: dWcp, mobile: mWcp },
  { host: 'theologymatters.com', desktop: dTheology, mobile: mTheology },
  { host: 'stonesteps50k.com', desktop: dStoneSteps, mobile: mStoneSteps },
  { host: 'mas-monograms.com', desktop: dMas, mobile: mMas },
  { host: 'presbyterianacademy.org', desktop: dAcademy, mobile: mAcademy },
];
---

<a
  class="hero-stage"
  href="/work/"
  aria-hidden="true"
  tabindex="-1"
  data-hero-showcase
  data-count={sites.length}
>
  {/* ---- Desktop / laptop browser (landscape) ---- */}
  <div class="dev dev-desktop">
    <div class="dev-chrome">
      <span class="dev-dots">
        <span class="bg-[#ff5f57]"></span>
        <span class="bg-[#febc2e]"></span>
        <span class="bg-[#28c840]"></span>
      </span>
      <span class="dev-address" data-address>
        <svg class="dev-lock" viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <rect x="5" y="11" width="14" height="9" rx="2" /><path d="M8 11V7a4 4 0 0 1 8 0v4" />
        </svg>
        <span data-address-text>{sites[0].host}</span>
      </span>
    </div>
    <div class="dev-screen dev-screen-desktop">
      {sites.map((s, i) => (
        <div class:list={['shot', i === 0 && 'is-active is-loaded']} data-shot={i} data-host={s.host}>
          <Image
            src={s.desktop}
            alt=""
            widths={[600, 900, 1200, 1440]}
            sizes="(min-width: 64rem) 640px, 80vw"
            class="shot-img"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
    </div>
  </div>

  {/* ---- Phone (portrait), overlapping the desktop's lower-right ---- */}
  <div class="dev dev-phone">
    <div class="dev-screen dev-screen-phone">
      {sites.map((s, i) => (
        <div class:list={['shot', i === 0 && 'is-active is-loaded']} data-shot={i}>
          <Image
            src={s.mobile}
            alt=""
            widths={[280, 420, 545]}
            sizes="(min-width: 64rem) 270px, 40vw"
            class="shot-img"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
    </div>
  </div>

</a>

<style>
  /* The stage fills the hero scene (Hero.astro holds it to the content width,
     right-aligned) and clamps its height so it never overflows the 100svh hero
     on short laptops. The two devices are positioned against it. */
  .hero-stage {
    display: block;
    position: relative;
    width: 100%;
    height: clamp(24rem, 62vh, 42rem);
  }

  /* Soft brand spotlight behind the devices. It lifts the screens off the WebGL
     flow and fills the space with light, rather than a hard card (which would
     box in frames that already carry their own shadow). The radial falloff
     keeps it reading as a glow, not a shape; it sits behind both devices. */
  .hero-stage::before {
    content: '';
    position: absolute;
    inset: -16% -8% -12% -6%;
    z-index: 0;
    background:
      radial-gradient(60% 55% at 58% 38%, color-mix(in oklab, var(--color-secondary) 50%, transparent), transparent 70%),
      radial-gradient(56% 60% at 40% 78%, color-mix(in oklab, var(--color-accent) 40%, transparent), transparent 72%);
    pointer-events: none;
  }

  .dev {
    position: absolute;
  }

  /* Desktop: top-LEFT of the stage and the larger of the two, with the phone now
     riding its lower-right. Left-aligned so the phone can take the right edge
     (which lines up with the header nav) and the cluster stays inside the content
     width. Enlarged from 76% for more presence. */
  .dev-desktop {
    top: 0;
    left: 0;
    width: 95%;
    z-index: 2;
    border-radius: 0.6rem;
    overflow: hidden;
    background-color: color-mix(in oklab, var(--color-primary) 72%, #000);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-frame);
  }

  /* Phone: the front element, deliberately prominent. It now sits on the RIGHT,
     over the desktop's lower-right, with its right edge at the content edge
     (level with the header nav). Far from the headline on the left, so it never
     needs to dodge the copy. A deeper shadow lifts it in front. Enlarged from
     34% to stay a real focal point beside the bigger desktop. */
  .dev-phone {
    right: 0;
    bottom: 1%;
    width: 39%;
    z-index: 5;
    border-radius: 1.7rem;
    padding: 0.5rem;
    background: #0b0e14;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 50px 80px -32px rgba(0, 0, 0, 0.7);
  }
  /* Narrow desktops (small laptops, tablet landscape): the headline wraps wider
     and reaches further into the scene, so trim the cluster a touch (the desktop
     now sits on the left, nearest the headline) to keep it from crowding. */
  @media (max-width: 1279px) {
    .dev-desktop {
      width: 88%;
    }
    .dev-phone {
      width: 37%;
    }
  }
  /* Phone speaker/notch pill. */
  .dev-phone::before {
    content: '';
    position: absolute;
    top: 0.62rem;
    left: 50%;
    transform: translateX(-50%);
    width: 26%;
    height: 0.28rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.25);
    z-index: 2;
  }

  /* Browser chrome on the desktop frame: traffic-light dots + address bar. */
  .dev-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.06);
  }
  .dev-dots {
    display: inline-flex;
    gap: 0.3rem;
    flex: none;
  }
  .dev-dots span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
  }
  .dev-address {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-width: 0;
    padding: 0.12rem 0.6rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: rgba(255, 255, 255, 0.78);
  }
  .dev-lock {
    flex: none;
    opacity: 0.7;
  }
  .dev-address [data-address-text] {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  /* Screens: a fixed-aspect window with the (taller) page screenshot panning
     inside it. overflow hidden clips to the viewport. */
  .dev-screen {
    position: relative;
    overflow: hidden;
    background-color: color-mix(in oklab, var(--color-primary) 60%, #000);
  }
  .dev-screen-desktop {
    aspect-ratio: 16 / 10;
  }
  .dev-screen-phone {
    aspect-ratio: 9 / 19;
    border-radius: 1.1rem;
  }

  /* Each site's screenshot stacks absolutely. display:none until the script (or
     the SSR is-active on the first site) promotes it, so inactive shots are not
     downloaded. There is NO opacity fade: a crossfade always blends two
     different sites (a ghosty double-exposure), so the swap is a SLIDE instead.
     Every rendered shot is fully opaque; the active one sits on top and covers
     the screen, hiding the loaded-but-inactive ones stacked beneath it. The pan
     lives on the inner .shot-img and the slide on the .shot, so they never
     fight. */
  .shot {
    position: absolute;
    inset: 0;
    display: none;
    z-index: 1;
  }
  /* Loaded shots render (so the browser downloads them) but sit beneath the
     active one, which is opaque and covers the whole screen. */
  .shot.is-loaded,
  .shot.is-active,
  .shot.is-leaving {
    display: block;
  }
  /* Active site sits flat on top. The leaving one keeps the same level so it
     stays above the other loaded shots while the incoming slides over it. */
  .shot.is-active,
  .shot.is-leaving {
    z-index: 2;
  }
  /* Incoming site slides up from below to cover the outgoing one. Gated to
     motion-OK; with reduced motion the script does not cycle at all. */
  @media (prefers-reduced-motion: no-preference) {
    .shot.is-entering {
      z-index: 3;
      animation: hero-slide-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  }
  @keyframes hero-slide-in {
    from {
      transform: translateY(101%);
    }
    to {
      transform: translateY(0);
    }
  }
  .shot-img {
    display: block;
    width: 100%;
    height: auto;
    /* The image is taller than its screen; the pan animation slides it up. */
  }

  /* ---- Motion: the active page pans down, gated to motion-OK ------------- */
  @media (prefers-reduced-motion: no-preference) {
    /* Pan only once the slide-in has finished (is-entering removed), so the page
       does not scroll while it is still sliding into view. */
    .shot.is-active:not(.is-entering) .shot-img {
      animation: hero-pan 9s linear both;
    }
    /* Hover (or tab hidden) pauses the scroll and any in-flight slide. */
    .hero-stage.is-paused .shot.is-active:not(.is-entering) .shot-img,
    .hero-stage.is-paused .shot.is-entering {
      animation-play-state: paused;
    }
  }

  @keyframes hero-pan {
    from {
      transform: translateY(0);
    }
    to {
      /* Percentage is of the image's own height, so it scrolls a consistent
         share of each page regardless of how tall the capture is. */
      transform: translateY(-42%);
    }
  }

  /* Lift the cluster slightly on hover so it invites a look. */
  @media (hover: hover) and (pointer: fine) {
    .hero-stage {
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-stage:hover {
      transform: translateY(-4px);
    }
  }

  /* ======================================================================
     SHOWCASE LIGHTING VARIANTS. Set data-hero-variant="lightfall|window|
     radiance" on .hero-stage to try one; no attribute = the shipped base glow
     above. All three light the two devices like a photographic set: a
     screen-blended brand key on .hero-stage::before, a navy vignette + grounded
     contact floor on ::after (BOTH at z-index:0, behind the devices, so nothing
     dark ever sits over a screenshot), and key-biased rim/bloom + a deep drop
     shadow on each device frame (box-shadow draws outside the frame and is NOT
     clipped by its overflow:hidden). No panel/card behind the devices. For A/B
     comparison; the chosen one gets folded in as the default and this trimmed.
     ====================================================================== */

  /* ---- PRIMARY: "Spotlight Chiaroscuro" (data-hero-variant="lightfall") ----
     A hard key cone from the top-center-right, a four-corner navy vignette that
     crushes the surround, a contact floor dropped below the phone, and
     key-biased rim/bloom + deep drop on both frames. The brightest, most
     directional read. */
  .hero-stage[data-hero-variant='lightfall']::before {
    background:
      radial-gradient(24% 19% at 60% -8%,
        rgba(255, 255, 255, 0.88),
        color-mix(in oklab, var(--color-secondary) 70%, transparent) 44%,
        transparent 72%),
      radial-gradient(72% 80% at 61% -6%,
        color-mix(in oklab, var(--color-secondary) 82%, transparent),
        color-mix(in oklab, var(--color-accent) 52%, transparent) 46%,
        transparent 74%),
      conic-gradient(from 180deg at 61% -12%,
        transparent 0deg,
        transparent 150deg,
        color-mix(in oklab, var(--color-secondary) 44%, transparent) 168deg,
        color-mix(in oklab, var(--color-secondary) 28%, transparent) 192deg,
        transparent 210deg,
        transparent 360deg),
      radial-gradient(40% 34% at 26% 98%,
        color-mix(in oklab, var(--color-tertiary) 42%, transparent),
        transparent 70%);
    filter: blur(5px) saturate(1.18) brightness(1.05);
    mix-blend-mode: screen;
    opacity: 1;
  }
  .hero-stage[data-hero-variant='lightfall']::after {
    content: '';
    position: absolute;
    inset: -16% -8% -12% -6%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(34% 16% at 50% 103%,
        rgba(0, 0, 0, 0.80),
        rgba(0, 0, 0, 0.32) 46%,
        transparent 72%),
      radial-gradient(86% 96% at 60% 34%,
        transparent 58%,
        color-mix(in oklab, var(--color-primary) 72%, transparent) 78%,
        color-mix(in oklab, var(--color-primary) 97%, transparent) 90%,
        var(--color-primary) 100%);
    filter: blur(2px);
  }
  .hero-stage[data-hero-variant='lightfall'] .dev-desktop {
    box-shadow:
      0 -1px 0 0 rgba(255, 255, 255, 0.42),
      6px -8px 30px -6px color-mix(in oklab, var(--color-secondary) 78%, transparent),
      10px -22px 64px -12px color-mix(in oklab, var(--color-accent) 58%, transparent),
      0 8px 40px -6px color-mix(in oklab, var(--color-secondary) 26%, transparent),
      -14px 44px 72px -28px rgba(0, 0, 0, 0.82),
      -6px 18px 36px -22px rgba(0, 0, 0, 0.66);
  }
  .hero-stage[data-hero-variant='lightfall'] .dev-phone {
    box-shadow:
      0 -1px 0 0 rgba(255, 255, 255, 0.50),
      4px -6px 24px -4px color-mix(in oklab, var(--color-secondary) 88%, transparent),
      8px -16px 50px -10px color-mix(in oklab, var(--color-accent) 64%, transparent),
      -12px 16px 44px -12px color-mix(in oklab, var(--color-tertiary) 46%, transparent),
      -8px 56px 88px -30px rgba(0, 0, 0, 0.84),
      -4px 24px 46px -24px rgba(0, 0, 0, 0.70);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-stage[data-hero-variant='lightfall']::before {
      animation: LF-beam-breathe 8s ease-in-out infinite;
      will-change: opacity, filter;
    }
    @keyframes LF-beam-breathe {
      0%, 100% { opacity: 0.92; filter: blur(5px) saturate(1.12) brightness(1); }
      50%      { opacity: 1;    filter: blur(6px) saturate(1.22) brightness(1.10); }
    }
  }

  /* ---- ALTERNATE A: "Window Light" (data-hero-variant="window") ----
     Softer, daylight feel: an upper-left north-window key rakes the stage and
     throws long brand-tinted shadows down to the lower-right. Reads as a real
     daylight set rather than a stage spotlight. */
  .hero-stage[data-hero-variant='window']::before {
    background:
      radial-gradient(38% 32% at 42% 4%,
        rgba(255, 255, 255, 0.50), transparent 62%),
      radial-gradient(78% 70% at 38% -10%,
        color-mix(in oklab, var(--color-secondary) 76%, transparent),
        color-mix(in oklab, var(--color-secondary) 24%, transparent) 46%,
        transparent 66%),
      radial-gradient(72% 66% at 58% 16%,
        color-mix(in oklab, var(--color-accent) 60%, transparent), transparent 68%),
      radial-gradient(56% 46% at 74% 98%,
        color-mix(in oklab, var(--color-tertiary) 40%, transparent), transparent 72%);
    filter: saturate(1.16) brightness(1.05) blur(2px);
    mix-blend-mode: screen;
  }
  .hero-stage[data-hero-variant='window']::after {
    content: '';
    position: absolute;
    inset: -16% -8% -12% -6%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(56% 19% at 70% 100%,
        rgba(0, 0, 0, 0.68), transparent 74%),
      radial-gradient(30% 15% at 40% 103%,
        rgba(0, 0, 0, 0.55), transparent 76%),
      radial-gradient(130% 112% at 48% 28%,
        transparent 54%,
        color-mix(in oklab, var(--color-primary) 68%, transparent) 82%,
        color-mix(in oklab, var(--color-primary) 96%, transparent) 100%);
    filter: blur(13px);
  }
  .hero-stage[data-hero-variant='window'] .dev-desktop {
    box-shadow:
      -6px -6px 22px -6px color-mix(in oklab, #ffffff 50%, transparent),
      -1px -1px 1px 1px color-mix(in oklab, #ffffff 30%, transparent),
      -10px -12px 46px -10px color-mix(in oklab, var(--color-secondary) 60%, transparent),
      0 0 110px 16px color-mix(in oklab, var(--color-secondary) 22%, transparent),
      -14px -8px 56px -14px color-mix(in oklab, var(--color-accent) 48%, transparent),
      28px 46px 84px -32px rgba(0, 0, 0, 0.80);
  }
  .hero-stage[data-hero-variant='window'] .dev-phone {
    box-shadow:
      -6px -6px 20px -6px color-mix(in oklab, #ffffff 55%, transparent),
      -1.5px -1.5px 1px 1.5px color-mix(in oklab, #ffffff 38%, transparent),
      -12px -14px 48px -10px color-mix(in oklab, var(--color-secondary) 64%, transparent),
      0 0 100px 14px color-mix(in oklab, var(--color-secondary) 24%, transparent),
      14px 20px 56px -14px color-mix(in oklab, var(--color-tertiary) 40%, transparent),
      34px 60px 92px -30px rgba(0, 0, 0, 0.84);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-stage[data-hero-variant='window']::before {
      animation: LF-window-breathe 9s ease-in-out infinite alternate;
    }
    @keyframes LF-window-breathe { from { opacity: 0.9; } to { opacity: 1; } }
  }

  /* ---- ALTERNATE B: "Brand Radiance Pool" (data-hero-variant="radiance") ----
     The loudest: a saturated sky-to-accent glow pools right behind the devices
     with a hot near-white core, the frames carry a bright brand rim, and a
     heavy navy vignette crushes the surround. Pick if the others read too
     quiet. */
  .hero-stage[data-hero-variant='radiance']::before {
    background:
      radial-gradient(28% 24% at 62% 22%,
        rgba(255, 255, 255, 0.66),
        color-mix(in oklab, var(--color-secondary) 50%, transparent) 44%,
        transparent 66%),
      radial-gradient(58% 52% at 62% 34%,
        color-mix(in oklab, var(--color-secondary) 88%, transparent),
        color-mix(in oklab, var(--color-secondary) 40%, transparent) 46%,
        transparent 70%),
      radial-gradient(74% 70% at 58% 40%,
        color-mix(in oklab, var(--color-accent) 70%, transparent),
        color-mix(in oklab, var(--color-accent) 22%, transparent) 52%,
        transparent 78%),
      radial-gradient(46% 40% at 30% 98%,
        color-mix(in oklab, var(--color-tertiary) 46%, transparent), transparent 72%),
      radial-gradient(40% 36% at 88% 6%,
        color-mix(in oklab, var(--color-secondary) 40%, transparent), transparent 66%);
    filter: saturate(1.32) brightness(1.10) blur(2px);
    mix-blend-mode: screen;
    opacity: 1;
  }
  .hero-stage[data-hero-variant='radiance']::after {
    content: '';
    position: absolute;
    inset: -16% -8% -12% -6%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(36% 17% at 48% 103%,
        rgba(0, 0, 0, 0.62), transparent 72%),
      radial-gradient(84% 92% at 60% 38%,
        transparent 56%,
        color-mix(in oklab, var(--color-primary) 64%, transparent) 80%,
        color-mix(in oklab, var(--color-primary) 96%, transparent) 100%);
    filter: blur(4px);
  }
  .hero-stage[data-hero-variant='radiance'] .dev-desktop {
    box-shadow:
      0 -1px 0 0 rgba(255, 255, 255, 0.38),
      4px -6px 30px -4px color-mix(in oklab, var(--color-secondary) 82%, transparent),
      8px -10px 84px 4px color-mix(in oklab, var(--color-accent) 55%, transparent),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.20),
      -12px 44px 72px -28px rgba(0, 0, 0, 0.80);
  }
  .hero-stage[data-hero-variant='radiance'] .dev-phone {
    box-shadow:
      0 -1px 0 0 rgba(255, 255, 255, 0.46),
      3px -5px 24px -2px color-mix(in oklab, var(--color-secondary) 90%, transparent),
      6px -8px 66px 2px color-mix(in oklab, var(--color-accent) 62%, transparent),
      -10px 18px 42px -12px color-mix(in oklab, var(--color-tertiary) 34%, transparent),
      -8px 56px 88px -30px rgba(0, 0, 0, 0.84);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-stage[data-hero-variant='radiance']::before {
      animation: LF-radiance-breathe 9s ease-in-out infinite alternate;
    }
    @keyframes LF-radiance-breathe {
      from { filter: saturate(1.26) brightness(1.04) blur(2px); opacity: 0.9; }
      to   { filter: saturate(1.40) brightness(1.18) blur(2px); opacity: 1; }
    }
  }
</style>

<script>
  // Cycle the active site every 5s, sliding the next one in over both devices,
  // keep the address bar in sync, and preload one site ahead so a swap never
  // lands on a blank.
  // Runs on astro:page-load (survives View Transitions) with a bind guard;
  // disabled under reduced motion; pauses on hover and while the tab is hidden.
  function initHeroShowcase() {
    document
      .querySelectorAll<HTMLElement>('[data-hero-showcase]:not([data-showcase-bound])')
      .forEach((root) => {
        root.dataset.showcaseBound = 'true';

        // TEMPORARY A/B PREVIEW: ?hero=lightfall|window|radiance sets the
        // lighting variant on the stage so the treatments can be compared on the
        // deploy. No param = the shipped look. Remove once a direction is chosen.
        const variantParam = new URLSearchParams(location.search).get('hero');
        if (variantParam && ['lightfall', 'window', 'radiance'].includes(variantParam)) {
          root.dataset.heroVariant = variantParam;
        }

        // Reduced motion: leave the first site shown on both devices, static.
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const count = Number(root.dataset.count || '0');
        if (count < 2) return;

        const addr = root.querySelector<HTMLElement>('[data-address-text]');
        const shots = (i: number) =>
          Array.from(root.querySelectorAll<HTMLElement>(`[data-shot="${i}"]`));
        const hostOf = (i: number) =>
          root.querySelector<HTMLElement>(`[data-shot="${i}"][data-host]`)?.dataset.host ?? '';

        let cur = 0;
        const load = (i: number) => shots(i).forEach((e) => e.classList.add('is-loaded'));

        load((cur + 1) % count); // preload the next site during the first dwell

        let timer: ReturnType<typeof setInterval> | undefined;
        let cleanup: ReturnType<typeof setTimeout> | undefined;
        let paused = false;
        const SLIDE_MS = 620;

        const tick = () => {
          const next = (cur + 1) % count;
          const leaving = cur;

          // Outgoing: freeze its scroll exactly where it is (so it cannot snap
          // back to the top while it is still partly visible), and hold it
          // beneath as "leaving" until the incoming has covered it.
          shots(leaving).forEach((s) => {
            const img = s.querySelector<HTMLElement>('.shot-img');
            if (img) {
              const t = getComputedStyle(img).transform;
              img.style.animation = 'none';
              if (t && t !== 'none') img.style.transform = t;
            }
            s.classList.remove('is-active');
            s.classList.add('is-leaving');
          });

          // Incoming: slide up over the outgoing. It becomes active now, but its
          // pan is deferred until the slide finishes (the :not(.is-entering)
          // rule), so the page does not scroll while it is still sliding in.
          shots(next).forEach((s) => {
            s.classList.remove('is-leaving');
            s.classList.add('is-active', 'is-entering');
          });

          if (addr) addr.textContent = hostOf(next);
          load((next + 1) % count); // stay one ahead
          cur = next;

          clearTimeout(cleanup);
          cleanup = setTimeout(() => {
            // Retire the old site (now covered) and clear its frozen transform
            // so it is fresh next time it appears.
            shots(leaving).forEach((s) => {
              s.classList.remove('is-leaving');
              const img = s.querySelector<HTMLElement>('.shot-img');
              if (img) {
                img.style.animation = '';
                img.style.transform = '';
              }
            });
            // Let the new site start panning now that it has settled.
            shots(next).forEach((s) => s.classList.remove('is-entering'));
          }, SLIDE_MS);
        };
        const start = () => {
          if (!timer && !paused) timer = setInterval(tick, 5000);
        };
        const stop = () => {
          if (timer) {
            clearInterval(timer);
            timer = undefined;
          }
        };
        start();

        // Pause on hover (fine pointers only) so an explored shot holds still.
        if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
          root.addEventListener('pointerenter', () => {
            paused = true;
            root.classList.add('is-paused');
            stop();
          });
          root.addEventListener('pointerleave', () => {
            paused = false;
            root.classList.remove('is-paused');
            if (!document.hidden) start();
          });
        }

        document.addEventListener('visibilitychange', () =>
          document.hidden ? stop() : start(),
        );
      });
  }
  document.addEventListener('astro:page-load', initHeroShowcase);
</script>
