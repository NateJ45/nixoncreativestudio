---
// Safe to edit.
/* ============================================================================
   HeroShowcase
   ============================================================================
   A staggered cascade of three browser-chrome frames in the homepage hero,
   each crossfading real screenshots of shipped client sites with the live URL
   in its address bar. It puts a "wall of real work" above the fold (the "show,
   don't tell" instinct the brand is built on) and fills the right side of the
   hero next to the headline.

   How duplicates are impossible: the cover pool is PARTITIONED across the three
   frames (round-robin), so each frame owns a distinct, non-overlapping set of
   sites. Two frames can never show the same site, by construction, no matter
   where each is in its rotation.

   How blanks are impossible: every slide image is loading="eager". The pool is
   small (a handful of covers, deduped by Astro to one optimized asset each), so
   a frame can never crossfade to an image that hasn't loaded yet.

   How the rotation stays calm: one shared timer advances ONE frame per tick
   (round-robin), so only one frame ever crossfades at a time.

   Collection-driven: it reads the case-studies covers (real hero screenshots of
   the live sites) so it stays in sync as the portfolio grows. featured entries
   lead; the newest others fill in.

   Decorative by design: the whole cluster is aria-hidden and not interactive.
   The navigable work lives in the "See the work" CTA beside it and the Selected
   Work section below, so this auto-advancing visual never becomes an
   accessibility trap. The crossfade is disabled under prefers-reduced-motion
   (each frame holds its first, distinct shot) and pauses when the tab is hidden.
   ============================================================================ */

import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const studies = (await getCollection('case-studies')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);

// featured first, then newest others.
const ordered = [
  ...studies.filter((s) => s.data.featured),
  ...studies.filter((s) => !s.data.featured),
];

const host = (s: (typeof ordered)[number]) =>
  s.data.liveUrl ? new URL(s.data.liveUrl).host.replace(/^www\./, '') : s.data.client;

const FRAME_COUNT = 3;

// Pool of covers, capped at three per frame so the DOM stays light.
const pool = ordered.slice(0, FRAME_COUNT * 3).map((s) => ({ cover: s.data.cover, host: host(s) }));

// Partition the pool across the frames round-robin: frame 0 gets covers
// 0,3,6; frame 1 gets 1,4,7; frame 2 gets 2,5,8. Disjoint sets, so no two
// frames ever show the same site, and each frame opens on one of the top three.
const frames: { cover: (typeof pool)[number]['cover']; host: string }[][] = Array.from(
  { length: FRAME_COUNT },
  () => [],
);
pool.forEach((item, i) => frames[i % FRAME_COUNT].push(item));

// Only render frames that actually received a cover (needs pool.length >= 3).
const renderable = frames.filter((f) => f.length > 0);
---

{pool.length >= FRAME_COUNT && (
  <div class="hero-showcase" aria-hidden="true" data-hero-showcase>
    {renderable.map((covers, fi) => (
      <div class:list={['showcase-frame', `frame-${fi}`]} data-frame>
        {/* Browser chrome: traffic-light dots + an address bar whose text the
            crossfade script updates to the active site's host. */}
        <div class="frame-chrome">
          <span class="frame-dots">
            <span class="bg-[#ff5f57]"></span>
            <span class="bg-[#febc2e]"></span>
            <span class="bg-[#28c840]"></span>
          </span>
          <span class="frame-address" data-frame-address>{covers[0].host}</span>
        </div>

        {/* Crossfading viewport. Every cover stacks absolutely; the script
            fades between them. object-top so each shot reads from the top of
            the page. All eager so a crossfade never lands on a blank. */}
        <div class="frame-viewport">
          {covers.map((s, i) => (
            <div class="frame-slide" data-slide data-host={s.host} data-active={i === 0 ? 'true' : undefined}>
              <Image
                src={s.cover}
                alt=""
                widths={[400, 640, 900]}
                sizes="(min-width: 64rem) 40vw, 80vw"
                class="h-full w-full object-cover object-top"
                loading="eager"
              />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
)}

<style>
  /* The cascade lives in a height-clamped relative box so the three absolutely
     positioned frames have a definite height to resolve their % offsets
     against, and so the whole cluster shrinks on short laptops instead of
     overflowing the 100svh hero. */
  .hero-showcase {
    position: relative;
    width: 100%;
    height: clamp(22rem, 58vh, 40rem);
  }

  .showcase-frame {
    position: absolute;
    overflow: hidden;
    border-radius: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-frame);
    background-color: color-mix(in oklab, var(--color-primary) 70%, #000);
  }

  /* Diagonal cascade. Widths are generous and the offsets push the set to span
     the full column width (frame-1 reaches the right edge), so the cluster
     fills the horizontal space instead of clustering in the middle. Light
     vertical overlap gives depth without hiding much of each shot. */
  .frame-0 {
    top: 0;
    left: 0;
    width: 68%;
    z-index: 10;
    opacity: 0.9;
  }
  .frame-1 {
    top: 24%;
    right: 0;
    width: 74%;
    z-index: 20;
    opacity: 0.96;
  }
  .frame-2 {
    top: 47%;
    left: 6%;
    width: 70%;
    z-index: 30;
  }

  .frame-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.05);
  }
  .frame-dots {
    display: inline-flex;
    gap: 0.28rem;
  }
  .frame-dots span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
  }
  .frame-address {
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    white-space: nowrap;
    text-overflow: ellipsis;
    color: rgba(255, 255, 255, 0.72);
  }

  /* 16:9 viewport keeps the (wide) frames from getting too tall to cascade. */
  .frame-viewport {
    position: relative;
    aspect-ratio: 16 / 9;
  }
  .frame-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .frame-slide[data-active] {
    opacity: 1;
  }

  /* No transition under reduced motion; each frame simply holds its first,
     distinct shot, so the cluster is still a three-site collage. */
  @media (prefers-reduced-motion: reduce) {
    .frame-slide {
      transition: none;
    }
  }
</style>

<script>
  // Crossfade the cascade and keep each frame's address bar in sync. Runs on
  // astro:page-load (survives View Transitions) with a dataset bind guard;
  // disabled under reduced motion; pauses while the tab is hidden. Frames hold
  // disjoint cover sets (see the frontmatter), so there is no cross-frame
  // de-duplication to do here: each just advances through its own list.
  function initHeroShowcase() {
    document
      .querySelectorAll<HTMLElement>('[data-hero-showcase]:not([data-showcase-bound])')
      .forEach((root) => {
        root.dataset.showcaseBound = 'true';
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const frames = Array.from(root.querySelectorAll<HTMLElement>('[data-frame]')).map((frame) => ({
          slides: Array.from(frame.querySelectorAll<HTMLElement>('[data-slide]')),
          address: frame.querySelector<HTMLElement>('[data-frame-address]'),
          idx: 0,
        }));
        if (!frames.length) return;

        const advance = (f: (typeof frames)[number]) => {
          if (f.slides.length < 2) return;
          f.slides[f.idx].removeAttribute('data-active');
          f.idx = (f.idx + 1) % f.slides.length;
          f.slides[f.idx].setAttribute('data-active', 'true');
          if (f.address) f.address.textContent = f.slides[f.idx].dataset.host ?? '';
        };

        let tick = 0;
        let timer: ReturnType<typeof setInterval> | undefined;
        // One frame per tick, round-robin: only one crossfade happens at a time.
        const onTick = () => {
          advance(frames[tick % frames.length]);
          tick++;
        };
        const start = () => {
          if (!timer) timer = setInterval(onTick, 1600);
        };
        const stop = () => {
          if (timer) {
            clearInterval(timer);
            timer = undefined;
          }
        };
        start();
        document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));
      });
  }
  document.addEventListener('astro:page-load', initHeroShowcase);
</script>
