---
// Safe to edit.
/* ============================================================================
   HeroShowcase
   ============================================================================
   A staggered cascade of three browser-chrome frames in the homepage hero,
   each crossfading real screenshots of shipped client sites with the live URL
   in its address bar. It puts a "wall of real work" above the fold (the "show,
   don't tell" instinct the brand is built on) and fills the right side of the
   hero next to the headline.

   Motion is deliberately restrained (research on UI motion is consistent that
   peripheral motion steals attention from the headline if it is busy):
     - Slow cadence. One shared timer advances ONE frame per tick, so only one
       frame crossfades at a time, and the cadence is long (each frame is shown
       ~8s), so it reads ambient, not frantic.
     - Gentle Ken Burns. The active shot zooms very slightly over its dwell, so
       it feels alive without a hard motion.
     - Hover to explore. On a fine pointer, hovering a frame lifts it, pans its
       screenshot down to reveal more of the page, and PAUSES the rotation so
       you can take it in. The whole cluster links to /work so a click is never
       a dead end.
   All of the above is gated to (prefers-reduced-motion: no-preference); with
   reduced motion the cascade is a still three-site collage.

   Why duplicates and blanks are impossible: the cover pool is PARTITIONED
   across the three frames (round-robin), so each frame owns a distinct set and
   no two can show the same site; every slide image is loading="eager", so a
   crossfade never lands on an unloaded image. Wider `widths` keep the frames
   crisp on retina screens.

   Decorative by design: the cluster is aria-hidden and out of the tab order
   (the real navigation is the "See the work" CTA beside it and the Selected
   Work section below), so the /work link is a mouse-only bonus, not an
   accessibility trap.
   ============================================================================ */

import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const studies = (await getCollection('case-studies')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);

// featured first, then newest others.
const ordered = [
  ...studies.filter((s) => s.data.featured),
  ...studies.filter((s) => !s.data.featured),
];

const host = (s: (typeof ordered)[number]) =>
  s.data.liveUrl ? new URL(s.data.liveUrl).host.replace(/^www\./, '') : s.data.client;

const FRAME_COUNT = 3;

// Pool of covers, capped at three per frame so the DOM stays light.
const pool = ordered.slice(0, FRAME_COUNT * 3).map((s) => ({ cover: s.data.cover, host: host(s) }));

// Partition the pool across the frames round-robin: frame 0 gets covers
// 0,3,6; frame 1 gets 1,4,7; frame 2 gets 2,5,8. Disjoint sets, so no two
// frames ever show the same site, and each frame opens on one of the top three.
const frames: { cover: (typeof pool)[number]['cover']; host: string }[][] = Array.from(
  { length: FRAME_COUNT },
  () => [],
);
pool.forEach((item, i) => frames[i % FRAME_COUNT].push(item));

// Only render frames that actually received a cover (needs pool.length >= 3).
const renderable = frames.filter((f) => f.length > 0);
---

{pool.length >= FRAME_COUNT && (
  <a class="hero-showcase" href="/work/" aria-hidden="true" tabindex="-1" data-hero-showcase>
    {renderable.map((covers, fi) => (
      <div class:list={['showcase-frame', `frame-${fi}`]} data-frame>
        {/* Browser chrome: traffic-light dots + an address bar whose text the
            crossfade script updates to the active site's host. */}
        <div class="frame-chrome">
          <span class="frame-dots">
            <span class="bg-[#ff5f57]"></span>
            <span class="bg-[#febc2e]"></span>
            <span class="bg-[#28c840]"></span>
          </span>
          <span class="frame-address" data-frame-address>{covers[0].host}</span>
        </div>

        {/* Crossfading viewport. Every cover stacks absolutely; the script
            fades between them. All eager so a crossfade never lands on a blank.
            wider `widths` so the frames stay crisp on retina screens. */}
        <div class="frame-viewport">
          {covers.map((s, i) => (
            <div class="frame-slide" data-slide data-host={s.host} data-active={i === 0 ? 'true' : undefined}>
              <Image
                src={s.cover}
                alt=""
                widths={[480, 760, 1100]}
                sizes="(min-width: 64rem) 34vw, 80vw"
                class="frame-img h-full w-full"
                loading="eager"
              />
            </div>
          ))}
        </div>
      </div>
    ))}
  </a>
)}

<style>
  /* A clickable, height-clamped relative box. The three absolutely positioned
     frames resolve their % offsets against this height, and it shrinks on short
     laptops instead of overflowing the 100svh hero. */
  .hero-showcase {
    display: block;
    position: relative;
    width: 100%;
    height: clamp(22rem, 58vh, 40rem);
  }

  .showcase-frame {
    position: absolute;
    overflow: hidden;
    border-radius: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-frame);
    background-color: color-mix(in oklab, var(--color-primary) 70%, #000);
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s ease,
      opacity 0.4s ease;
  }

  /* Diagonal cascade. Widths are generous and the offsets push the set to span
     the full column width (frame-1 reaches the right edge), so the cluster
     fills the horizontal space. Light vertical overlap gives depth. */
  .frame-0 {
    top: 0;
    left: 0;
    width: 68%;
    z-index: 10;
    opacity: 0.9;
  }
  .frame-1 {
    top: 24%;
    right: 0;
    width: 74%;
    z-index: 20;
    opacity: 0.96;
  }
  .frame-2 {
    top: 47%;
    left: 6%;
    width: 70%;
    z-index: 30;
  }

  .frame-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.05);
  }
  .frame-dots {
    display: inline-flex;
    gap: 0.28rem;
  }
  .frame-dots span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
  }
  .frame-address {
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    white-space: nowrap;
    text-overflow: ellipsis;
    color: rgba(255, 255, 255, 0.72);
  }

  /* 16:9 viewport keeps the (wide) frames from getting too tall to cascade. */
  .frame-viewport {
    position: relative;
    aspect-ratio: 16 / 9;
  }
  .frame-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  .frame-slide[data-active] {
    opacity: 1;
  }
  .frame-img {
    object-fit: cover;
    /* Shows the top of each page by default; hover pans this toward the
       bottom (see below) to reveal more of the site. */
    object-position: 50% 0%;
  }

  /* ---- Motion layer, all gated to motion-OK ----------------------------- */
  @media (prefers-reduced-motion: no-preference) {
    /* Gentle Ken Burns on whichever slide is active: a slow, slight zoom over
       roughly the dwell time so the visible shot feels alive, not static. */
    .frame-slide[data-active] .frame-img {
      animation: hero-kenburns 9s ease-out both;
    }
  }

  /* ---- Hover to explore (fine pointers only) ---------------------------- */
  @media (prefers-reduced-motion: no-preference) and (hover: hover) and (pointer: fine) {
    .frame-img {
      transition: object-position 3.5s ease;
    }
    /* Lift the hovered frame forward; gently dim the others so it reads as
       "examine this one." */
    .hero-showcase:hover .showcase-frame {
      opacity: 0.72;
    }
    .showcase-frame:hover {
      transform: translateY(-6px);
      z-index: 40;
      opacity: 1;
      box-shadow: 0 40px 70px -30px rgba(0, 0, 0, 0.6);
    }
    /* Pan the hovered frame's shot down to reveal more of the page. */
    .showcase-frame:hover .frame-slide[data-active] .frame-img {
      object-position: 50% 100%;
    }
  }

  @keyframes hero-kenburns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.06);
    }
  }
</style>

<script>
  // Crossfade the cascade, keep each frame's address bar in sync, and pause on
  // hover so an explored shot does not swap mid-look. Runs on astro:page-load
  // (survives View Transitions) with a dataset bind guard; disabled under
  // reduced motion; pauses while the tab is hidden. Frames hold disjoint cover
  // sets (see the frontmatter), so each just advances through its own list.
  function initHeroShowcase() {
    document
      .querySelectorAll<HTMLElement>('[data-hero-showcase]:not([data-showcase-bound])')
      .forEach((root) => {
        root.dataset.showcaseBound = 'true';
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const frames = Array.from(root.querySelectorAll<HTMLElement>('[data-frame]')).map((frame) => ({
          slides: Array.from(frame.querySelectorAll<HTMLElement>('[data-slide]')),
          address: frame.querySelector<HTMLElement>('[data-frame-address]'),
          idx: 0,
        }));
        if (!frames.length) return;

        const advance = (f: (typeof frames)[number]) => {
          if (f.slides.length < 2) return;
          f.slides[f.idx].removeAttribute('data-active');
          f.idx = (f.idx + 1) % f.slides.length;
          f.slides[f.idx].setAttribute('data-active', 'true');
          if (f.address) f.address.textContent = f.slides[f.idx].dataset.host ?? '';
        };

        let tick = 0;
        let timer: ReturnType<typeof setInterval> | undefined;
        let paused = false; // set true while a pointer is hovering the cluster
        // One frame per tick, round-robin, on a slow cadence: only one crossfade
        // at a time and each frame changes roughly every FRAME_COUNT * interval.
        const onTick = () => {
          advance(frames[tick % frames.length]);
          tick++;
        };
        const start = () => {
          if (!timer && !paused) timer = setInterval(onTick, 2800);
        };
        const stop = () => {
          if (timer) {
            clearInterval(timer);
            timer = undefined;
          }
        };
        start();

        // Pause the rotation while a fine pointer hovers, so the shot you are
        // exploring holds still. Touch devices have no hover, so this is gated.
        if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
          root.addEventListener('pointerenter', () => {
            paused = true;
            stop();
          });
          root.addEventListener('pointerleave', () => {
            paused = false;
            if (!document.hidden) start();
          });
        }

        document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));
      });
  }
  document.addEventListener('astro:page-load', initHeroShowcase);
</script>
