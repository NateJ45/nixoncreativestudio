---
// Safe to edit. Replace the placeholder names and quotes with real
// attributed testimonials as they come in.
/* ============================================================================
   Section 06 | Testimonials
   ============================================================================
   Three quote cards. Each card has a pull-quote, attribution name, and a
   small role + organization line.

   Visual treatment keeps the quote primary and the attribution small so
   the reader's eye lands on the words first. Border-left in the accent
   blue acts as a quotation marker without dropping a literal mark.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

// Placeholder quotes. Replace with real testimonials as they come in.
const quotes = [
  {
    quote: 'Nathan listened first and built second. The site launched on time and the form started filling up the same week.',
    name: 'Placeholder Name',
    role: 'Communications Director, Crestview Presbyterian',
  },
  {
    quote: 'For the first time our parents can find tour signup, tuition, and the calendar without calling the office. That alone paid for the project.',
    name: 'Placeholder Name',
    role: 'Director, Oakwood Preschool',
  },
  {
    quote: 'The photos and the website match because the same person made both. That sounds small until you see what we had before.',
    name: 'Placeholder Name',
    role: 'Executive Director, Cincy Table',
  },
];
---

<section class="py-2xl" aria-labelledby="testimonials-heading">
  <div class="ncs-container">

    <SectionHeading
      num="06"
      title="What people say"
      sub="A few words from the people I have worked with recently."
      headingId="testimonials-heading"
    />

    <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(18rem,1fr))]">
      {quotes.map((entry) => (
        <li>
          <!-- figure + blockquote + figcaption is the most accurate semantic
               pairing for a quote with attribution. -->
          <figure class="m-0 flex h-full flex-col gap-m rounded-r-lg border-l-4 border-accent bg-bg-soft p-l">
            <blockquote class="m-0 text-text">
              <p class="text-lg italic leading-[1.55]">{entry.quote}</p>
            </blockquote>
            <!-- mt-auto pushes attribution to the bottom on taller cards
                 so the names line up across the row when quotes differ
                 in length. -->
            <figcaption class="mt-auto flex flex-col gap-[2px]">
              <span class="font-semibold text-heading">{entry.name}</span>
              <span class="text-[0.9rem] text-text-muted">{entry.role}</span>
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>

  </div>
</section>
