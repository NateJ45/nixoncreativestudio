---
// Safe to edit.
/* ============================================================================
   BeforeAfter  [revamp]
   ============================================================================
   A draggable before/after image comparison slider. Drag the handle (or use
   the arrow keys on the focused slider) to wipe between the old site and the
   new one. A strong portfolio device for redesigns.

   IMPORTANT on sourcing the "before" image: the Wayback Machine is NOT a
   reliable source for these. Archived Wix / Squarespace / WordPress pages
   usually render broken (missing CSS and assets), which misrepresents the
   prior site. Use a real screenshot you captured when you started the
   project. Until you have one, leave this component out of the case study.

   Usage inside a case study .mdx (imports go right under the frontmatter):

     import BeforeAfter from '../../components/BeforeAfter.astro';
     import before from '../../assets/case-studies/shots/<slug>-before.png';
     import after  from '../../assets/case-studies/shots/<slug>-home.png';

     <BeforeAfter
       before={before}
       after={after}
       beforeAlt="The previous <Client> site"
       afterAlt="The redesigned <Client> site"
     />

   Accessibility: the control is a native range input (keyboard operable,
   labelled). No auto-motion, so there is nothing to gate for reduced motion.
   ============================================================================ */

import { Image } from 'astro:assets';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt: string;
  afterAlt: string;
  beforeLabel?: string;
  afterLabel?: string;
}

const {
  before,
  after,
  beforeAlt,
  afterAlt,
  beforeLabel = 'Before',
  afterLabel = 'After',
} = Astro.props;
---

<figure class="my-l">
  <div
    class="ba relative select-none overflow-hidden rounded-xl border border-border shadow-[0_30px_70px_-42px_rgba(10,22,40,0.6)]"
    data-beforeafter
    style="--pos: 50%;"
  >
    <!-- Base layer: the "before" image fills the frame. -->
    <Image src={before} alt={beforeAlt} widths={[600, 900, 1200]} sizes="(min-width: 56rem) 70vw, 100vw" class="block h-auto w-full" />

    <!-- Top layer: the "after" image, clipped from the left edge to --pos. -->
    <div class="ba-after pointer-events-none absolute inset-0" aria-hidden="true">
      <Image src={after} alt="" widths={[600, 900, 1200]} sizes="(min-width: 56rem) 70vw, 100vw" class="block h-auto w-full" />
    </div>

    <!-- Corner labels. -->
    <span class="pointer-events-none absolute left-3 top-3 rounded-full bg-primary/80 px-2.5 py-1 font-mono text-[0.7rem] uppercase tracking-[0.08em] text-primary-foreground">{afterLabel}</span>
    <span class="pointer-events-none absolute right-3 top-3 rounded-full bg-bg/85 px-2.5 py-1 font-mono text-[0.7rem] uppercase tracking-[0.08em] text-text">{beforeLabel}</span>

    <!-- Divider line + handle, positioned at --pos. -->
    <div class="ba-divider pointer-events-none absolute inset-y-0" style="left: var(--pos);" aria-hidden="true">
      <span class="absolute inset-y-0 -ml-px w-0.5 bg-white/90"></span>
      <span class="absolute top-1/2 -ml-4 -mt-4 flex h-8 w-8 -translate-y-0 items-center justify-center rounded-full border border-border bg-bg text-text shadow-md">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /><path d="m9 6 6 6-6 6" /></svg>
      </span>
    </div>

    <!-- The actual control: a full-bleed range input. Visually hidden but
         keyboard operable and pointer-draggable; the script maps it to --pos. -->
    <input
      class="ba-range absolute inset-0 h-full w-full cursor-ew-resize opacity-0"
      type="range"
      min="0"
      max="100"
      value="50"
      aria-label={`Drag to compare the ${beforeLabel.toLowerCase()} and ${afterLabel.toLowerCase()} versions`}
    />
  </div>
  <figcaption class="mt-xs text-center font-mono text-[0.75rem] text-text-muted">
    Drag to compare {beforeLabel.toLowerCase()} and {afterLabel.toLowerCase()}.
  </figcaption>
</figure>

<style>
  /* Clip the "after" layer from the left edge to the slider position. */
  .ba-after {
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }
</style>

<script>
  // Wire every before/after slider: the range input writes its value to the
  // container's --pos custom property, which both clips the "after" image and
  // positions the divider. Runs on astro:page-load so it survives View
  // Transitions; a dataset guard prevents double-binding.
  function initBeforeAfter() {
    document.querySelectorAll<HTMLElement>('[data-beforeafter]:not([data-ba-bound])').forEach((el) => {
      el.dataset.baBound = 'true';
      const range = el.querySelector<HTMLInputElement>('.ba-range');
      if (!range) return;
      const update = () => el.style.setProperty('--pos', `${range.value}%`);
      range.addEventListener('input', update);
      update();
    });
  }
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
