---
// Safe to edit.
/* ============================================================================
   BeforeAfter  [revamp]
   ============================================================================
   A draggable before/after image comparison slider. Follows the standard
   convention so it reads left-to-right as a progression: the BEFORE (previous
   site) is on the LEFT, the AFTER (redesign) is on the RIGHT. Drag the handle
   (or arrow-key the focused slider) to wipe between them. The labels are
   color-coded for clarity: Before is a neutral pill, After is a brand-accent
   pill (the new one).

   IMPORTANT on sourcing the "before" image: the Wayback Machine is NOT a
   reliable source for these. Archived Wix / Squarespace / WordPress pages
   usually render broken (missing CSS and assets), which misrepresents the
   prior site. Use a real screenshot you captured when you started the
   project. For best results the before and after images should share the same
   aspect ratio (both hero/viewport crops, e.g. 1440x1080) so the wipe lines up.

   Usage inside a case study .mdx (imports go right under the frontmatter):

     import BeforeAfter from '../../components/BeforeAfter.astro';
     import before from '../../assets/case-studies/shots/<slug>-before.png';
     import after  from '../../assets/case-studies/<slug>.png';

     <BeforeAfter
       before={before}
       after={after}
       beforeAlt="The previous <Client> site"
       afterAlt="The redesigned <Client> site"
     />

   Accessibility: the control is a native range input (keyboard operable,
   labelled). No auto-motion, so there is nothing to gate for reduced motion.
   ============================================================================ */

import { Image } from 'astro:assets';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt: string;
  afterAlt: string;
  beforeLabel?: string;
  afterLabel?: string;
}

const {
  before,
  after,
  beforeAlt,
  afterAlt,
  beforeLabel = 'Before',
  afterLabel = 'After',
} = Astro.props;
---

<figure class="my-l">
  <div
    class="ba relative select-none overflow-hidden rounded-xl border border-border shadow-[var(--shadow-frame)]"
    data-beforeafter
    style="--pos: 50%;"
  >
    <!-- Base layer: the AFTER (redesigned) image fills the frame. It shows on
         the RIGHT, wherever the clipped BEFORE layer doesn't cover it. -->
    <Image src={after} alt={afterAlt} widths={[768, 1024, 1440]} sizes="(min-width: 56rem) 70vw, 100vw" class="block h-auto w-full" />

    <!-- Top layer: the BEFORE (previous) image, clipped from the left edge to
         --pos so it occupies the LEFT side. -->
    <div class="ba-before pointer-events-none absolute inset-0" aria-hidden="true">
      <Image src={before} alt="" widths={[768, 1024, 1440]} sizes="(min-width: 56rem) 70vw, 100vw" class="block h-auto w-full" />
    </div>

    <!-- Corner labels, color-coded. Before (left) is a neutral pill; After
         (right) is the brand-accent pill, marking it as the new site. -->
    <span class="pointer-events-none absolute left-3 top-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-primary/85 px-3 py-1 font-mono text-xs font-semibold uppercase tracking-[0.08em] text-primary-foreground shadow-sm backdrop-blur-sm">
      <span aria-hidden="true">←</span>{beforeLabel}
    </span>
    <span class="pointer-events-none absolute right-3 top-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-accent px-3 py-1 font-mono text-xs font-semibold uppercase tracking-[0.08em] text-accent-foreground shadow-sm">
      {afterLabel}<span aria-hidden="true">→</span>
    </span>

    <!-- Divider line + handle, positioned at --pos. -->
    <div class="ba-divider pointer-events-none absolute inset-y-0 z-10" style="left: var(--pos);" aria-hidden="true">
      <span class="absolute inset-y-0 -ml-px w-0.5 bg-white/90"></span>
      <span class="absolute top-1/2 -ml-4 -mt-4 flex h-8 w-8 items-center justify-center rounded-full border border-border bg-bg text-text shadow-md">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /><path d="m9 6 6 6-6 6" /></svg>
      </span>
    </div>

    <!-- The actual control: a full-bleed range input. Visually hidden but
         keyboard operable and pointer-draggable; the script maps it to --pos. -->
    <input
      class="ba-range absolute inset-0 z-20 h-full w-full cursor-ew-resize opacity-0"
      type="range"
      min="0"
      max="100"
      value="50"
      aria-label={`Comparison slider: drag to reveal the previous site on the left and the redesigned site on the right`}
    />
  </div>
  <figcaption class="mt-xs text-center font-mono text-[0.75rem] text-text-muted">
    Drag the handle: the previous site is on the left, the redesign on the right.
  </figcaption>
</figure>

<style>
  /* Clip the BEFORE layer from the left edge to the slider position, so the
     left side shows "before" and the right side shows the base "after". */
  .ba-before {
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }
</style>

<script>
  // Wire every before/after slider: the range input writes its value to the
  // container's --pos custom property, which both clips the BEFORE image and
  // positions the divider. Runs on astro:page-load so it survives View
  // Transitions; a dataset guard prevents double-binding.
  function initBeforeAfter() {
    document.querySelectorAll<HTMLElement>('[data-beforeafter]:not([data-ba-bound])').forEach((el) => {
      el.dataset.baBound = 'true';
      const range = el.querySelector<HTMLInputElement>('.ba-range');
      if (!range) return;
      const update = () => el.style.setProperty('--pos', `${range.value}%`);
      range.addEventListener('input', update);
      update();
    });
  }
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
