---
// Foundation, edit with care. This block sets the visual rhythm for every
// section heading on the homepage and on inner pages that use the same pattern.
/* ============================================================================
   Section Heading
   ============================================================================
   Reusable heading block. Keeps the numbered visual map (01 through 08)
   consistent across the homepage and any inner page that imports it: a
   small mono number, a display-font title, and an optional muted sub
   paragraph for context.

   Sections 02 through 08 on the homepage import this. The Hero builds
   its own heading because it has a different treatment (overline +
   statement headline).

   Usage:
     <SectionHeading num="02" title="Selected work" />
     <SectionHeading num="03" title="What I do" sub="Strategy, design, photography." />
   ============================================================================ */

interface Props {
  num: string;          // Two-digit section number, e.g. "02". Quoted so the leading zero stays.
  title: string;        // The section's display title.
  sub?: string;         // Optional supporting sentence beneath the title.
  headingId?: string;   // Optional id rendered on the <h2>. Pair with the parent
                        // section's aria-labelledby so the heading actually labels
                        // the landmark. Without this, aria-labelledby references on
                        // the parent point at nothing.
}

const { num, title, sub, headingId } = Astro.props;
---

<!--
  Using <header> as the wrapper so screen readers and search engines see a
  clear section landmark, not just a styled row.
-->
<header class="flex flex-col gap-xs mb-l">

  <!-- Mono section number. aria-hidden so screen readers don't announce
       the digits separately from the heading they label. -->
  <span class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">
    {num}
  </span>

  <!-- Section title. Inherits size from the global h2 rule, no overrides.
       The id (when provided) is the anchor for the parent section's
       aria-labelledby. -->
  <h2 id={headingId}>{title}</h2>

  <!-- Optional supporting line. Rendered only when provided so empty space
       doesn't pile up under sections that don't need a sub. -->
  {sub && (
    <p class="max-w-[48ch] text-lg leading-[1.5] text-text-muted">{sub}</p>
  )}

</header>
