---
// Foundation, edit with care. This block sets the visual rhythm for inner-page
// section headings that still benefit from a numbered marker (currently /work
// and the Process steps on /services). The homepage no longer uses it; the
// three-act rewrite dropped the eyebrow-grammar numbering across the
// non-sequential sections.
/* ============================================================================
   Section Heading
   ============================================================================
   Reusable heading block: optional mono section number, a display-font
   title, and an optional muted sub paragraph for context.

   The num prop is optional on purpose. Pass it only when the section is
   genuinely a numbered sequence (an ordered list of steps, a chapter
   index). Skip it for stand-alone sections where a number would be
   eyebrow decoration rather than information.

   Usage:
     <SectionHeading title="Selected work" />
     <SectionHeading title="How we work" sub="Four steps, in order." />
     <SectionHeading num="03" title="Strategy" />   // when num is real IA
   ============================================================================ */

interface Props {
  num?: string;         // Optional two-digit number, e.g. "02". Quoted so the leading zero stays.
  title: string;        // The section's display title.
  sub?: string;         // Optional supporting sentence beneath the title.
  headingId?: string;   // Optional id rendered on the <h2>. Pair with the parent
                        // section's aria-labelledby so the heading actually labels
                        // the landmark. Without this, aria-labelledby references on
                        // the parent point at nothing.
}

const { num, title, sub, headingId } = Astro.props;
---

<!--
  Using <header> as the wrapper so screen readers and search engines see a
  clear section landmark, not just a styled row.
-->
<header class="flex flex-col gap-xs mb-l">

  <!-- Mono section number. Rendered only when num is provided. aria-hidden
       so screen readers don't announce the digits separately from the
       heading they label. -->
  {num && (
    <span class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">
      {num}
    </span>
  )}

  <!-- Section title. Inherits size from the global h2 rule, no overrides.
       The id (when provided) is the anchor for the parent section's
       aria-labelledby. -->
  <h2 id={headingId}>{title}</h2>

  <!-- Optional supporting line. Rendered only when provided so empty space
       doesn't pile up under sections that don't need a sub. -->
  {sub && (
    <p class="max-w-[48ch] text-lg leading-[1.5] text-text-muted">{sub}</p>
  )}

</header>
