---
/* ============================================================================
   Section 07 | CTA Banner
   ============================================================================
   Full-bleed call-to-action band that sits right above the footer on the
   homepage and at the end of every inner page. One sentence prompting the
   visitor toward the contact page, plus a primary button.

   Reusable: the props default to homepage copy but every other page can
   pass its own title and subtitle to tune the message for the context.

   BEM:
     cta-banner            Outer banner block (full-bleed background).
     cta-banner__inner     Content column, constrained by .ncs-container.
     cta-banner__title     Headline.
     cta-banner__sub       Supporting line.
     cta-banner__action    Primary button.
   ============================================================================ */

interface Props {
  title?: string;
  sub?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title = 'Have a project in mind?',
  sub = 'I take a small number of projects each quarter. The earlier we talk, the better we can pace it together.',
  ctaLabel = 'Start a project',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="cta-banner" aria-labelledby="cta-banner-title">
  <div class="ncs-container cta-banner__inner">

    <div class="cta-banner__copy">
      <h2 id="cta-banner-title" class="cta-banner__title">{title}</h2>
      <p class="cta-banner__sub">{sub}</p>
    </div>

    <a class="cta-banner__action" href={ctaHref}>{ctaLabel}</a>

  </div>
</section>


<style>
  /* --------------------------------------------------------------------------
     Outer banner. Dark navy background mirrors the footer below it, so the
     two heavy sections at the bottom of the page feel like one block. Light
     text on dark surface; accent button.
     -------------------------------------------------------------------------- */
  .cta-banner {
    background-color: var(--color-primary);
    color: var(--color-bg);
    padding-block: var(--space-xl);
  }

  /* --------------------------------------------------------------------------
     Inner row. Copy on the left, button on the right. Wraps and stacks on
     narrow screens.
     -------------------------------------------------------------------------- */
  .cta-banner__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
  }

  /* --------------------------------------------------------------------------
     Copy column. Title + sub paragraph stacked. Caps line length so the
     subtitle doesn't sprawl across the full banner width on big screens.
     -------------------------------------------------------------------------- */
  .cta-banner__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    max-width: 50ch;
  }

  /* Headline. Light text overrides the global heading color (which is primary). */
  .cta-banner__title {
    color: var(--color-bg);
  }

  /* Sub line. Slightly muted against the dark surface. */
  .cta-banner__sub {
    color: color-mix(in srgb, var(--color-bg) 80%, transparent);
    font-size: 1.125rem;
    line-height: 1.5;
  }

  /* --------------------------------------------------------------------------
     Primary button. Same recipe as the Hero CTA so the affordance is
     consistent across the page.
     -------------------------------------------------------------------------- */
  .cta-banner__action {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-radius: 0.5rem;
    transition: background-color 150ms ease, transform 150ms ease;
  }

  .cta-banner__action:hover,
  .cta-banner__action:focus-visible {
    background-color: var(--color-secondary);
    transform: translateY(-1px);
  }
</style>
