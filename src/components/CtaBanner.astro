---
// Foundation, edit with care. The default props handle the homepage-style CTA;
// inner pages tune the copy by passing title, sub, ctaLabel, ctaHref.
/* ============================================================================
   CTA Banner  [revamp]
   ============================================================================
   Reusable call-to-action band that closes most inner pages and sits above the
   footer. Now a designed closing moment rather than a flat rectangle: an
   animated aurora mesh over the navy surface, a cursor-following spotlight, a
   scroll-reveal on the copy, and a magnetic shine button. The navy base still
   flows into the navy footer so the bottom of the page reads as one dark field.

   All motion is reduced-motion safe (see globals.css section 6).
   ============================================================================ */

import { Button } from './ui/button';

interface Props {
  title?:    string;
  sub?:      string;
  ctaLabel?: string;
  ctaHref?:  string;
}

const {
  title    = "Let's build something that lasts.",
  sub      = 'I take a small number of projects each quarter. The earlier we talk, the better we can pace it together.',
  ctaLabel = 'Start a project',
  ctaHref  = '/contact',
} = Astro.props;
---

<section
  class="bg-aurora spotlight-card relative isolate overflow-hidden bg-primary py-2xl text-primary-foreground"
  aria-labelledby="cta-banner-title"
  data-spotlight
>
  <!-- Copy on the left, button on the right. flex-wrap so the button drops
       below the copy on narrow screens. -->
  <div
    class="ncs-container relative z-10 flex flex-wrap items-center justify-between gap-l"
    data-reveal
  >

    <div class="flex max-w-[50ch] flex-col gap-s">
      <h2 id="cta-banner-title" class="text-primary-foreground">{title}</h2>
      <p class="text-lg leading-[1.5] text-primary-foreground/80">{sub}</p>
    </div>

    <span class="inline-block" data-magnetic="0.4">
      <Button asChild variant="brand" size="cta" className="shine">
        <a href={ctaHref}>{ctaLabel}</a>
      </Button>
    </span>

  </div>
</section>
