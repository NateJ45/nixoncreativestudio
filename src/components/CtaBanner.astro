---
// Foundation, edit with care. The default props handle the homepage CTA;
// inner pages tune the copy by passing title, sub, ctaLabel, ctaHref.
/* ============================================================================
   Section 07 | CTA Banner
   ============================================================================
   Reusable call-to-action band. Sits above the footer on the homepage and
   at the end of inner pages.

   Dark navy background mirrors the footer below it, so the two heavy
   blocks at the bottom of the page read as one continuous dark band.

   Phase 6 will swap the inline button styling for a shadcn Button.
   ============================================================================ */

import { Button } from './ui/button';

interface Props {
  title?:    string;
  sub?:      string;
  ctaLabel?: string;
  ctaHref?:  string;
}

const {
  title    = 'Have a project in mind?',
  sub      = 'I take a small number of projects each quarter. The earlier we talk, the better we can pace it together.',
  ctaLabel = 'Start a project',
  ctaHref  = '/contact',
} = Astro.props;
---

<section class="bg-primary py-xl text-bg" aria-labelledby="cta-banner-title">
  <!-- Copy on the left, button on the right. flex-wrap so the button drops
       below the copy on narrow screens. -->
  <div class="ncs-container flex flex-wrap items-center justify-between gap-l">

    <!-- Copy column. Capped at 50ch so the subtitle doesn't sprawl on
         wide screens where the button is far to the right. -->
    <div class="flex max-w-[50ch] flex-col gap-s">
      <!-- Light text on dark surface; overrides the default heading color
           which is primary. -->
      <h2 id="cta-banner-title" class="text-bg">{title}</h2>
      <p class="text-lg leading-[1.5] text-bg/80">{sub}</p>
    </div>

    <!-- Primary button. Shared shadcn Button so this banner, the Hero,
         and the contact form submit all share one styling recipe. -->
    <Button asChild variant="brand" size="cta">
      <a href={ctaHref}>{ctaLabel}</a>
    </Button>

  </div>
</section>
