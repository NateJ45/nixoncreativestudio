---
// Safe to edit. Step titles and bodies are content that Nathan rewrites
// as the process evolves.
/* ============================================================================
   Process  (currently unused, kept as a reusable soft-band process section)
   ============================================================================
   Four numbered steps in a row. Auto-fit grid drops cleanly from four
   columns at wide to two then one as viewport narrows.

   NOT currently imported anywhere. The homepage uses ProcessBand.astro (the
   four steps combined with the inquiry CTA on a navy band). /services used to
   import this soft-band version, but during the editorial-grid rebuild it
   inlined the same four steps as a ruled list on its own axis, so the page
   stays one seamless surface (see "Inner page architecture" in CLAUDE.md).
   This file is left in place as a ready-made soft-tint process section if a
   future page wants one; the step copy here is the source Nathan edits as the
   process evolves.

   Each step has a thin top border that gives the row visual rhythm
   without dominating the section.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

const steps = [
  {
    num: '01',
    title: 'Conversation',
    body: 'We meet for an hour, in person or on video, and talk about what you actually need. No pitch deck, no agency theater. Just a working session that ends with a one-page brief we both agree on.',
  },
  {
    num: '02',
    title: 'Strategy',
    body: 'I write the audience map, the page architecture, and the conversion path. You read it, push back, we revise. The strategy doc is the source of truth for every design choice that follows.',
  },
  {
    num: '03',
    title: 'Design and build',
    body: 'Components, content, and pages built in the open. Preview links land in your inbox at every milestone so you can react early instead of seeing the whole thing for the first time at launch.',
  },
  {
    num: '04',
    title: 'Launch and follow-through',
    body: 'We go live together, then I stay close for the first month to fix anything that surfaces. After that you own the site outright, with documentation and a simple way to reach me when something comes up.',
  },
];
---

<section class="bg-bg-soft py-2xl" aria-labelledby="process-heading">
  <div class="ncs-container">

    <SectionHeading
      title="How we work"
      sub="Four steps, in order. Everything else follows from the first conversation."
      headingId="process-heading"
    />

    <!-- Step grid. Four columns at wide, reflows via auto-fit minmax.
         Thin hairline top border per step gives rhythm without dominating. -->
    <ol class="grid gap-l pl-0 [grid-template-columns:repeat(auto-fit,minmax(14rem,1fr))]">
      {steps.map((step) => (
        <li class="flex flex-col gap-s border-t border-border pt-m">
          <span class="font-mono text-[0.95rem] tracking-[0.06em] text-link" aria-hidden="true">
            {step.num}
          </span>
          <!-- Step title at h4 size override (tighter than the default h3
               size that h3 normally pulls from globals.css). -->
          <h3 class="text-h4 text-heading">{step.title}</h3>
          <p class="leading-[1.5] text-text">{step.body}</p>
        </li>
      ))}
    </ol>

  </div>
</section>
