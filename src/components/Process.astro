---
/* ============================================================================
   Section 05 | How We Work (Process)
   ============================================================================
   Four numbered steps. Each step has a title and a two-sentence description.
   Visually a four-column row on desktop, two-column grid on tablet, single
   column on mobile.

   The numbered step pattern matches the section-number theme used across
   the homepage; here the numbers ground each step in sequence.

   BEM:
     process            Section wrapper.
     process__grid      Step grid.
     process-step       Single step block.
     process-step__num  Big mono number marker.
     process-step__title Step title.
     process-step__body Paragraph description.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

const steps = [
  {
    num: '01',
    title: 'Conversation',
    body: 'We meet for an hour, in person or on video, and talk about what you actually need. No pitch deck, no agency theater. Just a working session that ends with a one-page brief we both agree on.',
  },
  {
    num: '02',
    title: 'Strategy',
    body: 'I write the audience map, the page architecture, and the conversion path. You read it, push back, we revise. The strategy doc is the source of truth for every design choice that follows.',
  },
  {
    num: '03',
    title: 'Design and build',
    body: 'Components, content, and pages built in the open. Preview links land in your inbox at every milestone so you can react early instead of seeing the whole thing for the first time at launch.',
  },
  {
    num: '04',
    title: 'Launch and follow-through',
    body: 'We go live together, then I stay close for the first month to fix anything that surfaces. After that you own the site outright, with documentation and a simple way to reach me when something comes up.',
  },
];
---

<section class="process" aria-labelledby="process-heading">
  <div class="ncs-container">

    <SectionHeading
      num="05"
      title="How we work"
      sub="Four steps, in order. Everything else follows from the first conversation."
    />

    <ol class="process__grid">
      {steps.map((step) => (
        <li class="process-step">
          <span class="process-step__num" aria-hidden="true">{step.num}</span>
          <h3 class="process-step__title">{step.title}</h3>
          <p class="process-step__body">{step.body}</p>
        </li>
      ))}
    </ol>

  </div>
</section>


<style>
  /* --------------------------------------------------------------------------
     Section padding. Soft background tint, same as Services, so the two
     "tinted" sections (03 and 05) bookend the white sections in between.
     -------------------------------------------------------------------------- */
  .process {
    padding-block: var(--space-2xl);
    background-color: var(--color-bg-soft);
  }

  /* --------------------------------------------------------------------------
     Step grid. Four columns on wide screens, falling back via auto-fit
     minmax so the grid reflows automatically as the viewport shrinks.
     Reset the default ol padding so the row aligns with the section.
     -------------------------------------------------------------------------- */
  .process__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-l);
    padding-left: 0;
  }

  /* --------------------------------------------------------------------------
     Single step. Vertical stack: big number, title, body. Top border on
     each step echoes the numbered-step pattern from the WordPress build.
     -------------------------------------------------------------------------- */
  .process-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding-top: var(--space-m);
    border-top: 2px solid var(--color-primary);
  }

  /* --------------------------------------------------------------------------
     Step number. Mono, big enough to read as a marker without competing
     with the title. Accent color so it carries a little brand presence.
     -------------------------------------------------------------------------- */
  .process-step__num {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
  }

  /* Title at h4 scale; tighter than h3 because steps are compact blocks. */
  .process-step__title {
    color: var(--color-primary);
    font-size: var(--font-size-h4);
  }

  /* Body. Slightly tighter line-height than full body copy because step
     descriptions are short and dense. */
  .process-step__body {
    color: var(--color-text);
    line-height: 1.5;
  }
</style>
