---
// Foundation, edit with care. The "Currently" blurb in the script section
// is content that's safe to edit by hand whenever the season changes.
/* ============================================================================
   Site Footer
   ============================================================================
   Bottom of every page. Mirrors the structure of the WordPress build's
   footer so the content model carries over without surprises.

   Top row: three columns (Contact, Connect, Currently).
   Bottom row: copyright on the left, privacy link in the middle, tagline
   on the right, separated from the top row by a hairline divider.

   Contact details, social URLs, studio name, and tagline come from
   src/data/site.ts so a rebrand or contact change flows here without
   editing this file.
   ============================================================================ */

// Year stamp on the copyright. Recomputed at build time so it stays
// accurate without manual edits each January.
const year = new Date().getFullYear();

import { getCollection } from 'astro:content';
import { site } from '../data/site';
import CopyEmail from './CopyEmail';

// Footer site nav, mirroring the header's primary nav so the two never drift.
// Journal appears only once the journal has a published entry, exactly as in
// Header.astro (same visibility filter: drafts hidden in production). This is a
// quiet repeat of the menu for visitors who reach the bottom of a page and want
// to know where to go next, rather than scrolling back up to the header.
const journalCount = (await getCollection('journal', ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true,
)).length;
const navLinks = [
  { label: 'Work',     href: '/work/'    },
  { label: 'Services', href: '/services' },
  { label: 'About',    href: '/about'    },
  ...(journalCount > 0 ? [{ label: 'Journal', href: '/journal/' }] : []),
  { label: 'Contact',  href: '/contact'  },
];

// Social links rendered as a list. Driving this from site.social keeps
// labels in one place; add a network there and add a row here.
const social = [
  { label: 'Instagram', href: site.social.instagram },
  { label: 'LinkedIn',  href: site.social.linkedin  },
];

// "Currently" blurb. Short, present-tense, swappable per season. Lives
// here rather than in site.ts because it's marketing copy, not contact
// info, and Nathan updates it often.
const currently = 'Booking small business and nonprofit web projects for the season ahead, with a few photography days mixed in.';

// All anchor tags inside the footer share the same styling: --secondary
// (sky blue) at rest, underline appearing on hover/focus as the cue.
// Sky blue is the right token for footer links because the footer surface
// stays navy in both themes, and only a brighter blue clears WCAG AA on
// navy. --link (used elsewhere) is too dark for the footer; --accent only
// hits 4.46:1 on navy. --secondary is 7:1 on navy in light mode and 9.7:1
// in dark, so it passes comfortably in both. Pulled into a const so each
// <a> in the markup can apply the same set without copy-paste drift.
// On a touch device the links become 44px-tall flex rows so they're a
// comfortable tap target (at rest they render ~16-22px tall, fine for a mouse
// but cramped for a thumb). Gating on pointer:coarse, not screen width, means
// phones AND touch tablets (iPads) both get the larger target, while a
// mouse-driven desktop keeps the footer's tuned compact density.
const linkClass =
  'text-secondary no-underline transition-colors duration-150 ' +
  'hover:underline hover:underline-offset-2 ' +
  'focus-visible:underline focus-visible:underline-offset-2 ' +
  'pointer-coarse:inline-flex pointer-coarse:min-h-11 pointer-coarse:items-center';

// Section heading style inside each column. Same display font as h2 but
// dialed down in size so it reads as a label. text-primary-foreground is
// white in both light and dark modes (since --primary stays navy in dark),
// so the heading stays readable on the navy footer regardless of theme.
const headingClass = 'font-display text-xl tracking-[0.02em] text-primary-foreground mb-s';
---

<!--
  Full-bleed footer; the inner column uses .ncs-container to align with
  the rest of the content above. bg-primary stays navy in both modes
  (see globals.css), so this remains the darkest band on the page. A faint
  accent glow line at the very top seams it to the CtaBanner above so the two
  navy blocks read as one continuous dark field. An oversized wordmark sits
  behind the bottom row as a brand graphic.
-->
<footer class="footer-seam relative isolate overflow-hidden bg-primary py-2xl text-primary-foreground">

  <!-- Drifting brand aurora behind the columns. A child layer rather than the
       .bg-aurora ::before (the footer-seam already owns ::before). Decorative;
       freezes under reduced motion via the global rule. -->
  <div class="bg-aurora pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>

  <div class="ncs-container relative z-10">

    <!-- Top section: three columns side by side on desktop, stacked on mobile.
         auto-fit + minmax(16rem,1fr) means columns collapse to one as soon as
         a column would be thinner than 16rem, with no media query needed. -->
    <div class="mb-2xl">
      <div class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(16rem,1fr))]">

        <!-- Column 1: Explore. A quiet repeat of the primary nav so a visitor
             at the bottom of a page has the site map without scrolling back up.
             A real <nav> landmark (distinct aria-label) so assistive tech can
             jump to it. -->
        <nav aria-label="Site pages" data-reveal style="--reveal-delay: 0ms;">
          <h2 class={headingClass}>Explore</h2>
          <ul class="flex flex-col gap-xs">
            {navLinks.map(({ label, href }) => (
              <li><a class={linkClass} href={href}>{label}</a></li>
            ))}
          </ul>
        </nav>

        <!-- Column 2: Contact -->
        <div data-reveal style="--reveal-delay: 90ms;">
          <h2 class={headingClass}>Contact</h2>
          <ul class="flex flex-col gap-xs">
            <!-- CopyEmail renders the address as a mailto link plus a
                 small copy-to-clipboard button. The link still works
                 normally; the button is the convenience layer. -->
            <li><CopyEmail client:load email={site.email} tone="dark" /></li>
            <li><a class={linkClass} href={site.phoneHref}>{site.phone}</a></li>
            <li>{site.address}</li>
          </ul>
        </div>

        <!-- Column 3: Connect -->
        <div data-reveal style="--reveal-delay: 180ms;">
          <h2 class={headingClass}>Connect</h2>
          <ul class="flex flex-col gap-xs">
            {social.map(({ label, href }) => (
              <li>
                <!-- rel="noopener" on external links is a small security
                     default that also stops the new tab from poking at
                     window.opener. -->
                <a class={linkClass} href={href} target="_blank" rel="noopener noreferrer">{label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 4: Currently. Status chip + blurb, linking to the Currently
             section on /about, where the full snapshot now lives (the standalone
             /now page was merged into About). -->
        <div data-reveal style="--reveal-delay: 270ms;">
          <h2 class={headingClass}>Currently</h2>
          <a
            href="/about/#now"
            class="group mb-s inline-flex items-center gap-s rounded-full border border-white/15 px-3 py-1.5 text-sm text-primary-foreground/90 no-underline transition-colors duration-150 hover:border-white/30"
          >
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="status-ping absolute inline-flex h-full w-full rounded-full bg-tertiary opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-tertiary"></span>
            </span>
            <span>Booking projects</span>
            <span aria-hidden="true" class="transition-transform duration-150 group-hover:translate-x-0.5">→</span>
          </a>
          <p class="leading-[1.5] text-primary-foreground/75">{currently}</p>
        </div>

      </div>
    </div>

    <!-- Bottom row: the meta line (copyright + the utility links, joined by
         hairline middots so the links read as one continuous group instead of
         floating in the middle of the bar) sits on the left, the studio
         tagline on the right. Stacks on narrow screens. -->
    <div class="flex flex-col gap-s border-t border-white/10 pt-m text-sm text-primary-foreground/60 sm:flex-row sm:items-center sm:justify-between sm:gap-m">
      <div class="flex flex-wrap items-center gap-x-m gap-y-1">
        <small>© {year} {site.studioName}</small>
        <nav aria-label="Legal and accessibility" class="flex flex-wrap items-center gap-x-s gap-y-1">
          <a class={linkClass} href="/colophon">Colophon</a>
          <span aria-hidden="true" class="text-primary-foreground/30">·</span>
          <a class={linkClass} href="/privacy">Privacy</a>
          <span aria-hidden="true" class="text-primary-foreground/30">·</span>
          <a class={linkClass} href="/accessibility">Accessibility</a>
        </nav>
      </div>
      <small class="text-primary-foreground/55 sm:text-right">{site.tagline}</small>
    </div>

  </div>

  <!-- Oversized brand wordmark, bottom-anchored as a graphic. Decorative, so
       aria-hidden and clipped by the footer's overflow-hidden. -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-0 select-none overflow-hidden"
    aria-hidden="true"
  >
    <span class="footer-watermark block translate-y-[28%] whitespace-nowrap text-center font-display uppercase leading-none tracking-[0.02em] text-primary-foreground/5 [font-size:22vw]">
      {site.studioName}
    </span>
  </div>
</footer>

<style>
  /* Accent seam: a soft glow line at the very top of the footer so it joins
     the CtaBanner above into one continuous dark field. */
  .footer-seam::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in oklab, var(--color-secondary) 55%, transparent),
      transparent
    );
    z-index: 1;
  }

  /* Watermark parallax. Scroll-driven (ties motion to the visitor's scroll,
     not a timer) and progressively enhanced: only where animation-timeline is
     supported and motion is allowed. Otherwise the static translate-y-[28%]
     utility holds. Tiny amplitude so it reads as crafted, not flashy. */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .footer-watermark {
        animation: footer-drift linear both;
        animation-timeline: view();
        animation-range: entry 0% exit 100%;
      }
    }
  }
  @keyframes footer-drift {
    from { transform: translateY(40%); }
    to   { transform: translateY(20%); }
  }

  /* Availability status dot pulse. Honors reduced motion. */
  @media (prefers-reduced-motion: no-preference) {
    .status-ping {
      animation: status-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
    }
  }
  @keyframes status-ping {
    0%   { transform: scale(1);   opacity: 0.75; }
    75%, 100% { transform: scale(2.4); opacity: 0; }
  }
</style>
