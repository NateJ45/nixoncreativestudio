---
// Foundation, edit with care. The "Currently" blurb in the script section
// is content that's safe to edit by hand whenever the season changes.
/* ============================================================================
   Site Footer
   ============================================================================
   Bottom of every page. Mirrors the structure of the WordPress build's
   footer so the content model carries over without surprises.

   Top row: three columns (Contact, Connect, Currently).
   Bottom row: copyright on the left, privacy link in the middle, tagline
   on the right, separated from the top row by a hairline divider.

   Contact details, social URLs, studio name, and tagline come from
   src/data/site.ts so a rebrand or contact change flows here without
   editing this file.
   ============================================================================ */

// Year stamp on the copyright. Recomputed at build time so it stays
// accurate without manual edits each January.
const year = new Date().getFullYear();

import { site } from '../data/site';

// Social links rendered as a list. Driving this from site.social keeps
// labels in one place; add a network there and add a row here.
const social = [
  { label: 'Instagram', href: site.social.instagram },
  { label: 'LinkedIn',  href: site.social.linkedin  },
];

// "Currently" blurb. Short, present-tense, swappable per season. Lives
// here rather than in site.ts because it's marketing copy, not contact
// info, and Nathan updates it often.
const currently = 'Booking small business and nonprofit web projects for the season ahead, with a few photography days mixed in.';

// All anchor tags inside the footer share the same styling: accent blue
// by default, brighter sky blue on hover, no underline until focus or
// hover. Pulled into a const so each <a> in the markup can apply the
// same set without copy-paste drift.
const linkClass =
  'text-accent no-underline transition-colors duration-150 ' +
  'hover:text-secondary hover:underline hover:underline-offset-2 ' +
  'focus-visible:text-secondary focus-visible:underline focus-visible:underline-offset-2';

// Section heading style inside each column. Same display font as h2 but
// dialed down in size so it reads as a label, with the light bg color so
// it contrasts against the navy footer.
const headingClass = 'font-display text-xl tracking-[0.02em] text-bg mb-s';
---

<!--
  Full-bleed footer; the inner column uses .ncs-container to align with
  the rest of the content above.
-->
<footer class="bg-primary text-bg py-xl">
  <div class="ncs-container">

    <!-- Top section: three columns side by side on desktop, stacked on mobile.
         auto-fit + minmax(16rem,1fr) means columns collapse to one as soon as
         a column would be thinner than 16rem, with no media query needed. -->
    <div class="mb-l">
      <div class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(16rem,1fr))]">

        <!-- Column 1: Contact -->
        <div>
          <h2 class={headingClass}>Contact</h2>
          <ul class="flex flex-col gap-xs">
            <li><a class={linkClass} href={site.emailHref}>{site.email}</a></li>
            <li><a class={linkClass} href={site.phoneHref}>{site.phone}</a></li>
            <li>{site.address}</li>
          </ul>
        </div>

        <!-- Column 2: Connect -->
        <div>
          <h2 class={headingClass}>Connect</h2>
          <ul class="flex flex-col gap-xs">
            {social.map(({ label, href }) => (
              <li>
                <!-- rel="noopener" on external links is a small security
                     default that also stops the new tab from poking at
                     window.opener. -->
                <a class={linkClass} href={href} target="_blank" rel="noopener noreferrer">{label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Currently. Short blurb on what's on the docket. -->
        <div>
          <h2 class={headingClass}>Currently</h2>
          <p class="leading-[1.5] text-bg/75">{currently}</p>
        </div>

      </div>
    </div>

    <!-- Bottom row: copyright on the left, privacy link in the middle, tagline
         on the right. Hairline divider above. Wraps and stacks on narrow
         screens via flex-wrap. -->
    <div class="flex flex-wrap items-center justify-between gap-s border-t border-white/10 pt-m text-sm text-bg/65">
      <small>© {year} {site.studioName}</small>
      <small><a class={linkClass} href="/privacy">Privacy</a></small>
      <small>{site.tagline}</small>
    </div>

  </div>
</footer>
