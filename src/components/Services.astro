---
// Safe to edit. The chapters array below holds the user-facing copy; edit
// titles or bodies in place when positioning sharpens.
/* ============================================================================
   Section 03 | What I Do (Services)
   ============================================================================
   Three service chapters as a vertical sequence, not a card grid. Each
   chapter pairs a mono roman-numeral marker with a display title and a
   short body paragraph.

   Why stacked, not cards: services are chapters of one offering, not
   three competing options. The stacked layout lets each one breathe at
   its own size and reads as a sequence.

   The whole section sits on the soft tinted band so it visually
   alternates with the white sections above and below.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

// Three service chapters. Roman-numeral markers (i, ii, iii) read as
// steps of one offering rather than separate sections of the site.
const chapters = [
  {
    num: 'i',
    title: 'Strategy',
    body: 'Every project starts with the same question: what does this organization actually need a website to do? We map the audience, the conversion path, and the content you already have, then write the brief together.',
  },
  {
    num: 'ii',
    title: 'Web design',
    body: 'Modern, accessible, fast. Plain CSS, BEM naming, real fonts, real images. Built to load quickly on a phone in a parking lot and to keep working for years without a maintenance subscription.',
  },
  {
    num: 'iii',
    title: 'Photography',
    body: 'Headshots, event coverage, environmental shots for the site. Same person who designed the site shows up with the camera, so the visuals match the layout instead of fighting it.',
  },
];
---

<section class="bg-bg-soft py-2xl" aria-labelledby="services-heading">
  <div class="ncs-container">

    <SectionHeading
      num="03"
      title="What I do"
      sub="Three connected services. Most projects use all three; some use one or two."
    />

    <!-- Chapter list. Ordered because the chapters are sequential, but the
         default marker is hidden via list-none since we render our own
         number prefix to the left of each chapter. -->
    <ol class="flex list-none flex-col gap-xl pl-0">
      {chapters.map((chapter) => (
        <!-- Two-column grid at >= 40rem: 6rem-wide column for the number,
             then a wider column for the heading + body. Stacks at narrow
             widths so the chapters don't squeeze on phones. -->
        <li class="grid items-start gap-s grid-cols-1 sm:grid-cols-[6rem_1fr] sm:gap-m">

          <!-- Roman numeral marker. Sized just under h3 so it reads as a
               heading-mate, not body text. Padding-top nudges it to align
               visually with the title text. -->
          <span
            class="pt-1 font-mono text-xl tracking-[0.05em] text-accent"
            aria-hidden="true"
          >
            {chapter.num}
          </span>

          <!-- Copy column. Title + paragraph stacked. -->
          <div class="flex flex-col gap-s">
            <h3 class="text-primary">{chapter.title}</h3>
            <p class="max-w-[60ch] leading-[1.6] text-text">{chapter.body}</p>
          </div>

        </li>
      ))}
    </ol>

  </div>
</section>
