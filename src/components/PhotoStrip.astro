---
// Foundation, edit with care. Phase 4 swaps the gradient placeholders for
// the new Photo component backed by real JPGs in src/assets/photography/.
/* ============================================================================
   Section 04 | Selected Photography
   ============================================================================
   Photo grid. Four tiles on desktop, two on tablet, one on phone via
   auto-fit + minmax(15rem,1fr). Each tile is an <a> wrapping the
   placeholder div (and later, the <Image />), so the whole tile is the
   click target.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

// Placeholder tiles. Phase 4 wires this into the new Photo component
// backed by JPGs in src/assets/photography/.
const tiles = [
  { slug: 'event-night',     label: 'Event night',     category: 'Events'       },
  { slug: 'team-headshot',   label: 'Team headshot',   category: 'Portraits'    },
  { slug: 'classroom-light', label: 'Classroom light', category: 'Environments' },
  { slug: 'sunday-morning',  label: 'Sunday morning',  category: 'Events'       },
];
---

<section class="py-2xl" aria-labelledby="photo-strip-heading">
  <div class="ncs-container">

    <SectionHeading
      num="04"
      title="Selected photography"
      sub="A short strip of recent work. Most photos here come from the same projects as the web work above."
    />

    <!-- Tile grid. Four columns at wide, two at tablet, one at phone. -->
    <ul class="grid gap-m [grid-template-columns:repeat(auto-fit,minmax(15rem,1fr))]">
      {tiles.map((tile) => (
        <li>
          <!-- Whole tile is the link. Inner placeholder will become an
               <Image /> via the Photo component in Phase 4. -->
          <a
            class="flex flex-col gap-s text-inherit no-underline transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
            href={`/photography#${tile.slug}`}
          >
            <!-- Square placeholder so all tiles line up cleanly. Brand
                 gradient stand-in until real photography lands. -->
            <div
              class="aspect-square w-full rounded-md bg-gradient-to-br from-primary to-secondary"
              aria-hidden="true"
            ></div>
            <!-- Caption row: category small mono uppercase above label body font. -->
            <div class="flex flex-col gap-[2px]">
              <span class="font-mono text-xs uppercase tracking-[0.06em] text-text-muted">
                {tile.category}
              </span>
              <span class="text-[0.95rem] text-text">{tile.label}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
