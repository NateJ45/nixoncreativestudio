---
/* ============================================================================
   Section 04 | Selected Photography
   ============================================================================
   Full-bleed-ish photo grid. Four tiles on desktop, two on mobile. Each tile
   is a link wrapping an image, so the whole tile is clickable.

   Image area is a colored placeholder for now. Once real photography is in
   src/assets/photography/, swap the placeholder div for an Astro <Image />
   inside the <a>.

   Note on tag choice (matches the walkthrough doc): the tile is an <a> with
   the image nested inside, not a separate text link. The whole tile is the
   target.

   BEM:
     photo-strip                Section wrapper.
     photo-strip__grid          Tile grid.
     photo-strip__tile          One tile, an <a> wrapping the image.
     photo-strip__placeholder   Colored block standing in for the image.
     photo-strip__caption       Optional caption row below the image.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

// Placeholder tiles. Replace with real entries once photography is in.
const tiles = [
  { slug: 'event-night',     label: 'Event night',     category: 'Events'       },
  { slug: 'team-headshot',   label: 'Team headshot',   category: 'Portraits'    },
  { slug: 'classroom-light', label: 'Classroom light', category: 'Environments' },
  { slug: 'sunday-morning',  label: 'Sunday morning',  category: 'Events'       },
];
---

<section class="photo-strip" aria-labelledby="photo-strip-heading">
  <div class="ncs-container">

    <SectionHeading
      num="04"
      title="Selected photography"
      sub="A short strip of recent work. Most photos here come from the same projects as the web work above."
    />

    <!-- Tile grid. 4 cols at wide, 2 cols at narrow, controlled by minmax. -->
    <ul class="photo-strip__grid">
      {tiles.map((tile) => (
        <li>
          <!-- Whole tile is the link. Inner placeholder div will become an
               <Image /> once real photography lands. -->
          <a class="photo-strip__tile" href={`/photography#${tile.slug}`}>
            <div class="photo-strip__placeholder" aria-hidden="true"></div>
            <div class="photo-strip__caption">
              <span class="photo-strip__category">{tile.category}</span>
              <span class="photo-strip__label">{tile.label}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>


<style>
  /* --------------------------------------------------------------------------
     Section padding. Standard 2xl block rhythm.
     -------------------------------------------------------------------------- */
  .photo-strip {
    padding-block: var(--space-2xl);
  }

  /* --------------------------------------------------------------------------
     Tile grid. minmax(15rem, 1fr) drops to 2 columns on tablet and 1 on
     phones without media queries. On desktop it lands on 4 columns once
     the viewport is wide enough.
     -------------------------------------------------------------------------- */
  .photo-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: var(--space-m);
  }

  /* --------------------------------------------------------------------------
     Tile. Block-level link wrapping the image and caption. No underline,
     subtle hover lift so it reads as tappable.
     -------------------------------------------------------------------------- */
  .photo-strip__tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    text-decoration: none;
    color: inherit;
    transition: transform 200ms ease;
  }

  .photo-strip__tile:hover,
  .photo-strip__tile:focus-visible {
    transform: translateY(-2px);
  }

  .photo-strip__tile:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  /* --------------------------------------------------------------------------
     Image placeholder. Square aspect so tiles all line up regardless of
     viewport, and the eye reads them as a grid rather than a mason layout.
     Gradient hints at brand colors without committing to specific imagery.
     -------------------------------------------------------------------------- */
  .photo-strip__placeholder {
    aspect-ratio: 1 / 1;
    width: 100%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    border-radius: 6px;
  }

  /* --------------------------------------------------------------------------
     Caption row. Category (small, mono, muted) above the label (body font).
     -------------------------------------------------------------------------- */
  .photo-strip__caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .photo-strip__category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .photo-strip__label {
    font-size: 0.95rem;
    color: var(--color-text);
  }
</style>
