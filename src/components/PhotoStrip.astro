---
// Foundation, edit with care. The four placeholder JPGs in
// src/assets/photography/ are brand-gradient stand-ins; replace any of
// them with a real photo at the same filename to swap a tile.
/* ============================================================================
   Section 04 | Selected Photography
   ============================================================================
   Photo grid. Four tiles on desktop, two on tablet, one on phone via
   auto-fit + minmax(15rem,1fr). Each tile is an <a> wrapping a
   <Photo /> React island.

   Photo is a thin React component that renders an <img> with lazy-load
   and a fade-in. We could use Astro's <Image /> here directly for the
   same effect, but routing through Photo keeps the photo display logic
   in one place so PhotoGallery on the photography page and these
   PhotoStrip tiles share behavior.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';
import Photo from './Photo';

import eventsOne       from '../assets/photography/events-01.jpg';
import portraitsOne    from '../assets/photography/portraits-01.jpg';
import environmentsOne from '../assets/photography/environments-01.jpg';
import eventsTwo       from '../assets/photography/events-02.jpg';

// Four tiles. The img field carries the Astro-imported asset (ImageMetadata
// with src, width, height). Photo unpacks these into props.
const tiles = [
  { slug: 'event-night',     label: 'Event night',     category: 'Events',       img: eventsOne       },
  { slug: 'team-headshot',   label: 'Team headshot',   category: 'Portraits',    img: portraitsOne    },
  { slug: 'classroom-light', label: 'Classroom light', category: 'Environments', img: environmentsOne },
  { slug: 'sunday-morning',  label: 'Sunday morning',  category: 'Events',       img: eventsTwo       },
];
---

<section class="py-2xl" aria-labelledby="photo-strip-heading">
  <div class="ncs-container">

    <SectionHeading
      num="04"
      title="Selected photography"
      sub="A short strip of recent work. Most photos here come from the same projects as the web work above."
    />

    <!-- Tile grid. Four columns at wide, two at tablet, one at phone. -->
    <ul class="grid gap-m [grid-template-columns:repeat(auto-fit,minmax(15rem,1fr))]">
      {tiles.map((tile) => (
        <li>
          <a
            class="flex flex-col gap-s text-inherit no-underline transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
            href={`/photography#${tile.slug}`}
          >
            <!-- Photo renders an img wrapped in a wrapper div with the
                 aspect ratio baked in to prevent layout shift. Square
                 aspect override is enforced via outer aspect-square so
                 every tile lines up regardless of the source image
                 dimensions. -->
            <div class="aspect-square w-full overflow-hidden rounded-md">
              <Photo
                client:load
                src={tile.img.src}
                alt={`${tile.category} photography placeholder: ${tile.label}`}
                width={tile.img.width}
                height={tile.img.height}
                className="h-full w-full"
              />
            </div>
            <!-- Caption row: category small mono uppercase above label body font. -->
            <div class="flex flex-col gap-[2px]">
              <span class="font-mono text-xs uppercase tracking-[0.06em] text-text-muted">
                {tile.category}
              </span>
              <span class="text-[0.95rem] text-text">{tile.label}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
