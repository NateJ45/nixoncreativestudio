---
/* ============================================================================
   PressMentions
   ============================================================================
   Safe to edit. Renders a "Featured in" / press strip when the `press`
   array below is populated, nothing otherwise.

   Each entry has:
     - publication: where the mention appeared (e.g. "Cincinnati Magazine")
     - href:        link to the article
     - date:        ISO date string for sort
     - quote:       optional pulled excerpt
     - title:       optional article title (for tooltip / alt text)

   Drop this component anywhere a credibility section makes sense
   (likely About page, between Story and How I Work). The component
   sorts newest first and prints the publication name as a link.
   ============================================================================ */

interface PressEntry {
  publication: string;
  href:        string;
  date:        string;
  quote?:      string;
  title?:      string;
}

// Populate as press hits happen. Keeps the section out of the rendered
// page until there's actually something to show, so we never ship a
// "Featured in" heading with no content beneath it.
const press: PressEntry[] = [];

const sorted = press
  .slice()
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
---

{sorted.length > 0 && (
  <section class="py-xl" aria-labelledby="press-heading">
    <div class="ncs-container">
      <header class="mb-l flex flex-col gap-xs">
        <p class="font-mono text-sm tracking-[0.05em] text-text-muted" aria-hidden="true">P1</p>
        <h2 id="press-heading" class="text-heading">Featured in</h2>
      </header>

      <ul class="flex flex-col gap-m">
        {sorted.map((entry) => (
          <li class="flex flex-col gap-xs">
            <p class="font-mono text-[0.8rem] uppercase tracking-[0.06em] text-text-muted">
              {fmt.format(new Date(entry.date))}
            </p>
            <a
              class="text-link transition-colors duration-150 hover:underline hover:underline-offset-2 focus-visible:underline focus-visible:underline-offset-2"
              href={entry.href}
              target="_blank"
              rel="noopener noreferrer"
              title={entry.title}
            >
              <span class="font-display text-h4">{entry.publication}</span>
              {entry.title && <span class="text-text"> — {entry.title}</span>}
            </a>
            {entry.quote && (
              <blockquote class="mt-xs max-w-[60ch] border-l-4 border-accent pl-m text-text italic">
                {entry.quote}
              </blockquote>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
