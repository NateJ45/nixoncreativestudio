---
// Safe to edit. The featured array below is hardcoded today; Phase 5
// schema work + future page refinement will swap this to a content
// collection query that filters where featured === true.
/* ============================================================================
   Section 02 | Selected Work
   ============================================================================
   Three featured case study cards. Cards link to /work/{slug}. Each card's
   image area is a brand-gradient placeholder for now; replace with an
   Astro <Image /> once the case study art is in src/assets/case-studies/.
   ============================================================================ */

import SectionHeading from './SectionHeading.astro';

// Placeholder feed. Replace with getCollection('case-studies') filtered to
// featured===true once the schema work in Phase 5 lands.
const featured = [
  {
    slug: 'crestview-presbyterian',
    title: 'Crestview Presbyterian',
    client: 'Crestview Presbyterian Church',
    sector: 'Church',
    year: 2026,
    summary: 'Site refresh that doubled visit-planning form submissions in the first month.',
  },
  {
    slug: 'oakwood-preschool',
    title: 'Oakwood Preschool',
    client: 'Oakwood Preschool',
    sector: 'Preschool',
    year: 2026,
    summary: 'Brand and website built around how parents actually shop for early childhood care.',
  },
  {
    slug: 'cincy-table',
    title: 'Cincy Table',
    client: 'Cincy Table Nonprofit',
    sector: 'Nonprofit',
    year: 2025,
    summary: 'Photography and a new home page that put the people, not the program names, up front.',
  },
];
---

<section class="py-2xl" aria-labelledby="selected-work-heading">
  <div class="ncs-container">

    <SectionHeading
      num="02"
      title="Selected work"
      sub="A few recent projects. Each one started with a conversation about what the organization actually needed, not which template to pick."
      headingId="selected-work-heading"
    />

    <!-- Card grid. auto-fit + minmax means the row drops cleanly from
         three columns at wide to two then one as viewport narrows. -->
    <ul class="grid gap-l [grid-template-columns:repeat(auto-fit,minmax(18rem,1fr))]">
      {featured.map((entry) => (
        <li>
          <!-- Whole card is a single link (recommended a11y pattern for
               card UIs) so the click target covers image and body. -->
          <a
            class="flex flex-col gap-m rounded-xl text-inherit no-underline transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
            href={`/work/${entry.slug}`}
          >

            <!-- Media placeholder. 4:3 aspect keeps cards uniform until
                 real imagery lands. Soft brand gradient signals intent. -->
            <div
              class="aspect-[4/3] w-full rounded-lg bg-gradient-to-br from-bg-soft to-secondary"
              aria-hidden="true"
            ></div>

            <!-- Body stack: meta stamp, title, summary, arrow link. -->
            <div class="flex flex-col gap-xs">
              <p class="flex items-center gap-s font-mono text-[0.8rem] uppercase tracking-[0.05em] text-text-muted">
                <span>{entry.sector}</span>
                <span aria-hidden="true">·</span>
                <span>{entry.year}</span>
              </p>
              <h3 class="text-heading">{entry.title}</h3>
              <p class="leading-[1.5] text-text">{entry.summary}</p>
              <span class="card-link">Read the case study</span>
            </div>

          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
