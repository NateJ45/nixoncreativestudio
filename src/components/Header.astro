---
// Foundation, edit with care.
/* ============================================================================
   Site Header
   ============================================================================
   Top of every page. Wordmark lockup on the left, primary navigation on the
   right. Renders inside BaseLayout.astro above the <main> slot.

   Context-aware background (driven by enhance.ts):
     - data-over-hero : a hero covers the bar at the top of the page, so the
       header takes the hero's own surface colour. Theme-aware: the light hero
       surface in light mode, navy with white text over the navy hero in dark.
       Pages without a [data-hero-dark] element never get this state, so their
       header is the frosted bar from the first paint.
     - data-scrolled  : the page has scrolled past 8px; the bar frosts and
       condenses. When both are present, over-hero wins (holds the hero
       treatment while the hero is still behind it).

   All three visual states live in the scoped <style> block below rather than
   in Tailwind data-variant utilities, so the precedence between them is
   controlled by source order instead of specificity guesswork.

   The nav carries no 01-06 numerals: it is a flat set of destinations, not an
   ordered sequence, so numbered markers (which live only on the genuinely
   ordered Process band) would be decorative scaffolding here.
   ============================================================================ */

import { getCollection } from 'astro:content';
import { site } from '../data/site';
import MobileNav from './MobileNav';
import ThemeToggle from './ThemeToggle';
import { buttonVariants } from './ui/button';
import { cn } from '@/lib/utils';

// Hide the Journal nav link until the journal has something to show. Uses the
// SAME visibility filter as the journal index (drafts hidden in production,
// visible in dev), so the link appears exactly when the page has real content.
// While the collection is empty the link is omitted from both the desktop nav
// and the mobile drawer (they share this array).
const journalCount = (await getCollection('journal', ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true,
)).length;

// The nav model lives in the script so it's easy to reorder, rename, or extend
// without hunting through markup. MobileNav consumes the same array. Contact is
// NOT in this list: it is promoted to the "Start a project" CTA button (desktop
// header below, and the drawer's own CTA on mobile), both pointing at /contact.
const navLinks = [
  { label: 'Work',     href: '/work/'    },
  { label: 'Services', href: '/services' },
  { label: 'About',    href: '/about'    },
  ...(journalCount > 0 ? [{ label: 'Journal', href: '/journal/' }] : []),
];

// Active-route detection so the current section is marked in the nav. Treats a
// link as active when the path matches it or sits beneath it (e.g. /work/foo).
const path = Astro.url.pathname.replace(/\/+$/, '');
const isActive = (href: string): boolean => {
  const h = href.replace(/\/+$/, '');
  if (h === '') return path === '';
  return path === h || path.startsWith(`${h}/`);
};
---

<header data-header class="ncs-header sticky top-0 z-50">
  <div class="ncs-container flex items-center justify-between gap-m">

    <!-- Wordmark: the studio name, set in the display face. The text flips with
         theme and goes white over the dark hero. transition:name morphs it
         across View Transitions navigations. -->
    <a
      class="wordmark group inline-flex items-center no-underline"
      href="/"
      transition:name="site-wordmark"
    >
      <span class="wordmark-text link-underline font-display text-2xl leading-none tracking-[0.02em]">
        {site.studioName}
      </span>
    </a>

    <!-- Right-side cluster: desktop nav, theme toggle, mobile drawer. -->
    <div class="flex items-center gap-s">

      <!-- Desktop nav at >= md (six items don't fit at sm next to the wordmark
           and toggle); the MobileNav drawer takes over below md. -->
      <nav aria-label="Primary" class="hidden md:block">
        <ul class="flex items-center gap-m">
          {navLinks.map(({ label, href }) => (
            <li>
              <a
                class:list={[
                  'nav-link link-underline font-body text-base no-underline transition-colors duration-150',
                  isActive(href) ? 'is-active text-link' : 'text-text hover:text-link focus-visible:text-link',
                ]}
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Vertical separator between the page nav and the primary action, so the
           CTA reads as distinct. Inherits the header's text colour (dark on the
           light bar, light over the navy hero) at low opacity, staying subtle in
           every state. Desktop only, alongside the nav + CTA it divides. -->
      <div class="hidden h-6 w-px self-center bg-current opacity-20 md:block" aria-hidden="true"></div>

      <!-- Primary CTA, promoted from the old Contact nav link: a prominent brand
           button straight to the inquiry form. Desktop only; the MobileNav drawer
           carries its own "Start a project" CTA. The brand fill stands out in
           every header state (over the light or navy hero, and when scrolled). -->
      <div class="hidden md:block">
        <a
          href="/contact"
          class={cn(buttonVariants({ variant: 'brand', size: 'cta' }), 'shine px-5 py-2.5')}
        >
          Start a project
        </a>
      </div>

      <!-- Theme toggle. Desktop only; the MobileNav drawer carries its own. -->
      <div class="hidden md:block">
        <ThemeToggle client:load />
      </div>

      <!-- Mobile drawer. Hidden at >= md. client:only='react' skips SSR of the
           Radix-portal Sheet, which doesn't render cleanly inside Astro. -->
      <div class="md:hidden">
        <MobileNav client:only="react" links={navLinks} studioName={site.studioName} />
      </div>

    </div>

  </div>
</header>

<style>
  /* ---- Header surface states ---------------------------------------------
     Default: a frosted bar with a hairline divider, always legible over the
     light inner-page heroes. */
  .ncs-header {
    /* Top padding carries the status-bar / notch inset when the page runs
       edge-to-edge under viewport-fit=cover, so the wordmark and nav never
       slide under the notch in a standalone/landscape context. env() is 0 in
       normal browser chrome, so this reads as a flat --spacing-m there. */
    padding-top: calc(var(--spacing-m) + env(safe-area-inset-top));
    padding-bottom: var(--spacing-m);
    background-color: color-mix(in oklab, var(--color-bg) 95%, transparent);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition:
      background-color 0.3s ease,
      box-shadow 0.3s ease,
      padding 0.3s ease,
      border-color 0.3s ease;
  }

  /* Scrolled: frost deepens, the bar condenses and lifts. */
  .ncs-header[data-scrolled] {
    padding-top: calc(0.75rem + env(safe-area-inset-top));
    padding-bottom: 0.75rem;
    background-color: color-mix(in oklab, var(--color-bg) 90%, transparent);
    box-shadow: 0 10px 30px -18px rgba(10, 22, 40, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Over the hero: a solid bar that takes the hero's own surface colour so the
     two read as one continuous block. The header sits ABOVE the hero in flow
     (not overlapping), so a transparent bar would reveal the page background,
     not the hero, hence solid. Theme-aware: the light hero surface (bg-soft) in
     light mode, navy in dark. Declared after [data-scrolled] so it wins while
     the hero is still behind the bar. */
  .ncs-header[data-over-hero] {
    background-color: var(--color-bg-soft);
    border-color: transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  :global(.dark) .ncs-header[data-over-hero] {
    background-color: var(--primary);
  }
  /* Over the navy hero (dark mode) the wordmark + nav flip to white. In light
     mode the default dark heading / nav-link colours already read cleanly on the
     light hero surface, so no override is needed. The theme toggle + mobile
     hamburger are React islands that set their own icon colour via a text-*
     class; reach them with :global + a hook class so they flip white too. */
  :global(.dark) .ncs-header[data-over-hero] .wordmark-text,
  :global(.dark) .ncs-header[data-over-hero] .nav-link {
    color: #ffffff;
  }
  :global(.dark) .ncs-header[data-over-hero] :global(.theme-toggle),
  :global(.dark) .ncs-header[data-over-hero] :global(.mobile-trigger) {
    color: #ffffff;
  }

  /* ---- Wordmark ----------------------------------------------------------- */
  .wordmark-text {
    color: var(--color-heading);
    transition: color 0.2s ease;
  }

  /* Active nav item keeps its underline drawn (the .link-underline base hides
     it until hover). Paired with text-link + aria-current for a non-color cue. */
  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .ncs-header { transition: none; }
  }
</style>
