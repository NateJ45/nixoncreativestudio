---
/* ============================================================================
   Site Header
   ============================================================================
   Top of every page. Wordmark on the left, primary navigation on the right.
   Renders inside BaseLayout.astro above the <main> slot.

   The four nav links match the homepage section architecture documented in
   CLAUDE.md (01 Work, 02 Services, 03 About, 04 Contact). The numbered
   prefixes are the visual through-line that ties the header to the section
   headings on the homepage.

   Mobile note: at narrow widths the four links will compress and may overflow.
   A hamburger / off-canvas pattern is on the to-do list (carried over from the
   Bricks build). For now the desktop layout is the priority.
   ============================================================================ */

// The nav model lives in the script so it's easy to reorder, rename, or
// extend later without hunting through markup.
const navLinks = [
  { num: '01', label: 'Work',     href: '/work/'    },
  { num: '02', label: 'Services', href: '/services' },
  { num: '03', label: 'About',    href: '/about'    },
  { num: '04', label: 'Contact',  href: '/contact'  },
];
---

<!-- Outer header is full-bleed (background and border-bottom span the page),
     while the inner uses .ncs-container to align with the rest of the content. -->
<header class="site-header">
  <div class="ncs-container site-header__inner">

    <!-- Wordmark links home. Display font, brand color, deliberately set in rem
         so it scales with the user's root font-size preference. -->
    <a class="site-header__wordmark" href="/">Nixon Creative Studio</a>

    <!-- aria-label distinguishes this nav from the footer nav for screen readers. -->
    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {navLinks.map(({ num, label, href }) => (
          <li>
            <a class="site-nav__link" href={href}>
              <!-- Section number sits before the label, muted and in mono so it
                   reads as a label, not as part of the link text. -->
              <span class="site-nav__num">{num}</span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div>
</header>


<style>
  /* --------------------------------------------------------------------------
     Outer wrapper. Full-bleed background plus the thin hairline divider that
     separates the header from the page content below.
     -------------------------------------------------------------------------- */
  .site-header {
    padding-block: var(--space-m);
    /* Low-alpha black for the hairline, so it stays neutral if the section
       below ever changes background color. */
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    background-color: var(--color-bg);
  }

  /* --------------------------------------------------------------------------
     Inner row. Wordmark on the left, nav on the right, vertically centered.
     -------------------------------------------------------------------------- */
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
  }

  /* --------------------------------------------------------------------------
     Wordmark. Display font at a fixed 1.5rem so it stays steady in the header
     even as the hero h1 scales fluidly below.
     -------------------------------------------------------------------------- */
  .site-header__wordmark {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;             /* Tight so the row sits at a predictable height. */
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.01em;     /* A whisper of tracking so the caps breathe. */
  }

  /* --------------------------------------------------------------------------
     Nav list. Horizontal row of links with consistent gaps.
     -------------------------------------------------------------------------- */
  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-m);
  }

  /* --------------------------------------------------------------------------
     Nav link. Body font, near-black, transitions to the accent color on hover
     and keyboard focus. inline-flex with a small gap is what positions the
     number and label side by side.
     -------------------------------------------------------------------------- */
  .site-nav__link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-xs);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .site-nav__link:hover,
  .site-nav__link:focus-visible {
    color: var(--color-accent);
  }

  /* --------------------------------------------------------------------------
     Section number prefix. Smaller, mono, muted. Reads as a label rather
     than as part of the clickable text.
     -------------------------------------------------------------------------- */
  .site-nav__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
