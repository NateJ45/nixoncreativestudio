---
// Foundation, edit with care.
/* ============================================================================
   Site Header
   ============================================================================
   Top of every page. Wordmark on the left, primary navigation on the right.
   Renders inside BaseLayout.astro above the <main> slot.

   The four nav links match the homepage section architecture documented in
   CLAUDE.md (01 Work, 02 Services, 03 About, 04 Contact). The numbered
   prefixes are the visual through-line that ties the header to the section
   headings on the homepage.

   Mobile note: at narrow widths the four links will compress and may
   overflow. Phase 6 swaps in a shadcn Sheet for the mobile nav. For now
   the desktop layout is the priority.
   ============================================================================ */

// Studio name comes from the central site data module so a rebrand updates
// the wordmark, the footer, and meta together.
import { site } from '../data/site';

// The nav model lives in the script so it's easy to reorder, rename, or
// extend later without hunting through markup.
const navLinks = [
  { num: '01', label: 'Work',     href: '/work/'    },
  { num: '02', label: 'Services', href: '/services' },
  { num: '03', label: 'About',    href: '/about'    },
  { num: '04', label: 'Contact',  href: '/contact'  },
];
---

<!--
  Outer header is full-bleed: the background and the hairline divider span the
  whole page width. The inner row uses .ncs-container to align with the rest
  of the content column. .ncs-container stays as a utility class in
  globals.css since the same pattern repeats across every section component.
-->
<header class="border-b border-black/[0.08] bg-bg py-m">
  <div class="ncs-container flex items-center justify-between gap-m">

    <!-- Wordmark links home. Display font at a fixed 1.5rem so it stays
         steady even as the hero h1 scales fluidly on wide screens. -->
    <a
      class="font-display text-2xl leading-none tracking-[0.01em] text-primary no-underline"
      href="/"
    >
      {site.studioName}
    </a>

    <!-- aria-label distinguishes this nav from the footer nav for assistive tech. -->
    <nav aria-label="Primary">
      <ul class="flex items-center gap-m">
        {navLinks.map(({ num, label, href }) => (
          <li>
            <a
              class="inline-flex items-baseline gap-xs font-body text-base text-text no-underline transition-colors duration-150 hover:text-accent focus-visible:text-accent"
              href={href}
            >
              <!-- Section number prefix. Smaller, mono, muted. Reads as a
                   label rather than as part of the link text. -->
              <span class="font-mono text-xs text-text-muted">{num}</span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div>
</header>
