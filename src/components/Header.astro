---
// Foundation, edit with care.
/* ============================================================================
   Site Header
   ============================================================================
   Top of every page. Wordmark lockup on the left, primary navigation on the
   right. Renders inside BaseLayout.astro above the <main> slot.

   Context-aware background (driven by enhance.ts):
     - data-over-hero : the page has a dark hero at the top and it still covers
       the bar, so the header is transparent with white text and the brand mark.
       Pages without a [data-hero-dark] element never get this state, so their
       header is the frosted bar from the first paint.
     - data-scrolled  : the page has scrolled past 8px; the bar frosts and
       condenses. When both are present, over-hero wins (stays transparent
       while the dark hero is still behind it).

   All three visual states live in the scoped <style> block below rather than
   in Tailwind data-variant utilities, so the precedence between them is
   controlled by source order instead of specificity guesswork.

   The nav carries no 01-06 numerals: it is a flat set of destinations, not an
   ordered sequence, so numbered markers (which live only on the genuinely
   ordered Process band) would be decorative scaffolding here.
   ============================================================================ */

import { site } from '../data/site';
import MobileNav from './MobileNav';
import ThemeToggle from './ThemeToggle';

// The nav model lives in the script so it's easy to reorder, rename, or extend
// without hunting through markup. MobileNav consumes the same array.
const navLinks = [
  { label: 'Work',     href: '/work/'    },
  { label: 'Services', href: '/services' },
  { label: 'About',    href: '/about'    },
  { label: 'Journal',  href: '/journal/' },
  { label: 'Now',      href: '/now/'     },
  { label: 'Contact',  href: '/contact'  },
];

// Active-route detection so the current section is marked in the nav. Treats a
// link as active when the path matches it or sits beneath it (e.g. /work/foo).
const path = Astro.url.pathname.replace(/\/+$/, '');
const isActive = (href: string): boolean => {
  const h = href.replace(/\/+$/, '');
  if (h === '') return path === '';
  return path === h || path.startsWith(`${h}/`);
};
---

<header data-header class="ncs-header sticky top-0 z-50">
  <div class="ncs-container flex items-center justify-between gap-m">

    <!-- Wordmark lockup: a small amber brand mark plus the studio name. The
         mark stays amber over every background; the text flips with theme and
         goes white over the dark hero. transition:name morphs it across View
         Transitions navigations. -->
    <a
      class="wordmark group inline-flex items-center gap-s no-underline"
      href="/"
      transition:name="site-wordmark"
    >
      <span class="wordmark-glyph" aria-hidden="true">
        <!-- Inline-SVG monogram: an "N" stroke that draws itself on load, with
             the amber brand diamond at its shoulder. The stroke inherits the
             wordmark color (currentColor) so it flips with theme and over-hero;
             the diamond stays amber. -->
        <svg viewBox="0 0 32 32" width="26" height="26" fill="none">
          <path
            class="wordmark-stroke"
            d="M7 24V9l14 15V9"
            stroke="currentColor"
            stroke-width="2.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <rect class="wordmark-dot" x="20.4" y="6.4" width="5" height="5" rx="1" transform="rotate(45 22.9 8.9)" />
        </svg>
      </span>
      <span class="wordmark-text link-underline font-display text-2xl leading-none tracking-[0.02em]">
        {site.studioName}
      </span>
    </a>

    <!-- Right-side cluster: desktop nav, theme toggle, mobile drawer. -->
    <div class="flex items-center gap-s">

      <!-- Desktop nav at >= md (six items don't fit at sm next to the wordmark
           and toggle); the MobileNav drawer takes over below md. -->
      <nav aria-label="Primary" class="hidden md:block">
        <ul class="flex items-center gap-m">
          {navLinks.map(({ label, href }) => (
            <li>
              <a
                class:list={[
                  'nav-link link-underline font-body text-base no-underline transition-colors duration-150',
                  isActive(href) ? 'is-active text-link' : 'text-text hover:text-link focus-visible:text-link',
                ]}
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Theme toggle. Desktop only; the MobileNav drawer carries its own. -->
      <div class="hidden md:block">
        <ThemeToggle client:load />
      </div>

      <!-- Mobile drawer. Hidden at >= md. client:only='react' skips SSR of the
           Radix-portal Sheet, which doesn't render cleanly inside Astro. -->
      <div class="md:hidden">
        <MobileNav client:only="react" links={navLinks} studioName={site.studioName} />
      </div>

    </div>

  </div>
</header>

<style>
  /* ---- Header surface states ---------------------------------------------
     Default: a frosted bar with a hairline divider, always legible over the
     light inner-page heroes. */
  .ncs-header {
    padding-block: var(--spacing-m);
    background-color: color-mix(in oklab, var(--color-bg) 95%, transparent);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition:
      background-color 0.3s ease,
      box-shadow 0.3s ease,
      padding 0.3s ease,
      border-color 0.3s ease;
  }

  /* Scrolled: frost deepens, the bar condenses and lifts. */
  .ncs-header[data-scrolled] {
    padding-block: 0.75rem;
    background-color: color-mix(in oklab, var(--color-bg) 90%, transparent);
    box-shadow: 0 10px 30px -18px rgba(10, 22, 40, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Over the dark hero: a solid navy bar (matching --primary, which is navy in
     both themes) with white foreground, so it reads as one continuous block
     with the navy hero directly below it. Navy (not transparent) is deliberate:
     the header sits ABOVE the hero in flow rather than overlapping it, so a
     transparent bar would reveal the page background (white in light mode) and
     the white wordmark would vanish. Declared after [data-scrolled] so it wins
     while the hero is still behind the bar. */
  .ncs-header[data-over-hero] {
    background-color: var(--primary);
    border-color: transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  .ncs-header[data-over-hero] .wordmark-text,
  .ncs-header[data-over-hero] .wordmark-glyph,
  .ncs-header[data-over-hero] .nav-link {
    color: #ffffff;
  }
  /* Theme toggle + mobile hamburger are React islands that set their own icon
     color via a text-* class; reach them with :global and a hook class so they
     flip to white over the hero too. */
  .ncs-header[data-over-hero] :global(.theme-toggle),
  .ncs-header[data-over-hero] :global(.mobile-trigger) {
    color: #ffffff;
  }

  /* ---- Wordmark ----------------------------------------------------------- */
  .wordmark-text {
    color: var(--color-heading);
    transition: color 0.2s ease;
  }
  /* Monogram glyph: the N stroke inherits the wordmark color; the diamond
     stays amber. The whole glyph nudges up on hover. */
  .wordmark-glyph {
    display: inline-flex;
    color: var(--color-heading);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .wordmark-glyph svg { display: block; }
  .wordmark-dot { fill: var(--color-tertiary); }
  .wordmark:hover .wordmark-glyph,
  .wordmark:focus-visible .wordmark-glyph {
    transform: translateY(-1px);
  }
  /* Draw the N on first paint. */
  @media (prefers-reduced-motion: no-preference) {
    .wordmark-stroke {
      stroke-dasharray: 64;
      animation: wordmark-draw 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  }
  @keyframes wordmark-draw {
    from { stroke-dashoffset: 64; }
    to   { stroke-dashoffset: 0; }
  }

  /* Active nav item keeps its underline drawn (the .link-underline base hides
     it until hover). Paired with text-link + aria-current for a non-color cue. */
  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .ncs-header { transition: none; }
    .wordmark-glyph { transition: none; }
    .wordmark:hover .wordmark-glyph,
    .wordmark:focus-visible .wordmark-glyph { transform: none; }
  }
</style>
