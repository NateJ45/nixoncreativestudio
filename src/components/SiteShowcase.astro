---
// Safe to edit.
/* ============================================================================
   SiteShowcase  [device pairing]
   ============================================================================
   An animated "live site" showcase embedded in a case study: a browser-chrome
   window whose full-page DESKTOP screenshot scrolls on view, paired with a small
   PHONE in the lower-right showing the same site's MOBILE screenshot scrolling
   in step. Showing one site on two screens reads as "this is a real, responsive
   build," the same device-pairing language as the homepage hero and the Selected
   Work cards. The desktop frame links to the live site.

   Captures are resolved by slug (the same convention as the hero showcase and
   the /work cards), so a case study only needs:
     - src/assets/case-studies/shots/<slug>-home.png   (desktop, 1440 wide, full page)  REQUIRED
     - src/assets/case-studies/shots/<slug>-mobile.png  (phone, ~545 wide, full page)    OPTIONAL
   If the mobile capture is absent, the phone simply is not shown (desktop only),
   so a new study works the moment its home capture lands.

   Usage inside a case study .mdx (import goes right under the frontmatter):

     import SiteShowcase from '../../components/SiteShowcase.astro';

     <SiteShowcase
       slug="<slug>"
       alt="The <Client> homepage, scrolling top to bottom"
       href="https://example.com"
       label="example.com"
     />

   Accessibility: the scroll is gated behind prefers-reduced-motion, so a
   reduced-motion visitor sees static frames (the top of each page) and the link
   still works. The phone is decorative (aria-hidden, pointer-events:none, so the
   desktop link stays clickable beneath it). The chrome dots are decorative and
   the link carries an explicit aria-label. The phone is hidden below md, where a
   phone-inside-a-phone would be too cramped to read.
   ============================================================================ */

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** Case study slug. Resolves <slug>-home.png (required) and <slug>-mobile.png (optional). */
  slug: string;
  /** Descriptive alt for the desktop screenshot. */
  alt: string;
  /** Live site URL the frame links to. */
  href: string;
  /** Address-bar label. Defaults to the href host without protocol. */
  label?: string;
  /** 'scroll' (default) auto-scrolls the whole page; 'zoom' slow Ken Burns. */
  variant?: 'scroll' | 'zoom';
}

const { slug, alt, href, label, variant = 'scroll' } = Astro.props;

// Resolve the captures by slug (eager glob, same pattern as SelectedWork).
const homeShots = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/case-studies/shots/*-home.png',
  { eager: true },
);
const mobileShots = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/case-studies/shots/*-mobile.png',
  { eager: true },
);
const src = Object.entries(homeShots).find(([p]) => p.endsWith(`/${slug}-home.png`))?.[1].default;
const mobileSrc = Object.entries(mobileShots).find(([p]) => p.endsWith(`/${slug}-mobile.png`))?.[1].default;
if (!src) {
  throw new Error(`SiteShowcase: no desktop capture for slug "${slug}" (expected ${slug}-home.png)`);
}

const shown = (label ?? href).replace(/^https?:\/\//, '').replace(/\/$/, '');
const hasPhone = !!mobileSrc;
---

<figure class="site-showcase my-l">
  <div class:list={['showcase-pair', hasPhone && 'has-phone']}>
    <a
      class="showcase group block overflow-hidden rounded-xl border border-border bg-bg no-underline shadow-[var(--shadow-frame)] transition-transform duration-300 hover:-translate-y-1"
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Visit the live ${shown} site (opens in a new tab)`}
    >
      <!-- Browser chrome bar: traffic-light dots + a fake address bar. -->
      <div class="flex items-center gap-s border-b border-border bg-bg-soft px-3 py-2">
        <span class="flex gap-1.5" aria-hidden="true">
          <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
        </span>
        <span class="mx-auto inline-flex items-center gap-1.5 rounded-md bg-bg px-3 py-1 font-mono text-[0.72rem] text-text-muted">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="5" y="11" width="14" height="9" rx="2" />
            <path d="M8 11V7a4 4 0 0 1 8 0v4" />
          </svg>
          {shown}
        </span>
        <span class="font-mono text-[0.7rem] uppercase tracking-[0.08em] text-link opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-visible:opacity-100">
          Visit ↗
        </span>
      </div>

      <!-- Scrolling / zooming desktop viewport. -->
      <div class={`showcase-window ${variant === 'zoom' ? 'showcase-zoom' : 'showcase-scroll'}`}>
        <Image
          src={src}
          alt={alt}
          widths={[768, 1024, 1425]}
          sizes="(min-width: 56rem) 70vw, 100vw"
        />
      </div>
    </a>

    {hasPhone && (
      <!-- Phone overlapping the desktop's lower-right. Decorative (the desktop
           shows the same site), so aria-hidden; pointer-events:none keeps the
           desktop link clickable beneath it. Hidden below md (see <style>). -->
      <div class="showcase-phone" aria-hidden="true">
        <div class="showcase-phone-window">
          <Image
            src={mobileSrc!}
            alt=""
            widths={[220, 330, 440]}
            sizes="(min-width: 48rem) 200px, 1px"
            class="showcase-phone-img"
            loading="lazy"
          />
        </div>
      </div>
    )}
  </div>

  <figcaption class="mt-xs text-center font-mono text-[0.75rem] text-text-muted">
    Live at <span class="text-link">{shown}</span>.
  </figcaption>
</figure>

<style>
  /* The pair wraps the desktop frame and the floating phone. position:relative so
     the phone can be absolutely placed against it. */
  .showcase-pair {
    position: relative;
  }

  /* The fixed-height window crops the tall screenshot; the inner image is
     animated to reveal the whole page. --wh is shared between the window
     height and the scroll keyframe so the image stops exactly at its bottom. */
  .showcase-window {
    --wh: clamp(17rem, 52vh, 28rem);
    position: relative;
    height: var(--wh);
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .showcase-window :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---- Phone: a small floating device in the lower-right -------------------
     Hidden below md (a phone inside a phone is too cramped to read). At md+ it
     overlaps the desktop's lower-right, bottom-aligned, with a deep soft shadow
     so it reads as floating in front. --pw controls its width. */
  .showcase-phone {
    display: none;
  }
  @media (min-width: 48rem) {
    .showcase-phone {
      --pw: clamp(8.5rem, 19%, 11.5rem);
      display: block;
      position: absolute;
      right: 2.5%;
      bottom: 0;
      width: var(--pw);
      z-index: 3;
      padding: 0.35rem;
      border-radius: 1.4rem;
      background: #0b0e14;
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow:
        0 34px 60px -26px rgba(0, 0, 0, 0.62),
        0 14px 30px -22px rgba(0, 0, 0, 0.5);
      pointer-events: none; /* keep the desktop link clickable underneath */
    }
    /* Speaker/notch pill. */
    .showcase-phone::before {
      content: '';
      position: absolute;
      top: 0.5rem;
      left: 50%;
      transform: translateX(-50%);
      width: 26%;
      height: 0.22rem;
      border-radius: 9999px;
      background: rgba(255, 255, 255, 0.25);
      z-index: 2;
    }
  }

  .showcase-phone-window {
    position: relative;
    overflow: hidden;
    border-radius: 1.05rem;
    aspect-ratio: 9 / 19;
    background: var(--color-bg-soft);
  }
  .showcase-phone-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (prefers-reduced-motion: no-preference) {
    /* Scroll variant: pan the full-page screenshot top-to-bottom in lockstep
       with the visitor's own scroll as the frame crosses the viewport, so it
       feels like scrolling the real site through a window rather than watching
       a timed loop. Where scroll-timeline is unsupported, the image simply
       sits at the top (a clean static frame); the link still works. */
    @supports (animation-timeline: view()) {
      /* The timeline must be NAMED and declared on the outer figure. An
         anonymous view() set on the image binds to the image's NEAREST scroll
         container, which is the overflow:hidden .showcase-window (and, for the
         phone, .showcase-phone-window), NOT the page. Those inner boxes never
         scroll, so the timeline never advances and the screenshot sits frozen
         at one position (the bug this fixes). Naming the timeline on
         .site-showcase, whose nearest scroll container IS the page, and
         referencing it by name from both images, crosses the overflow boundary
         so the pan tracks real page scroll as the frame travels the viewport. */
      .site-showcase {
        view-timeline-name: --ncs-showcase-view;
        view-timeline-axis: block;
      }
      .showcase-scroll :global(img) {
        animation: showcase-scroll linear both;
        animation-timeline: --ncs-showcase-view;
        animation-range: entry 12% exit 88%;
      }
      /* The phone pans its (taller) mobile page on the same scroll, a touch
         further since a mobile layout stacks taller. */
      .showcase-phone-img {
        animation: showcase-phone-scroll linear both;
        animation-timeline: --ncs-showcase-view;
        animation-range: entry 12% exit 88%;
      }
    }

    /* Zoom variant keeps a slow Ken Burns loop and pauses on hover/focus. */
    .showcase-zoom :global(img) {
      transform-origin: top center;
      animation: showcase-zoom 18s ease-in-out infinite alternate;
    }
    .showcase:hover .showcase-zoom :global(img),
    .showcase:focus-visible .showcase-zoom :global(img) {
      animation-play-state: paused;
    }
  }

  @keyframes showcase-scroll {
    from { transform: translateY(0); }
    to   { transform: translateY(calc(-100% + var(--wh))); }
  }

  @keyframes showcase-phone-scroll {
    from { transform: translateY(0); }
    to   { transform: translateY(-58%); }
  }

  @keyframes showcase-zoom {
    from { transform: scale(1); }
    to   { transform: scale(1.16) translateY(-6%); }
  }
</style>
