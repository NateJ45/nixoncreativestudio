---
// Safe to edit. The four steps and the closing CTA copy below are content;
// rewrite in place when the process or the offer sharpens.
/* ============================================================================
   ProcessBand — the four-step "how we work" sequence
   ============================================================================
   ONE component, two placements, so the process reads identically everywhere:

     - Homepage close:  <ProcessBand />
         The navy band-themed closing band with the inquiry CTA folded in
         (variant 'band', showCta true). Ends the page on one decisive block.

     - /services mid-page:  <ProcessBand variant="soft" showCta={false} headingId="process-heading" />
         The same numbered connector-rail steps on the soft surface, no CTA.

   Both render the same treatment: four numbered nodes on a single connector
   line that draws across on scroll. The four step numbers are the ONE
   deliberately numbered sequence on the site (the process is genuinely
   ordered); the section itself carries no number.

   This replaces the old separate Process.astro, which used a different
   (detached top-rule + bare-numeral) treatment and made the process look like
   two different things across a two-click journey.
   ============================================================================ */

import { buttonVariants } from './ui/button';

interface Props {
  /** 'band' = navy band-themed closing band (homepage); 'soft' = bg-soft mid-page section (/services). */
  variant?: 'band' | 'soft';
  /** Render the closing inquiry CTA tail. Defaults on (the homepage close). */
  showCta?: boolean;
  /** id on the <h2> so a parent section's aria-labelledby resolves. */
  headingId?: string;
}

const { variant = 'band', showCta = true, headingId = 'process-band-heading' } = Astro.props;
const isBand = variant === 'band';

const steps = [
  {
    num: '01',
    title: 'Conversation',
    body: 'We meet for an hour, in person or on video, and talk about what you actually need. No pitch deck, no agency theater. Just a working session that ends with a one-page brief we both agree on.',
  },
  {
    num: '02',
    title: 'Strategy',
    body: 'I write the audience map, the page architecture, and the conversion path. You read it, push back, we revise. The strategy doc is the source of truth for every design choice that follows.',
  },
  {
    num: '03',
    title: 'Design and build',
    body: 'Components, content, and pages built in the open. Preview links land in your inbox at every milestone so you can react early instead of seeing the whole thing for the first time at launch.',
  },
  {
    num: '04',
    title: 'Launch and follow-through',
    body: 'We go live together, then I stay close for the first month to fix anything that surfaces. After that you own the site outright, with documentation and a simple way to reach me when something comes up.',
  },
];

// Closing CTA copy. Title is specific to audience and intentionally human;
// the old "Have a project in mind?" was sales-template cliché.
const ctaTitle = 'Tell me what you are building.';
const ctaSub  = 'I take a small number of projects each quarter. The earlier we talk, the better we can pace it together.';
---

<section
  class:list={[
    'process-band py-2xl',
    isBand ? 'band-themed process-band--closing' : 'bg-bg-soft',
  ]}
  aria-labelledby={headingId}
>
  <div class="ncs-container relative z-10 flex flex-col gap-2xl">

    <!-- Header. Title carries the weight; no eyebrow, no number. -->
    <header class="flex max-w-[60ch] flex-col gap-xs" data-reveal>
      <h2 id={headingId} class="text-heading">How we work</h2>
      <p class="text-lg leading-[1.55] text-text-muted">
        Four steps, in order. Everything else follows from the first conversation.
      </p>
    </header>

    <!-- Four process steps as numbered nodes on a single connector line. The
         one connector (drawn across on scroll at lg) carries the "ordered
         sequence" meaning. Grid: 1 col on mobile, 2 at sm, 4 across at lg
         where the connector lives. -->
    <ol class="process-steps relative grid list-none gap-l p-0 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Single connector rail behind the number nodes (lg row only). Draws
           left-to-right on scroll where supported; otherwise fully drawn. -->
      <span class="process-connector hidden lg:block" aria-hidden="true"></span>

      {steps.map((step, index) => (
        <li
          class="relative flex flex-col items-start gap-s"
          data-reveal
          style={`--reveal-delay: ${index * 110}ms;`}
        >
          <!-- One numbered node. The badge IS the step number (no second
               ghost numeral). accent-foreground keeps it readable on the
               accent fill in both themes. -->
          <span class="relative z-10 inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent font-mono text-sm text-accent-foreground">
            {step.num}
          </span>
          <h3 class="text-h4 text-heading">{step.title}</h3>
          <p class="leading-[1.55] text-text-muted">{step.body}</p>
        </li>
      ))}
    </ol>

    <!-- Closing CTA (homepage). Title + sub on the left, button on the right.
         flex-wrap so the button drops below on narrow screens. -->
    {showCta && (
      <div
        class="mt-l flex flex-wrap items-center justify-between gap-l border-t border-border pt-2xl"
        data-reveal
      >
        <div class="flex max-w-[50ch] flex-col gap-s">
          <p class="text-h3 leading-[1.1] text-heading font-display">{ctaTitle}</p>
          <p class="text-lg leading-[1.55] text-text-muted">{ctaSub}</p>
        </div>

        <span class="inline-block">
          <a href="/contact" class={buttonVariants({ variant: 'brand', size: 'cta', className: 'shine' })}>
            Start a project
          </a>
        </span>
      </div>
    )}

  </div>
</section>

<style>
  /* Single connector rail behind the number nodes. Sits at the vertical
     centre of the h-9 (2.25rem) badges and reads as one timeline through the
     ordered steps. */
  .process-connector {
    position: absolute;
    top: 1.125rem;
    left: 0;
    right: 0;
    height: 1px;
    background: color-mix(in oklab, var(--color-accent) 35%, transparent);
    transform: scaleX(1);
    transform-origin: left;
    z-index: 0;
  }

  /* Draw the rail across as the section scrolls into view. Progressive
     enhancement: only where scroll-timeline is supported and motion is
     allowed; otherwise the rail is simply fully drawn from first paint. */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .process-connector {
        transform: scaleX(0);
        animation: connector-draw linear both;
        animation-timeline: view();
        animation-range: entry 10% cover 35%;
      }
    }
  }
  @keyframes connector-draw {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* Closing band only (homepage): in dark mode fade the band's bottom to solid
     navy so it merges into the navy footer below instead of ending on the
     aurora's amber glow. Sits above the aurora (z 0 vs the ::before at z -1)
     and below the content (z 10). The soft /services variant is mid-page, so it
     gets no fade. */
  :global(.dark) .process-band--closing::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 45%;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--color-primary));
  }
</style>
