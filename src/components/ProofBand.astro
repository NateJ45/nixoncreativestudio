---
// Safe to edit. The positioning line is curation-framed and carries NO project
// count, so the portfolio reads as selected work rather than a running (still
// small) total. Client names are pulled live from the case-studies collection.
/* ============================================================================
   Proof Band  [revamp]
   ============================================================================
   A credibility strip between Act 1 (Hero) and Act 2 (Selected Work). It does
   the proof job WITHOUT the SaaS hero-metric template (big-number / small-label
   / count-up triplet) that the earlier version used. That pattern is an AI tell,
   and two of its three figures were empty calories ("100% owner-built" is a
   tautology for a sole owner; "4 sectors" is thin). It is replaced by:

     1. One honest, specific positioning line, framed as a selection of work
        (no project count, so the page does not advertise a small running total)
        rather than an animated KPI.
     2. A continuous marquee of real client names, drawn from the case-studies
        collection so it stays in sync as the portfolio grows. The marquee is
        decorative (aria-hidden) and paired with an sr-only list so screen
        readers get the same information without the motion.
   ============================================================================ */

import { getCollection } from 'astro:content';

const studies = await getCollection('case-studies');

// Distinct client names for the marquee, in newest-first order.
const clients = [
  ...new Set(
    studies
      .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
      .map((s) => s.data.client)
  ),
];

// Duplicated once so the CSS marquee can loop seamlessly at translateX(-50%).
const marqueeItems = [...clients, ...clients];
---

<section class="bg-mesh-soft overflow-hidden bg-bg-soft py-2xl" aria-label="Studio at a glance">

  <!-- Curation-framed positioning line, not a KPI grid: no project count, so
       the page reads as selected work rather than a running (and still small)
       total. The "one person, start to finish" is the real differentiator. -->
  <div class="ncs-container">
    <p
      class="mx-auto max-w-[44ch] text-center text-h4 leading-[1.3] text-heading"
      data-reveal
    >
      A selection of work for churches, schools, nonprofits, and small businesses around Cincinnati,
      each project designed, built, and photographed by <span class="text-link">one person</span>,
      start to finish.
    </p>
  </div>

  <!-- Client marquee. Decorative; the sr-only list below carries the same
       names for assistive tech. -->
  <div class="proof-marquee mt-2xl" data-reveal="fade" aria-hidden="true">
    <div class="proof-track">
      {marqueeItems.map((client) => (
        <span class="proof-item font-display text-2xl uppercase tracking-[0.03em] text-text-muted">
          {client}
        </span>
      ))}
    </div>
  </div>

  <p class="sr-only">Clients include {clients.join(', ')}.</p>

</section>

<style>
  /* Edge-faded, continuously scrolling client marquee. The track is two
     copies of the client list, so translateX(-50%) lands exactly on the
     start of the second copy for a continuous loop with no visible seam. */
  .proof-marquee {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
  }

  .proof-track {
    display: inline-flex;
    width: max-content;
    gap: 3.5rem;
    padding-inline: 1.75rem;
    white-space: nowrap;
  }

  .proof-item {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  /* Brand-dot separator before each name. */
  .proof-item::before {
    content: "";
    position: absolute;
    left: -1.9rem;
    height: 0.4rem;
    width: 0.4rem;
    border-radius: 9999px;
    background: var(--color-accent);
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: no-preference) {
    .proof-track {
      animation: proof-marquee 45s linear infinite;
    }
    .proof-marquee:hover .proof-track {
      animation-play-state: paused;
    }
  }

  @keyframes proof-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
