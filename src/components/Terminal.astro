---
// Safe to edit (the `lines` below are the content).
/* ============================================================================
   Terminal  [About-page motif]
   ============================================================================
   A small, honest terminal window that does two jobs at once:

   1. It signals technical depth, this studio site is custom-built, not pulled
      from a page builder, without the developer-portfolio cliche of fake
      scrolling code.
   2. It makes the RANGE clear: the `platforms` command shows that a custom-coded build is
      one option among several (WordPress, Squarespace), and that the
      platform is chosen to fit the client, not the designer's habits. So a
      visitor never reads "Astro is the only thing he does."

   Everything here is HONEST: the platforms are the ones the studio actually works
   in (see the "right platform for the job" principle), and the build claims are
   real (this site is custom-coded on Astro/Tailwind/TypeScript, 100 on
   accessibility, deployed to Cloudflare). If a claim stops being true, change it.

   The lines reveal in sequence on scroll via the shared [data-reveal] system
   (reduced-motion safe and visible without JS), and a cursor blinks on the final
   prompt. The whole window is decorative for assistive tech (aria-hidden); the
   sr-only paragraph after it carries the same message in plain language.

   To edit: change `title` and `lines`. A line's `type` is one of:
     cmd   a $-prompted command (white)
     ok    a checkmarked result line (amber check)
     out   a plain output line (muted)
     note  a # comment line (quiet, italic)
     list  a row of highlighted words from `items` (used for the platforms)
   ============================================================================ */

interface Line {
  type: 'cmd' | 'ok' | 'out' | 'note' | 'list';
  text?: string;
  items?: string[];
}

const title = 'nathan@nixon-creative-studio: ~/studio';

const lines: Line[] = [
  { type: 'cmd', text: 'whoami' },
  { type: 'out', text: 'Nathan. Strategy, design, photography, and code, all from one person.' },

  // The range: a custom-coded build is one option among several. Keep this in sync with
  // the "right platform for the job" principle on the About page.
  { type: 'cmd', text: 'platforms' },
  { type: 'list', items: ['custom-coded', 'WordPress', 'Squarespace'] },
  { type: 'note', text: '# I pick whichever one fits your budget and your team, not my habits.' },

  // This site as the proof that the custom-coded option is done well.
  { type: 'cmd', text: 'npm run build' },
  { type: 'ok',  text: 'This site is custom-coded on Astro + Tailwind, typed in TypeScript' },
  { type: 'ok',  text: 'A real 100 on accessibility, fast on any connection' },
  { type: 'ok',  text: 'Shipped to Cloudflare, then handed to you to own outright' },
];

// Plain-language equivalent for screen readers (the window itself is aria-hidden).
const srSummary =
  'How the studio works: one person doing strategy, design, photography, and code. ' +
  'I build on whichever platform fits the project, custom-coded, WordPress, ' +
  'or Squarespace, not just one. This site is custom-coded on Astro, Tailwind, ' +
  'and TypeScript, a real 100 on accessibility, deployed to Cloudflare and handed ' +
  'to you to own outright.';

// Reveal cadence: each line eases in a beat after the previous one, so it reads
// like the session is being typed out.
const step = 170;
const baseDelay = 120;
---

<div class="terminal" aria-hidden="true" data-reveal="scale">
  <div class="terminal-bar">
    <span class="terminal-dots">
      <span></span><span></span><span></span>
    </span>
    <span class="terminal-title">{title}</span>
  </div>

  <div class="terminal-body">
    {lines.map((line, i) => (
      <p class:list={['terminal-line', `is-${line.type}`]} data-reveal style={`--reveal-delay: ${baseDelay + i * step}ms;`}>
        {line.type === 'cmd' && <span class="terminal-prompt">$ </span>}
        {line.type === 'ok' && <span class="terminal-check">✓ </span>}
        {line.type === 'list' ? (
          <span class="terminal-list">
            {line.items?.map((item) => <span class="terminal-plat">{item}</span>)}
          </span>
        ) : (
          <span>{line.text}</span>
        )}
      </p>
    ))}
    <p class="terminal-line is-cmd" data-reveal style={`--reveal-delay: ${baseDelay + lines.length * step}ms;`}>
      <span class="terminal-prompt">$ </span><span class="terminal-cursor"></span>
    </p>
  </div>
</div>

<p class="sr-only">{srSummary}</p>

<style>
  /* Always-dark surface so it reads as a real code window on either theme. */
  .terminal {
    border-radius: 0.75rem;
    overflow: hidden;
    background: #0b0e14;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow-frame);
  }

  /* Window chrome: traffic-light dots + a path title, matching the hero device. */
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.8rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .terminal-dots {
    display: inline-flex;
    gap: 0.35rem;
    flex: none;
  }
  .terminal-dots span {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 9999px;
  }
  .terminal-dots span:nth-child(1) { background: #ff5f57; }
  .terminal-dots span:nth-child(2) { background: #febc2e; }
  .terminal-dots span:nth-child(3) { background: #28c840; }
  .terminal-title {
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .terminal-body {
    padding: 1rem 1.1rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.86);
  }

  .terminal-line {
    margin: 0;
  }
  /* A little air before each new command so the commands read as separate. */
  .terminal-line.is-cmd {
    margin-top: 0.55rem;
    color: #ffffff;
  }
  .terminal-line.is-cmd:first-child {
    margin-top: 0;
  }
  .terminal-line.is-out { color: rgba(255, 255, 255, 0.7); }
  .terminal-line.is-ok  { color: rgba(255, 255, 255, 0.82); }
  /* A shell comment: quiet and italic so it reads as an aside, not a result.
     Alpha holds at 0.52 (not lower) so the small italic text clears WCAG AA
     contrast on the terminal's dark surface while staying quieter than the
     command/output lines above. */
  .terminal-line.is-note {
    margin-top: 0.15rem;
    color: rgba(255, 255, 255, 0.52);
    font-style: italic;
  }

  .terminal-prompt {
    color: var(--color-secondary);
    font-weight: 600;
  }
  .terminal-check {
    color: var(--color-tertiary);
  }

  /* Platform list: the words pop in sky so the range registers at a glance. */
  .terminal-list {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.1rem 1.15rem;
  }
  .terminal-plat {
    color: var(--color-secondary);
  }

  /* Blinking block cursor on the final prompt. Static (no blink) under reduced
     motion; the cursor block still shows so the prompt reads as a terminal. */
  .terminal-cursor {
    display: inline-block;
    width: 0.55rem;
    height: 1.05em;
    vertical-align: text-bottom;
    background: var(--color-secondary);
  }
  @media (prefers-reduced-motion: no-preference) {
    .terminal-cursor {
      animation: terminal-blink 1.1s steps(1, end) infinite;
    }
  }
  @keyframes terminal-blink {
    0%, 50%      { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }
</style>
