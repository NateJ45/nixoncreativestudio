---
// Safe to edit.
/* ============================================================================
   DesignerNote
   ============================================================================
   A short, signed note from Nathan reflecting on a case study, rendered from the
   `designerNote` frontmatter string. It replaces the old prose "Reflections"
   section with a personal, signed aside: the human voice behind the work, which
   is a real differentiator for a one-person studio.

   The signature is a visual treatment (the owner name from site.ts in the
   display face), so the frontmatter only carries the note text. Keep the note
   honest and specific to the project; it was drafted from each study's existing
   "Reflections" prose and honesty-checked before wiring in.

   Rendered by src/pages/work/[slug].astro. To edit, change `designerNote:` in the
   case study's frontmatter.
   ============================================================================ */
import { site } from '../data/site';

interface Props {
  /** The note body (1-3 sentences). The signature is added below it. */
  note: string;
}
const { note } = Astro.props;
---

<aside class="ncs-note" aria-label="A note from the designer" data-reveal>
  <p class="ncs-note-eyebrow">A note from the designer</p>
  <p class="ncs-note-body">{note}</p>
  <p class="ncs-note-sign">{site.ownerName}</p>
</aside>

<style>
  /* No side-tab border (a known AI tell). The note reads as signed through type
     alone: a quiet mono eyebrow, an editorial italic body, and the owner name
     set in the display face like a signature. The parent container in
     [slug].astro already supplies the separating top rule. */
  .ncs-note {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 60ch;
  }
  .ncs-note-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted-foreground);
  }
  .ncs-note-body {
    margin: 0;
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--color-heading);
    font-style: italic;
  }
  .ncs-note-sign {
    margin: 0.25rem 0 0;
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--color-heading);
  }
</style>
