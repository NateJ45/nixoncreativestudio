---
// Safe to edit.
/* ============================================================================
   Hero (Act 1 of the three-act homepage)  [revamp]
   ============================================================================
   A full-viewport (100svh), kinetic opening. Two columns at lg: the positioning
   headline + CTAs on the left, a crossfading showcase of real shipped client
   sites (HeroShowcase) on the right, so real work sits above the fold. Below lg
   the showcase is hidden and the headline carries the hero.

   Background: a domain-warped WebGL brand-color flow (HeroCanvas, cursor
   reactive) over an animated aurora + grain fallback. A left-favoring scrim
   keeps the left-column copy legible while the right stays open for the flow
   and the showcase.

   Motion (all reduced-motion safe via globals.css section 6 + the canvas guard):
     - WebGL flow / aurora drift in the background
     - staggered entrance reveal on the copy cluster (data-reveal + delays)
     - solid amber (--tertiary) accent phrase on the headline (no gradient text)
     - magnetic + shine primary CTA
     - animated scroll cue at the base

   To swap in a real Nathan-shot hero photo as the background:
     1. Drop the image at src/assets/brand/hero.jpg (jpg, png, or webp).
     2. Uncomment the Astro <Image /> import + the <Image /> tag below; it
        layers above the aurora/WebGL, which then read as an edge bloom.
     3. Optionally soften or drop the WebGL once a photo carries the surface.

   Content is hardcoded here on purpose. The hero is bespoke.
   ============================================================================ */

import { Button } from './ui/button';
import HeroCanvas from './HeroCanvas';
import HeroShowcase from './HeroShowcase.astro';
// import { Image } from 'astro:assets';
// import heroPhoto from '../assets/brand/hero.jpg';

// Headline statement. The trailing phrase is lifted into a gradient span.
const statementLead = 'I make websites that';
const statementAccent = 'pull their weight.';

// One short positioning line that names audience and region.
const positioning = 'For churches, schools, and small businesses in the Cincinnati region.';
---

<section
  class="hero relative isolate flex min-h-screen flex-col overflow-hidden bg-primary text-primary-foreground"
  style="min-height: 100svh;"
  aria-labelledby="hero-statement"
  data-hero-dark
>

  <!-- ====================================================================
       Background surface. Either the real photograph (once it lands) or the
       animated aurora + grain. The scrim deepens toward the bottom so the
       overlaid copy always has contrast.
       ==================================================================== -->
  <div class="absolute inset-0 -z-10" aria-hidden="true">

    <!-- Real photograph slot. Uncomment when src/assets/brand/hero.jpg lands.
    <Image
      src={heroPhoto}
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
    -->

    <!-- Animated aurora mesh + film grain. This is the fallback / base layer:
         it paints immediately (SSR, no JS) and shows whenever the WebGL canvas
         below it is not active (reduced motion, no WebGL, before hydration). -->
    <div class="bg-aurora grain absolute inset-0"></div>

    <!-- WebGL brand-cloud shader. Layers over the aurora once hydrated; renders
         nothing (so the aurora shows) under reduced motion or without WebGL,
         and pauses when the hero is off-screen. client:only because R3F does
         not server-render. -->
    <HeroCanvas client:only="react" />

    <!-- Left-favoring scrim. Darkens the left (where the headline + CTAs sit)
         so copy stays legible, and fades toward the right so the WebGL flow and
         the showcase frame read clearly. A faint bottom darken anchors the
         scroll cue. -->
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/45 to-primary/10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"></div>

  </div>

  <!-- ====================================================================
       Foreground content. Full-viewport hero (100svh), vertically centered.
       Two columns at lg: the headline cluster on the left, the crossfading
       portfolio showcase on the right. Below lg the showcase is hidden and the
       headline carries the hero. The studio wordmark lives in the sticky header
       (navy over this hero), so there is no second wordmark here.
       ==================================================================== -->
  <div class="ncs-container relative z-10 flex flex-1 items-center py-2xl">
    <div class="grid w-full items-center gap-2xl lg:grid-cols-[1.05fr_0.95fr]">

      <!-- Left: headline + positioning + CTAs, choreographed in. -->
      <div class="flex max-w-[40ch] flex-col gap-m">

        <h1
          id="hero-statement"
          class="text-primary-foreground leading-[0.92]"
          data-reveal
          style="--reveal-delay: 120ms; text-wrap: balance;"
        >
          {statementLead}{' '}
          <span class="text-tertiary">{statementAccent}</span>
        </h1>

        <p
          class="text-lg leading-[1.5] text-primary-foreground/90 sm:text-xl"
          data-reveal
          style="--reveal-delay: 240ms;"
        >
          {positioning}
        </p>

        <div
          class="mt-s flex flex-wrap items-center gap-m"
          data-reveal
          style="--reveal-delay: 360ms;"
        >

          <!-- Magnetic wrapper so the button drifts toward the cursor; the
               shine class sweeps a light band across it on hover. -->
          <span class="inline-block" data-magnetic="0.4">
            <Button asChild variant="brand" size="cta" className="shine">
              <a href="/contact">Start a project</a>
            </Button>
          </span>

          <a
            class="hero-secondary inline-flex items-center gap-s font-body font-semibold text-primary-foreground no-underline"
            href="/work/"
          >
            <span>See the work</span>
            <span aria-hidden="true" class="hero-secondary-arrow">→</span>
          </a>

        </div>

      </div>

      <!-- Right: crossfading portfolio showcase (real shipped client sites).
           Hidden below lg so the mobile hero stays focused on the headline. -->
      <div class="hidden lg:block" data-reveal="right" style="--reveal-delay: 320ms;">
        <HeroShowcase />
      </div>

    </div>
  </div>

  <!-- Animated scroll cue, centered at the base of the hero. Decorative. -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-6 z-10 flex justify-center"
    aria-hidden="true"
    data-reveal="fade"
    style="--reveal-delay: 600ms;"
  >
    <span class="scroll-cue flex h-10 w-6 items-start justify-center rounded-full border border-primary-foreground/40 p-1.5">
      <span class="scroll-cue-dot h-1.5 w-1.5 rounded-full bg-primary-foreground/80"></span>
    </span>
  </div>
</section>

<style>
  /* ----------------------------------------------------------------------
     Secondary CTA hover. Arrow slides right; opacity softens.
     ---------------------------------------------------------------------- */
  .hero-secondary-arrow {
    display: inline-block;
    transition: transform 150ms ease;
  }
  .hero-secondary:hover,
  .hero-secondary:focus-visible {
    opacity: 0.85;
  }

  /* Explicit focus ring (sky blue is ~7:1 on navy) so keyboard focus is
     clearly visible over the aurora rather than relying on the UA default. */
  .hero-secondary:focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .hero-secondary:hover .hero-secondary-arrow,
  .hero-secondary:focus-visible .hero-secondary-arrow {
    transform: translateX(0.25rem);
  }

  /* ----------------------------------------------------------------------
     Scroll cue. The dot bobs down inside the mouse-shaped outline.
     ---------------------------------------------------------------------- */
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue-dot {
      animation: scroll-cue 1.6s ease-in-out infinite;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-secondary-arrow {
      transition: none;
    }
    .hero-secondary:hover .hero-secondary-arrow,
    .hero-secondary:focus-visible .hero-secondary-arrow {
      transform: none;
    }
  }
</style>
