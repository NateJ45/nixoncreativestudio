---
// Safe to edit.
/* ============================================================================
   Hero (Act 1 of the homepage)  [revamp]
   ============================================================================
   A full-viewport (100svh), kinetic opening. The layout is LAYERED, not a
   two-column split: a right-weighted "scene" of real shipped client sites
   (HeroShowcase) sits BEHIND an oversized headline. A left-strong scrim keeps
   the headline + CTAs fully legible even where the screenshots sit under them,
   while the far-right images stay crisp. Below lg the scene is hidden and the
   headline carries the hero.

   Why layered instead of side-by-side: a strict right column made the cascade
   either clip at the viewport edge or leave dead space. As a scene behind the
   text, held to the site's content width (.ncs-container) so its right edge
   lines up with the header nav, it reads as one composed image without bleeding
   into the page margins.

   Stacking (the section is `isolate`, so these z-indexes are local):
     z-0  background: animated aurora + WebGL flow
     z-1  showcase scene (right-weighted, contained)
     z-2  scrim (left-strong, fades right) + bottom darken
     z-10 copy + scroll cue

   The copy container is click-through (pointer-events-none) so the showcase
   behind it stays hoverable on the right; the copy column re-enables pointer
   events for its own links.

   Legibility over the images comes from three things together: the left-strong
   scrim, a soft text-shadow on the headline, and the densest part of the
   cascade sitting to the right, away from the headline's core.

   To swap in a real Nathan-shot hero photo as the background: drop it at
   src/assets/brand/hero.jpg and uncomment the <Image /> import + tag below; it
   layers over the aurora/WebGL.

   Content is hardcoded here on purpose. The hero is bespoke.
   ============================================================================ */

import { Button } from './ui/button';
import HeroCanvas from './HeroCanvas';
import HeroShowcase from './HeroShowcase.astro';
// import { Image } from 'astro:assets';
// import heroPhoto from '../assets/brand/hero.jpg';

// Headline statement. The trailing phrase is lifted into a solid amber span.
const statementLead = 'I make websites that';
const statementAccent = 'pull their weight.';

// One short positioning line that names audience and region.
const positioning = 'For churches, schools, and small businesses in the Cincinnati region.';
---

<section
  class="hero relative isolate flex min-h-screen flex-col overflow-hidden bg-primary text-primary-foreground"
  style="min-height: 100svh;"
  aria-labelledby="hero-statement"
  data-hero-dark
>

  <!-- ====================================================================
       z-0 Background: animated aurora + grain (paints immediately, SSR) with
       the WebGL brand-cloud flow layered over it once hydrated. Real photo
       slot is commented until src/assets/brand/hero.jpg lands.
       ==================================================================== -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <!--
    <Image src={heroPhoto} alt="" class="h-full w-full object-cover" loading="eager" decoding="async" />
    -->
    <div class="bg-aurora grain absolute inset-0"></div>
    <HeroCanvas client:only="react" />
  </div>

  <!-- ====================================================================
       z-1 Showcase scene. A right-weighted layer of real client sites behind
       the headline, held inside the site's content width (.ncs-container) so
       its right edge lines up with the header nav and it never bleeds into the
       outer margins (those show the WebGL flow). Hidden below lg (mobile leads
       with the headline alone). The wrapper is pointer-events-none so the copy
       stays usable; the showcase itself re-enables them for hover/explore.
       ==================================================================== -->
  <div
    class="hero-scene pointer-events-none absolute inset-0 z-[1] hidden lg:block"
    data-reveal="fade"
    style="--reveal-delay: 320ms;"
  >
    <div class="ncs-container relative h-full">
      <div class="hero-scene-inner pointer-events-auto absolute inset-y-0 right-0 flex items-center">
        <HeroShowcase />
      </div>
    </div>
  </div>

  <!-- ====================================================================
       z-2 Scrim. Left-strong and fading right so the headline stays legible
       over the screenshots while the far-right images read clearly. Plus a
       faint bottom darken to anchor the scroll cue. Both click-through.
       ==================================================================== -->
  <div class="hero-scrim pointer-events-none absolute inset-0 z-[2]" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute inset-0 z-[2] bg-gradient-to-t from-primary/45 to-transparent"
    aria-hidden="true"
  ></div>

  <!-- ====================================================================
       z-10 Foreground copy. The container is pointer-events-none so the scene
       behind it stays hoverable on the right; the copy column re-enables
       pointer events for its links.
       ==================================================================== -->
  <div class="ncs-container pointer-events-none relative z-10 flex flex-1 items-center py-l">
    <div class="hero-copy pointer-events-auto flex max-w-[46rem] flex-col gap-m">

      <h1
        id="hero-statement"
        class="hero-headline hero-anim text-primary-foreground"
      >
        {statementLead}{' '}
        <span class="text-tertiary">{statementAccent}</span>
      </h1>

      <p
        class="hero-sub hero-anim max-w-[32ch] text-xl leading-[1.45] text-primary-foreground/90 sm:text-2xl"
        style="--enter-delay: 120ms;"
      >
        {positioning}
      </p>

      <div class="hero-anim flex flex-wrap items-center gap-m" style="--enter-delay: 240ms;">

        <!-- Magnetic wrapper so the button drifts toward the cursor; the shine
             class sweeps a light band across it on hover. -->
        <span class="inline-block" data-magnetic="0.4">
          <Button asChild variant="brand" size="cta" className="shine">
            <a href="/contact">Start a project</a>
          </Button>
        </span>

        <a
          class="hero-secondary inline-flex items-center gap-s font-body text-lg font-semibold text-primary-foreground no-underline"
          href="/work/"
        >
          <span>See the work</span>
          <span aria-hidden="true" class="hero-secondary-arrow">→</span>
        </a>

      </div>

    </div>
  </div>

  <!-- Animated scroll cue, centered at the base of the hero. Decorative. -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-6 z-10 flex justify-center"
    aria-hidden="true"
    data-reveal="fade"
    style="--reveal-delay: 600ms;"
  >
    <span class="scroll-cue flex h-10 w-6 items-start justify-center rounded-full border border-primary-foreground/40 p-1.5">
      <span class="scroll-cue-dot h-1.5 w-1.5 rounded-full bg-primary-foreground/80"></span>
    </span>
  </div>
</section>

<style>
  /* ----------------------------------------------------------------------
     Hero headline. Deliberately oversized (well past the global h1 clamp):
     this is the showpiece and the LCP element. min(vw, vh) so it scales to
     viewport WIDTH on tall windows but is capped by HEIGHT on short laptops,
     keeping the cluster inside 100svh. The text-shadow is what lets it stay
     readable where the screenshots sit beneath it: a tight shadow for a crisp
     edge plus a soft navy glow that separates the letters from busy images.
     ---------------------------------------------------------------------- */
  .hero-headline {
    font-size: clamp(3.25rem, min(9.5vw, 15vh), 9.5rem);
    line-height: 0.86;
    text-wrap: balance;
    text-shadow:
      0 1px 2px rgba(10, 22, 40, 0.5),
      0 6px 34px rgba(10, 22, 40, 0.55);
  }

  /* Positioning line sits in the strong part of the scrim, so it only needs a
     soft halo to stay crisp if an image edge creeps under it. */
  .hero-sub {
    text-shadow: 0 1px 14px rgba(10, 22, 40, 0.6);
  }

  /* ----------------------------------------------------------------------
     Hero copy entrance. The copy holds the LCP headline, so it is animated
     with a CSS-only entrance that runs at first render rather than the JS
     reveal system. The reveal observer fires only after the page scripts
     run, and on a throttled phone (behind the WebGL bundle) that pushed the
     headline's paint past 6s. A CSS animation leaves opacity:0 within the
     first frame, so LCP lands at first paint instead. Base state is visible,
     so reduced-motion and no-JS visitors get the copy immediately; the
     keyframes only play when motion is OK. The headline carries no delay so
     it is the first thing to paint; the sub and CTAs stagger behind it.
     ---------------------------------------------------------------------- */
  @media (prefers-reduced-motion: no-preference) {
    .hero-anim {
      opacity: 0;
      animation: hero-copy-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: var(--enter-delay, 0ms);
    }
  }
  @keyframes hero-copy-in {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ----------------------------------------------------------------------
     Showcase scene. A right-weighted band; a small right inset keeps the
     cascade from touching the viewport edge so it reads as contained, not
     bled. Width is generous so the work is prominent.
     ---------------------------------------------------------------------- */
  .hero-scene-inner {
    /* Right-aligned within .ncs-container, so the cascade ends at the content
       edge (level with the header nav) and the wide-screen margins stay clear
       for the WebGL flow. */
    width: 56%;
  }

  /* ----------------------------------------------------------------------
     Scrim. Solid navy on the left (headline core), fading to transparent on
     the right so the far images stay crisp. Tuned so the headline's right
     edge still sits over enough navy to read with its shadow.
     ---------------------------------------------------------------------- */
  .hero-scrim {
    background: linear-gradient(
      to right,
      var(--color-primary) 0%,
      var(--color-primary) 30%,
      color-mix(in oklab, var(--color-primary) 75%, transparent) 50%,
      color-mix(in oklab, var(--color-primary) 32%, transparent) 68%,
      transparent 86%
    );
  }

  /* ----------------------------------------------------------------------
     Secondary CTA hover. Arrow slides right; opacity softens.
     ---------------------------------------------------------------------- */
  .hero-secondary-arrow {
    display: inline-block;
    transition: transform 150ms ease;
  }
  .hero-secondary:hover,
  .hero-secondary:focus-visible {
    opacity: 0.85;
  }

  /* Explicit focus ring (sky blue is ~7:1 on navy) so keyboard focus is clearly
     visible over the scene rather than relying on the UA default. */
  .hero-secondary:focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .hero-secondary:hover .hero-secondary-arrow,
  .hero-secondary:focus-visible .hero-secondary-arrow {
    transform: translateX(0.25rem);
  }

  /* ----------------------------------------------------------------------
     Scroll cue. The dot bobs down inside the mouse-shaped outline.
     ---------------------------------------------------------------------- */
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue-dot {
      animation: scroll-cue 1.6s ease-in-out infinite;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-secondary-arrow {
      transition: none;
    }
    .hero-secondary:hover .hero-secondary-arrow,
    .hero-secondary:focus-visible .hero-secondary-arrow {
      transform: none;
    }
  }
</style>
