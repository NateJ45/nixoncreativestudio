---
// Safe to edit.
/* ============================================================================
   Section 01 | Hero
   ============================================================================
   First impression. Two columns on large screens (copy on the left at a
   1.2fr share, portrait on the right at 1fr), single column on mobile.

   Left column: small mono overline "01 / Hello.", a large Bebas Neue
   statement headline, a locale tag, a two-sentence positioning paragraph,
   then a primary button to /contact and a secondary link to /work.

   Right column: portrait placeholder for now. Once Nathan has a real
   headshot in src/assets/brand/, swap the placeholder div for an
   Astro <Image />.

   Content is hardcoded here on purpose. The Hero is bespoke, not a
   candidate for content collections or props.
   ============================================================================ */

// Pull the public address through the site data module so the locale tag
// updates with the rest of the site if Nathan ever changes how he lists
// his service area.
import { site } from '../data/site';

// shadcn Button. Used here for the primary "Start a project" CTA so the
// button styling lives in one place site-wide (CtaBanner and the contact
// form submit use the same variant + size).
import { Button } from './ui/button';

// Headline statement. Edit in place when the positioning sharpens.
const statement = 'I make websites that pull their weight.';

// Two-sentence positioning paragraph. Conversational, not corporate.
const intro = `${site.studioName} designs and builds modern websites for small businesses, nonprofits, churches, and schools in the Cincinnati region. Strategy first, then design, then code, all done by one person who cares about how the whole thing works together.`;

// Locale tag under the headline. Small detail, but it tells visitors
// quickly that this is a local studio, not a faceless agency.
const locale = `${site.address} · Greater Cincinnati`;
---

<section class="py-2xl" aria-labelledby="hero-statement">
  <!-- Two-column grid at >= 56rem (about 896px). Below that, it collapses
       to a single column so the portrait and copy don't squeeze each
       other on tablets. Custom breakpoint via arbitrary value because
       56rem sits between Tailwind's md (48rem) and lg (64rem) defaults. -->
  <div class="ncs-container grid grid-cols-1 items-center gap-xl min-[56rem]:grid-cols-[1.2fr_1fr]">

    <!-- Left column: copy stack. -->
    <div class="flex flex-col gap-m">

      <!-- Overline: "01" + "Hello." sitting on one line, baseline aligned. -->
      <p class="inline-flex items-baseline gap-s text-[0.95rem] text-text-muted">
        <span class="font-mono text-sm tracking-[0.05em]">01</span>
        <span class="font-body">Hello.</span>
      </p>

      <!-- Statement headline. Inherits size from the global h1 rule.
           Tighter line-height than h1 default since the headline runs
           multiple lines and should read as a single block. -->
      <h1 id="hero-statement" class="max-w-[18ch] leading-[0.95]">
        {statement}
      </h1>

      <!-- Locale line. Small, muted, sits below the headline as a place tag. -->
      <p class="text-[0.95rem] tracking-[0.02em] text-text-muted">
        {locale}
      </p>

      <!-- Positioning paragraph. Capped to about 58 characters so the
           line stays comfortable to read at the desktop heading size. -->
      <p class="max-w-[58ch] text-lg leading-[1.6] text-text">
        {intro}
      </p>

      <!-- CTA row. Primary button + secondary link, baseline aligned with
           flex-wrap so the link drops to a new line on narrow screens. -->
      <div class="mt-s flex flex-wrap items-center gap-m">

        <!-- Primary button. asChild forwards Button's classes to the <a>
             inside so the link gets the brand styling + focus ring while
             remaining a real anchor for keyboard navigation and prefetch.
             Same variant + size as CtaBanner and the contact submit. -->
        <Button asChild variant="brand" size="cta">
          <a href="/contact">Start a project</a>
        </Button>

        <!-- Secondary text link with arrow. card-link stays as a global
             utility class for the arrow + hover slide; shadcn doesn't
             have a direct equivalent and the pattern repeats elsewhere. -->
        <a class="card-link" href="/work/">See selected work</a>

      </div>

    </div>

    <!-- Right column: portrait placeholder. 4:5 aspect, soft brand
         gradient, rounded corners. Swap for an Astro <Image /> when
         the real headshot lands in src/assets/brand/. -->
    <div
      class="aspect-[4/5] w-full rounded-lg bg-gradient-to-br from-bg-soft to-secondary"
      role="img"
      aria-label="Portrait placeholder"
    ></div>

  </div>
</section>
